#!/usr/bin/env bash
# Print one-line git log for commits in current branch vs its base.
#
# Uses git-branch-base to find the base ref.
# This works correctly for worktrees and fresh clones that don't have a
# tracking branch set.
#
# Usage: git-branch-log
#
# Exit codes:
#   0  always (best-effort output)

set -uo pipefail

base=$(git-branch-base 2> /dev/null) || {
  echo "No commits found"
  exit 0
}

out=$(git log --oneline "${base}..HEAD" 2> /dev/null)
if [[ -n "$out" ]]; then
  printf '%s\n' "$out"
else
  echo "No commits found"
fi
