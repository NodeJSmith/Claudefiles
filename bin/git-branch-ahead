#!/usr/bin/env bash
# Report how many commits the current branch has ahead of the default branch.
#
# Ahead count = commits reachable from HEAD but not from origin/<default>,
# i.e. `git rev-list --count origin/<default>..HEAD`.
#
# Mirror of `git-branch-behind` — same resolution, same flags, opposite
# direction. See git-branch-behind for design rationale (fetch timeout,
# graceful degradation, exit codes).
#
# Depends on `git-default-branch` for the default branch name.
#
# Usage: git-branch-ahead [--json] [--no-fetch]
#
# Options:
#   --json       Emit a JSON object instead of a human-readable line.
#   --no-fetch   Skip the network fetch; compare against local refs only.
#
# Exit codes:
#   0   up to date (ahead == 0), or could not verify
#   10  ahead (ahead > 0)
#   1   hard error: not a git repo, no origin remote, or default unresolvable

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
  cat << 'EOF'
Usage: git-branch-ahead [--json] [--no-fetch]

Report how many commits the current branch has ahead of the default branch
(i.e. unpushed work relative to the base).

Fetches the default branch from origin, then counts how many commits HEAD has
ahead of origin/<default>. Does not block on a failed fetch — reports against
the last-known state and flags that the remote could not be reached.

Options:
  --json       Emit a JSON object instead of a human-readable line.
  --no-fetch   Skip the network fetch; compare against local refs only.

Exit codes:
  0   up to date (or could not verify)
  10  ahead by one or more commits
  1   not a git repo / no origin / default branch unresolvable

Examples:
  git-branch-ahead                 # "up to date with origin/main"
  git-branch-ahead --json          # {"ahead":3,"default_branch":"main",...}
  git-branch-ahead && echo clean   # exit 0 only when up to date
EOF
  exit 0
}

set -uo pipefail

# Bound the fetch so a reachable-but-slow host can't wedge an unattended caller.
FETCH_TIMEOUT_SECONDS=15

emit_json=0
do_fetch=1
for arg in "$@"; do
  case "$arg" in
    --json) emit_json=1 ;;
    --no-fetch) do_fetch=0 ;;
    *)
      echo "git-branch-ahead: unknown argument: $arg" >&2
      exit 1
      ;;
  esac
done

# Must be inside a git repo with an origin remote.
if ! git rev-parse --git-dir > /dev/null 2>&1; then
  echo "fatal: not a git repository" >&2
  exit 1
fi
if ! git remote get-url origin > /dev/null 2>&1; then
  echo "fatal: no remote named 'origin'" >&2
  exit 1
fi

default=$(git-default-branch --no-network 2> /dev/null) || default=""
# git-default-branch exits non-zero when it can't decide; fall back to the
# network resolver, and let the emptiness check below report a hard failure.
if [[ -z "$default" ]]; then
  default=$(git-default-branch 2> /dev/null) || default=""
fi
if [[ -z "$default" ]]; then
  echo "fatal: could not determine default branch for 'origin'" >&2
  exit 1
fi

current=$(git branch --show-current 2> /dev/null) || current=""

# Fetch the default branch so the comparison reflects the real remote state.
# A hung credential/host prompt is worse than a stale answer here, so never
# prompt — fail fast and fall through to the last-known remote-tracking ref.
# fetch_ok==0 means the ahead count is NOT backed by a fresh fetch (network
# failure or --no-fetch); callers reading JSON treat it as "freshness unknown".
# GIT_TERMINAL_PROMPT=0 handles an *unreachable* host; `timeout` (when present)
# handles a *reachable-but-slow* one — a stalled socket or hanging proxy would
# otherwise wedge an unattended caller indefinitely.
fetch_ok=1
if ((do_fetch)); then
  fetch_cmd=(git fetch --quiet origin "$default")
  command -v timeout > /dev/null 2>&1 && fetch_cmd=(timeout "$FETCH_TIMEOUT_SECONDS" "${fetch_cmd[@]}")
  if ! GIT_TERMINAL_PROMPT=0 "${fetch_cmd[@]}" > /dev/null 2>&1; then
    fetch_ok=0
  fi
else
  # --no-fetch: no fetch attempted, so freshness is unverified — same flag, deliberate skip.
  fetch_ok=0
fi
fetch_ok_json=$( ((fetch_ok)) && echo true || echo false)

base_ref="origin/$default"
if ! git rev-parse --verify --quiet "$base_ref" > /dev/null 2>&1; then
  if ((emit_json)); then
    printf '{"current":"%s","default_branch":"%s","base_ref":null,"ahead":null,"fetch_ok":%s,"up_to_date":null}\n' \
      "$current" "$default" "$fetch_ok_json"
  else
    suffix=""
    [[ -n "$current" ]] && suffix=" (on $current)"
    echo "could not verify: no $base_ref ref available$suffix"
  fi
  exit 0
fi

ahead=$(git rev-list --count "${base_ref}..HEAD" 2> /dev/null) || ahead=""
if [[ -z "$ahead" ]]; then
  echo "fatal: could not compute commits ahead of $base_ref" >&2
  exit 1
fi

if ((emit_json)); then
  up_to_date=$([[ "$ahead" -eq 0 ]] && echo true || echo false)
  printf '{"current":"%s","default_branch":"%s","base_ref":"%s","ahead":%d,"fetch_ok":%s,"up_to_date":%s}\n' \
    "$current" "$default" "$base_ref" "$ahead" "$fetch_ok_json" "$up_to_date"
else
  suffix=""
  if ((!fetch_ok)); then
    if ((do_fetch)); then
      suffix=" (could not reach origin; based on last fetch)"
    else
      suffix=" (local refs only; --no-fetch)"
    fi
  fi
  if [[ "$ahead" -eq 0 ]]; then
    echo "up to date with $base_ref${suffix}"
  else
    plural=$([[ "$ahead" -eq 1 ]] && echo commit || echo commits)
    echo "$ahead $plural ahead of $base_ref${suffix}"
  fi
fi

[[ "$ahead" -gt 0 ]] && exit 10
exit 0
