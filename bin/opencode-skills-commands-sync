#!/usr/bin/env python3
"""Generate OpenCode slash-command wrappers for user-invocable Claudefiles skills.

OpenCode can load Claude-style skills well enough when prompted, but those skills do
not appear in the `/` command picker. This bridge generates one lightweight command
per user-invocable skill, so `/mine-debug` and friends are discoverable while the
skill file remains the source of truth.
"""

import argparse
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
SKILL_DIRS = ("skills", "skills-impeccable", "skills-cli")
GENERATED_MARKER = (
    "<!-- GENERATED BY opencode-skills-commands-sync — DO NOT EDIT MANUALLY. -->"
)


def split_frontmatter(text: str) -> tuple[dict[str, str], str]:
    if not text.startswith("---\n"):
        return {}, text
    parts = text.split("---", 2)
    if len(parts) < 3:
        return {}, text
    frontmatter: dict[str, str] = {}
    for raw_line in parts[1].splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, value = line.split(":", 1)
        frontmatter[key.strip()] = value.strip().strip("\"'")
    return frontmatter, parts[2]


def is_true(value: str | None) -> bool:
    return (value or "").strip().lower() == "true"


def quote_frontmatter(value: str) -> str:
    escaped = value.replace('"', '\\"')
    return f'"{escaped}"'


def skill_paths(repo_dir: Path) -> list[Path]:
    paths: list[Path] = []
    for dirname in SKILL_DIRS:
        base = repo_dir / dirname
        if not base.is_dir():
            continue
        paths.extend(sorted(base.glob("*/SKILL.md")))
    return sorted(paths)


def installed_skill_paths(skills_dir: Path) -> list[Path]:
    if not skills_dir.is_dir():
        return []
    return sorted(skills_dir.glob("*/SKILL.md"))


def command_body(name: str, description: str, skill_base_path: str) -> str:
    skill_path = f"{skill_base_path.rstrip('/')}/{name}/SKILL.md"
    return f"""---
description: {quote_frontmatter(description)}
---

{GENERATED_MARKER}

# {name}

Run the `{name}` skill with these arguments:

```text
$ARGUMENTS
```

Load and follow the OpenCode skill named `{name}`. Treat the command arguments above
as the skill's `$ARGUMENTS`.

If the skill is not available through OpenCode's skill loader, read the installed
Claude-compatible skill file at `{skill_path}` and execute that workflow with the
same `$ARGUMENTS` value.
"""


def load_skills(
    repo_dir: Path, skills_dir: Path | None = None
) -> list[tuple[str, str]]:
    skills: list[tuple[str, str]] = []
    paths = installed_skill_paths(skills_dir) if skills_dir else skill_paths(repo_dir)
    for path in paths:
        frontmatter, _body = split_frontmatter(path.read_text())
        if not is_true(frontmatter.get("user-invocable")):
            continue
        name = frontmatter.get("name") or path.parent.name
        description = frontmatter.get("description") or f"Run the {name} skill."
        skills.append((name, description))
    return sorted(skills)


def resolve_opencode_commands_dir(raw: str | None) -> Path:
    if raw:
        return Path(raw).expanduser().resolve()
    config_dir = os.environ.get("OPENCODE_CONFIG_DIR")
    if config_dir:
        return (Path(config_dir).expanduser() / "commands").resolve()
    return (Path.home() / ".config" / "opencode" / "commands").resolve()


def opencode_config_exists(raw_commands_dir: str | None) -> bool:
    if raw_commands_dir or os.environ.get("OPENCODE_CONFIG_DIR"):
        return True
    return (Path.home() / ".config" / "opencode").is_dir()


def in_worktree() -> bool:
    return "/.claude/worktrees/" in ROOT.as_posix()


def write_commands(
    skills: list[tuple[str, str]], commands_dir: Path, skill_base_path: str
) -> tuple[int, int, list[str]]:
    commands_dir.mkdir(parents=True, exist_ok=True)
    written = 0
    skipped = 0
    errors: list[str] = []
    expected = {f"{name}.md" for name, _description in skills}

    for name, description in skills:
        target = commands_dir / f"{name}.md"
        output = command_body(name, description, skill_base_path)
        if target.exists():
            existing = target.read_text()
            if GENERATED_MARKER not in existing:
                skipped += 1
                errors.append(
                    f"skip {target}: exists and is not generated by this tool"
                )
                continue
            if existing == output:
                continue
        target.write_text(output)
        written += 1

    for target in sorted(commands_dir.glob("*.md")):
        if target.name in expected:
            continue
        try:
            existing = target.read_text()
        except OSError:
            continue
        if GENERATED_MARKER in existing:
            target.unlink()

    return written, skipped, errors


def remove_generated_commands(commands_dir: Path) -> int:
    if not commands_dir.is_dir():
        return 0
    removed = 0
    for target in sorted(commands_dir.glob("*.md")):
        try:
            existing = target.read_text()
        except OSError:
            continue
        if GENERATED_MARKER in existing:
            target.unlink()
            removed += 1
    return removed


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate OpenCode slash-command wrappers for user-invocable Claudefiles skills."
    )
    parser.add_argument(
        "--repo-dir",
        type=Path,
        default=ROOT,
        help="Claudefiles repo directory (default: script parent repo)",
    )
    parser.add_argument(
        "--commands-dir",
        help="OpenCode commands directory (default: $OPENCODE_CONFIG_DIR/commands or ~/.config/opencode/commands)",
    )
    parser.add_argument(
        "--skills-dir",
        type=Path,
        help="installed skills directory to read instead of repo source skill directories",
    )
    parser.add_argument(
        "--skill-base-path",
        help="path text to embed in generated fallback instructions (default: --skills-dir or ${CLAUDE_CONFIG_DIR:-~/.claude}/skills)",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="print generated command names without writing",
    )
    parser.add_argument(
        "--remove-generated",
        action="store_true",
        help="remove command wrappers generated by this tool, then exit",
    )
    parser.add_argument(
        "--allow-worktree",
        action="store_true",
        help="permit writing global OpenCode commands from a worktree checkout",
    )
    args = parser.parse_args()

    commands_dir = resolve_opencode_commands_dir(args.commands_dir)

    using_default_global_commands = args.commands_dir is None and not os.environ.get(
        "OPENCODE_CONFIG_DIR"
    )
    if using_default_global_commands and in_worktree() and not args.allow_worktree:
        raise SystemExit(
            f"opencode-skills-commands-sync: refusing to generate from a worktree ({ROOT}). "
            "The global ~/.config/opencode/commands directory is machine-wide — run "
            "from the main repo, or pass --allow-worktree (or --commands-dir) to override."
        )

    if args.remove_generated:
        if not opencode_config_exists(args.commands_dir):
            print(
                "opencode-skills-commands-sync: OpenCode config dir does not exist — "
                "skipping (OpenCode not installed)."
            )
            return 0
        removed = remove_generated_commands(commands_dir)
        print(
            f"opencode-skills-commands-sync: removed {removed} generated command wrapper(s) from {commands_dir}"
        )
        return 0

    skills_dir = args.skills_dir.expanduser().resolve() if args.skills_dir else None
    skill_base_path = args.skill_base_path or (
        str(skills_dir) if skills_dir else "${CLAUDE_CONFIG_DIR:-~/.claude}/skills"
    )
    skills = load_skills(args.repo_dir, skills_dir)
    if args.list:
        print(f"OpenCode skill commands ({len(skills)}):")
        for name, _description in skills:
            print(f"  {name}")
        return 0

    if not opencode_config_exists(args.commands_dir):
        print(
            "opencode-skills-commands-sync: OpenCode config dir does not exist — "
            "skipping (OpenCode not installed)."
        )
        return 0

    written, skipped, errors = write_commands(skills, commands_dir, skill_base_path)
    for error in errors:
        print(f"opencode-skills-commands-sync: {error}", file=sys.stderr)
    print(
        f"opencode-skills-commands-sync: wrote {written} command wrapper(s) to {commands_dir} "
        f"({len(skills)} skills, {skipped} skipped)"
    )
    return 0 if skipped == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
