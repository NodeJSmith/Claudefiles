#!/usr/bin/env bash
set -euo pipefail

# Sync Claudefiles config to OpenCode via OpenPackage.
#
# Workflow:
#   1. Create a temp copy of Claudefiles without .claude/ (triggers opkg misdetection)
#   2. Run opkg install targeting opencode platform
#   3. Remap Claude model names to OpenAI equivalents
#
# Requires: npx (comes with Node.js)

# --- Configuration -----------------------------------------------------------

# Model mapping: Claude tier → OpenAI model ID
# Update these when switching to newer OpenAI models.
declare -A MODEL_MAP=(
  [opus]="openai/gpt-5.5"
  [sonnet]="openai/gpt-5.4"
  [haiku]="openai/gpt-5.4-mini"
)

# Where OpenCode reads global config
OPENCODE_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"

# Source repo
CLAUDEFILES="${CLAUDEFILES_DIR:-$HOME/Claudefiles}"

# --- Helpers ------------------------------------------------------------------

die() {
  printf '%s\n' "$1" >&2
  exit 1
}

check_deps() {
  command -v npx > /dev/null 2>&1 || die "npx not found. Install Node.js."
}

# Version-pinned to avoid silent upgrades when running against $HOME config.
opkg() {
  npx --yes opkg@0.11.3 "$@"
}

in_worktree() {
  [[ "$(cd "$CLAUDEFILES" 2> /dev/null && pwd)" == *"/.claude/worktrees/"* ]]
}

# Remap model fields in a directory.
# $1: directory to scan
# $2: "anchored" for frontmatter-only (^model: X$) or "inline" for any occurrence
remap_models() {
  local dir="$1" mode="$2"
  local count=0

  if [[ "$mode" != "anchored" && "$mode" != "inline" ]]; then
    die "remap_models: unknown mode '$mode' (expected 'anchored' or 'inline')"
  fi

  for claude_model in "${!MODEL_MAP[@]}"; do
    local openai_model="${MODEL_MAP[$claude_model]}"
    local grep_pattern sed_pattern

    if [[ "$mode" == "anchored" ]]; then
      grep_pattern="^model: ${claude_model}$"
      sed_pattern="s#^model: ${claude_model}\$#model: ${openai_model}#"
    else
      grep_pattern="model: ${claude_model}"
      sed_pattern="s#model: ${claude_model}#model: ${openai_model}#g"
    fi

    while IFS= read -r -d '' file; do
      sed -i "$sed_pattern" "$file"
      count=$((count + 1))
    done < <(grep -rlZ "$grep_pattern" "$dir" 2> /dev/null || true)
  done

  printf '%d' "$count"
}

# --- Argument parsing ---------------------------------------------------------

parse_args() {
  DRY_RUN=false
  VERBOSE=false
  ALLOW_WORKTREE=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run | -n)
        DRY_RUN=true
        shift
        ;;
      --verbose | -v)
        VERBOSE=true
        shift
        ;;
      --allow-worktree)
        ALLOW_WORKTREE=true
        shift
        ;;
      --help | -h)
        printf 'Usage: opencode-sync [--dry-run] [--verbose] [--allow-worktree]\n\n'
        printf 'Sync Claudefiles to OpenCode config via OpenPackage.\n\n'
        printf 'Options:\n'
        printf '  --dry-run, -n       Show what would be installed without writing\n'
        printf '  --verbose, -v       Show opkg output\n'
        printf '  --allow-worktree    Permit running from a worktree checkout\n'
        exit 0
        ;;
      *) die "Unknown option: $1" ;;
    esac
  done
}

# --- Staging ------------------------------------------------------------------

stage_config() {
  local tmpdir="$1"

  $VERBOSE && printf 'Staging clean copy to %s...\n' "$tmpdir"

  # Copy Claudefiles excluding: .claude/ (causes opkg platform misdetection),
  # .git/__pycache__/node_modules/.venv (VCS and caches), and
  # packages/tests/design (Python packaging and dev artifacts, not agent config).
  rsync -a --exclude='.claude' --exclude='__pycache__' \
    --exclude='node_modules' --exclude='.git' \
    --exclude='packages' --exclude='tests' \
    --exclude='design' --exclude='.venv' \
    "$CLAUDEFILES/" "$tmpdir/claudefiles/"

  rm -f "$tmpdir/claudefiles/rules/common/sudo.md" \
    "$tmpdir/claudefiles/rules/common/tmux.md"

  cat > "$tmpdir/claudefiles/rules/common/opencode-compat.md" << 'RULE'
---
tool: opencode
---

# OpenCode Compatibility

This configuration was developed for Claude Code and adapted for OpenCode. Most rules, skills, and agents work as-is. Where a specific instruction references a Claude Code feature that doesn't exist in OpenCode, use the OpenCode equivalent:

- "AskUserQuestion tool" → use OpenCode's interactive prompting
- "Agent tool with subagent_type" → use OpenCode's agent dispatch
- "Skill tool" → use OpenCode's skill invocation (slash commands)
- "Read/Write/Edit/Grep/Glob tools" → use OpenCode's file tools
- "TaskCreate/TaskUpdate" → use OpenCode's task tracking if available
- "${CLAUDE_CONFIG_DIR:-~/.claude}" paths → ~/.config/opencode
- "PreToolUse/PostToolUse hooks" → OpenCode plugins (tool.execute.before)
- "settings.json" → opencode.json

When an instruction is clearly inapplicable (e.g., references a hook that doesn't exist), skip it silently rather than erroring.
RULE
}

# --- Post-install processing --------------------------------------------------

postprocess_config() {
  # Strip color frontmatter — OpenCode doesn't use it.
  if [[ -d "$OPENCODE_CONFIG/agents" ]]; then
    sed -i '/^color: /d' "$OPENCODE_CONFIG/agents"/*.md 2> /dev/null || true
  fi

  if [[ -d "$OPENCODE_CONFIG/agents" ]]; then
    local agent_count
    agent_count=$(remap_models "$OPENCODE_CONFIG/agents" "anchored")
    printf 'Remapped models in %d agent file(s)\n' "$agent_count"
  fi

  if [[ -d "$OPENCODE_CONFIG/skills" ]]; then
    local skill_count
    skill_count=$(remap_models "$OPENCODE_CONFIG/skills" "inline")
    printf 'Remapped models in %d skill file(s)\n' "$skill_count"
  fi
}

# --- Main ---------------------------------------------------------------------

main() {
  check_deps
  parse_args "$@"

  if ! $ALLOW_WORKTREE && in_worktree; then
    die "Refusing to sync from a worktree (would overwrite live config with branch state). Use --allow-worktree to override."
  fi

  [[ -d "$CLAUDEFILES" ]] || die "Claudefiles not found at $CLAUDEFILES"

  OPENCODE_SYNC_TMPDIR=$(mktemp -d "${CLAUDE_CODE_TMPDIR:-/tmp}/opencode-sync-XXXXXX")
  trap 'rm -rf "${OPENCODE_SYNC_TMPDIR:-}"' EXIT
  local tmpdir="$OPENCODE_SYNC_TMPDIR"

  # Uninstall previous install so deleted skills/agents don't linger as orphans.
  # If the subsequent install fails, the user reruns — no automatic rollback.
  if opkg list -g --cwd "$HOME" 2> /dev/null | grep -qw "claudefiles"; then
    $VERBOSE && printf 'Removing previous claudefiles install...\n'
    if ! $DRY_RUN; then
      opkg uninstall claudefiles -g --cwd "$HOME" > /dev/null 2>&1 || true
    fi
  fi

  stage_config "$tmpdir"

  local -a opkg_args=(
    install "$tmpdir/claudefiles"
    --platforms opencode
    --cwd "$HOME"
    -g
    --force
  )
  $DRY_RUN && opkg_args+=(--dry-run)

  $VERBOSE && printf 'Running: opkg %s\n' "${opkg_args[*]}"

  local opkg_output
  if ! opkg_output=$(opkg "${opkg_args[@]}" 2>&1); then
    printf '%s\n' "$opkg_output" >&2
    die "opkg install failed"
  fi

  if $VERBOSE; then
    printf '%s\n' "$opkg_output"
  else
    local filtered
    filtered=$(printf '%s\n' "$opkg_output" | grep -E "^✓|Installed files:|No files" || true)
    if [[ -n "$filtered" ]]; then
      printf '%s\n' "$filtered"
    else
      printf '%s\n' "$opkg_output"
    fi
  fi

  if $DRY_RUN; then
    printf '\n[dry-run] Configured model remaps (applied post-install):\n'
    for claude_model in "${!MODEL_MAP[@]}"; do
      printf '  model: %s → model: %s\n' "$claude_model" "${MODEL_MAP[$claude_model]}"
    done
    return 0
  fi

  postprocess_config

  printf 'Done. OpenCode config updated at %s\n' "$OPENCODE_CONFIG"
}

main "$@"
