#!/usr/bin/env python3
"""claude-log — Query Claude Code JSONL session logs.

Subcommands:
    list        List sessions across projects
    show        Show session content (messages, tools, thinking, usage)
    search      Search across sessions
    stats       Session statistics
    skills      Skill/command usage across sessions
    agents      Agent usage across sessions
    extract     Extract structured data as JSON
    permissions Suggest new permission allow entries from tool usage

All JSONL files live under ~/.claude/projects/*/.
"""

import argparse
import json
import os
import re
import sys
from collections import deque
from collections.abc import Callable, Generator, Sequence
from datetime import datetime, timezone
from itertools import islice
from pathlib import Path
from typing import Any, TypedDict

PROJECTS_DIR = Path.home() / ".claude" / "projects"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def _compile_pattern(pattern: str, *, fixed: bool = False) -> re.Pattern[str]:
    """Compile a regex pattern, with optional fixed-string (literal) mode.

    When *fixed* is True, metacharacters in *pattern* are escaped so the
    string is matched literally.  Invalid regex produces a user-friendly
    error on stderr and exits with code 1.
    """
    if fixed:
        pattern = re.escape(pattern)
    try:
        return re.compile(pattern, re.IGNORECASE)
    except re.error as exc:
        print(f"Error: invalid regex {pattern!r}: {exc}", file=sys.stderr)
        sys.exit(1)


def _parse_since(since: str | None) -> datetime | None:
    """Parse a YYYY-MM-DD date string into a timezone-aware datetime.

    Returns ``None`` when *since* is falsy.  Exits with a user-friendly
    error on invalid format.
    """
    if not since:
        return None
    try:
        return datetime.strptime(since, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    except ValueError:
        print(
            f"Error: invalid date '{since}' — expected YYYY-MM-DD format",
            file=sys.stderr,
        )
        sys.exit(1)


def iter_session_files(
    *,
    project_filter: str | None = None,
    cwd_filter: str | None = None,
    since: str | None = None,
) -> Generator[tuple[str, str, Path], None, None]:
    """Yield ``(project_name, session_id, jsonl_path)`` for matching sessions.

    Handles project name filtering and mtime-based date filtering so callers
    don't have to.
    """
    if not PROJECTS_DIR.is_dir():
        return

    since_dt = _parse_since(since)

    for project_dir in sorted(PROJECTS_DIR.iterdir()):
        if not project_dir.is_dir():
            continue

        proj_name = project_name_from_dir(project_dir.name)
        if project_filter and project_filter.lower() not in proj_name.lower():
            continue

        for jsonl_file in sorted(project_dir.glob("*.jsonl")):
            if since_dt:
                mod_time = datetime.fromtimestamp(
                    jsonl_file.stat().st_mtime, tz=timezone.utc
                )
                if mod_time < since_dt:
                    continue

            if cwd_filter:
                real_cwd = extract_cwd(jsonl_file)
                effective_path = real_cwd or project_path_from_dir(project_dir.name)
                if cwd_filter.lower() not in effective_path.lower():
                    continue

            yield proj_name, jsonl_file.stem, jsonl_file


def project_name_from_dir(dirname: str) -> str:
    """Extract human-readable project name from encoded dir name.

    e.g. '-home-jessica-Dotfiles' -> 'Dotfiles'
    """
    parts = dirname.strip("-").split("-")
    return parts[-1] if parts else dirname


def project_path_from_dir(dirname: str) -> str:
    """Extract full path from encoded dir name.

    e.g. '-home-jessica-Dotfiles' -> '/home/jessica/Dotfiles'

    Note: Lossy fallback — directory names containing hyphens will not
    round-trip correctly (e.g., 'my-project' becomes 'my/project').
    Prefer ``extract_cwd()`` for accurate paths when JSONL contains cwd.
    """
    return "/" + dirname.lstrip("-").replace("-", "/")


def extract_cwd(path: Path) -> str | None:
    """Extract the working directory from a session JSONL file.

    Scans the first 20 lines for a ``user`` or ``assistant`` entry with a
    ``cwd`` field and returns the first one found, or ``None``.
    """
    try:
        with open(path) as f:
            for i, line in enumerate(f):
                if i >= 20:
                    break
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if entry.get("type", "") in ("user", "assistant"):
                    cwd = entry.get("cwd")
                    if cwd:
                        return cwd
    except OSError:
        pass
    return None


def find_sessions(
    *,
    project_filter: str | None = None,
    cwd_filter: str | None = None,
    since: str | None = None,
    limit: int = 20,
) -> list[dict[str, Any]]:
    """Find sessions across all projects.

    Optimized to parse only the first ~20 lines of each JSONL file for
    metadata (timestamp, branch, cwd) and count remaining lines without
    JSON parsing for the message estimate.
    """
    sessions: list[dict[str, Any]] = []

    for proj_name, session_id, jsonl_file in iter_session_files(
        project_filter=project_filter, cwd_filter=cwd_filter, since=since
    ):
        mod_time = datetime.fromtimestamp(jsonl_file.stat().st_mtime, tz=timezone.utc)
        branch = ""
        first_ts = ""
        cwd: str | None = None
        head_lines = 0

        try:
            with open(jsonl_file) as f:
                # Phase 1: parse first ~20 lines for metadata via readline()
                # (avoid 'for line in f' which uses an internal read-ahead
                # buffer that would skip lines in Phase 2)
                while head_lines < 20:
                    line = f.readline()
                    if not line:
                        break
                    head_lines += 1
                    try:
                        entry = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    entry_type = entry.get("type", "")
                    if not branch and entry.get("gitBranch"):
                        branch = entry["gitBranch"]
                    if not first_ts and entry.get("timestamp"):
                        first_ts = entry["timestamp"]
                    if cwd is None and entry_type in ("user", "assistant"):
                        entry_cwd = entry.get("cwd")
                        if entry_cwd:
                            cwd = entry_cwd

                # Phase 2: count remaining lines without JSON parsing
                tail_lines = sum(1 for _ in f)
        except OSError:
            continue

        msg_count = head_lines + tail_lines
        if msg_count == 0:
            continue

        # Prefer real cwd; fall back to lossy dir-name reconstruction
        project_path = cwd or project_path_from_dir(jsonl_file.parent.name)

        sessions.append(
            {
                "session_id": session_id,
                "project": proj_name,
                "project_path": project_path,
                "date": first_ts[:10] if first_ts else mod_time.strftime("%Y-%m-%d"),
                "timestamp": first_ts or mod_time.isoformat(),
                "messages": msg_count,
                "branch": branch,
                "path": str(jsonl_file),
            }
        )

    sessions.sort(key=lambda s: s["timestamp"], reverse=True)
    return sessions[:limit]


def resolve_session(session_id_prefix: str) -> Path:
    """Resolve a session ID prefix to a full JSONL path.

    Accepts full UUID, short prefix (first 8 chars), or partial match.
    Exits with error if ambiguous or not found.
    """
    if not PROJECTS_DIR.is_dir():
        print("Error: ~/.claude/projects/ not found", file=sys.stderr)
        sys.exit(1)

    matches: list[Path] = []
    for project_dir in PROJECTS_DIR.iterdir():
        if not project_dir.is_dir():
            continue
        for jsonl_file in project_dir.glob("*.jsonl"):
            if jsonl_file.stem.startswith(session_id_prefix):
                matches.append(jsonl_file)

    if not matches:
        print(
            f"Error: no session found matching '{session_id_prefix}'", file=sys.stderr
        )
        sys.exit(1)

    if len(matches) > 1:
        print(
            f"Error: ambiguous session prefix '{session_id_prefix}', matches:",
            file=sys.stderr,
        )
        for m in matches[:10]:
            proj = project_name_from_dir(m.parent.name)
            print(f"  {m.stem}  ({proj})", file=sys.stderr)
        sys.exit(1)

    return matches[0]


def iter_entries(
    path: Path,
    *,
    type_filter: str | None = None,
) -> Generator[dict[str, Any], None, None]:
    """Iterate JSONL entries, optionally filtered by type.

    Tracks corrupt lines and emits a stderr warning when the generator is
    exhausted if >1 line was skipped.  A single corrupt line (common for
    active sessions being written to) is silently tolerated.
    """
    skipped = 0
    try:
        with open(path) as f:
            for line in f:
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    skipped += 1
                    continue
                if type_filter and entry.get("type") != type_filter:
                    continue
                yield entry
    finally:
        if skipped > 1:
            print(
                f"Warning: skipped {skipped} corrupt lines in {path}",
                file=sys.stderr,
            )


def extract_text(message: dict[str, Any]) -> str:
    """Extract readable text from a message content field."""
    content = message.get("content", "")
    if isinstance(content, str):
        return content

    parts: list[str] = []
    if isinstance(content, list):
        for block in content:
            if not isinstance(block, dict):
                continue
            if block.get("type") == "text":
                parts.append(block.get("text", ""))
            elif block.get("type") == "thinking":
                parts.append(f"[thinking] {block.get('thinking', '')}")
    return "\n".join(parts)


def extract_tool_uses(message: dict[str, Any]) -> list[dict[str, Any]]:
    """Extract tool_use blocks from a message."""
    content = message.get("content", [])
    if not isinstance(content, list):
        return []
    return [b for b in content if isinstance(b, dict) and b.get("type") == "tool_use"]


def extract_subagent_tool_uses(entry: dict[str, Any]) -> list[dict[str, Any]]:
    """Extract tool_use blocks from an agent_progress entry.

    Returns a list of dicts with keys: name, input, timestamp, agent_id,
    parent_tool_use_id.  Returns [] for non-progress entries, hook progress,
    user messages, or malformed data.
    """
    if entry.get("type") != "progress":
        return []
    data = entry.get("data")
    if not isinstance(data, dict) or data.get("type") != "agent_progress":
        return []
    outer_msg = data.get("message")
    if not isinstance(outer_msg, dict) or outer_msg.get("type") != "assistant":
        return []
    inner_msg = outer_msg.get("message")
    if not isinstance(inner_msg, dict):
        return []
    tools = extract_tool_uses(inner_msg)
    if not tools:
        return []
    agent_id = data.get("agentId", "")
    parent_tool_use_id = entry.get("parentToolUseID", "")
    ts = entry.get("timestamp", "")
    results = []
    for t in tools:
        record: dict[str, Any] = {
            "name": t.get("name", "?"),
            "input": t.get("input", {}),
            "timestamp": ts,
            "agent_id": agent_id,
            "parent_tool_use_id": parent_tool_use_id,
        }
        # Preserve tool_use id for nested Agent indexing
        if t.get("id"):
            record["id"] = t["id"]
        results.append(record)
    return results


def _is_system_entry(entry: dict[str, Any]) -> bool:
    """Return True for system-injected entries that should be skipped in orientation.

    Identifies:
    - Content starting with ``<`` (XML system tags like ``<local-command-caveat>``,
      ``<env>``, ``<system-reminder>``)
    - Entries with type ``tool_result``
    - Content starting with ``/`` (slash commands)
    """
    entry_type = entry.get("type", "")

    # tool_result entries are always system
    if entry_type == "tool_result":
        return True

    # Only user entries can be system-injected user messages
    if entry_type != "user":
        return False

    message = entry.get("message", {})
    content = message.get("content", "")

    # Extract the first text to check
    first_text = ""
    if isinstance(content, str):
        first_text = content
    elif isinstance(content, list):
        for block in content:
            if isinstance(block, dict) and block.get("type") == "text":
                first_text = block.get("text", "")
                break

    if not first_text:
        return False

    # XML-prefixed content or slash commands
    return first_text.startswith("<") or first_text.startswith("/")


# ---------------------------------------------------------------------------
# Turn model
# ---------------------------------------------------------------------------


class Turn(TypedDict):
    role: str  # "user" | "assistant" | "tool" | "subagent"
    text: str  # pre-extracted readable text (via extract_text)
    tool_calls: list[dict]  # pre-extracted, pre-summarized (via _tool_input_summary)
    timestamp: str
    request_id: str | None
    source: str  # "parent" | agent label


def to_turn(entry: dict[str, Any], agent_index: dict[str, str]) -> Turn:
    """Convert a raw JSONL entry dict into a Turn domain object.

    For progress (subagent) entries, extracts the inner assistant message
    and resolves the agent label from *agent_index*.
    """
    entry_type = entry.get("type", "")
    ts = entry.get("timestamp", "")
    request_id = entry.get("requestId")

    if entry_type == "progress":
        # Subagent progress entry
        data = entry.get("data", {})
        outer_msg = data.get("message", {})
        inner_msg = outer_msg.get("message", {})
        text = extract_text(inner_msg)
        tool_uses = extract_tool_uses(inner_msg)
        parent_id = entry.get("parentToolUseID", "")
        source = agent_index.get(parent_id, "subagent")
        tool_calls = [
            {
                "name": t.get("name", "?"),
                "input": t.get("input", {}),
                "summary": _tool_input_summary(t.get("name", "?"), t.get("input", {})),
            }
            for t in tool_uses
        ]
        return Turn(
            role="subagent",
            text=text,
            tool_calls=tool_calls,
            timestamp=ts,
            request_id=request_id,
            source=source,
        )

    # User or assistant entry
    message = entry.get("message", {})
    text = extract_text(message)
    tool_uses = extract_tool_uses(message)
    tool_calls = [
        {
            "name": t.get("name", "?"),
            "input": t.get("input", {}),
            "summary": _tool_input_summary(t.get("name", "?"), t.get("input", {})),
        }
        for t in tool_uses
    ]
    return Turn(
        role=entry_type,
        text=text,
        tool_calls=tool_calls,
        timestamp=ts,
        request_id=request_id,
        source="parent",
    )


def to_turns(entries: list[dict[str, Any]], agent_index: dict[str, str]) -> list[Turn]:
    """Convert a list of raw JSONL entries into collapsed Turn objects.

    Entries sharing the same ``requestId`` are merged into a single Turn:
    text parts are joined with newlines, tool_calls are concatenated.
    Entries without a ``requestId`` each become their own Turn.

    Returns Turns in order of first appearance.
    """
    # Ordered mapping: requestId -> list of entries to collapse
    # Entries without requestId get a unique sentinel key
    groups: dict[str, list[dict[str, Any]]] = {}
    order: list[str] = []
    sentinel_counter = 0

    for entry in entries:
        req_id = entry.get("requestId")
        if req_id:
            key = req_id
        else:
            key = f"__no_req_{sentinel_counter}"
            sentinel_counter += 1
        if key not in groups:
            groups[key] = []
            order.append(key)
        groups[key].append(entry)

    result: list[Turn] = []
    for key in order:
        group = groups[key]
        if len(group) == 1:
            result.append(to_turn(group[0], agent_index))
        else:
            # Collapse multiple entries into one Turn
            first = group[0]
            texts: list[str] = []
            all_tool_calls: list[dict] = []
            for entry in group:
                turn = to_turn(entry, agent_index)
                if turn["text"]:
                    texts.append(turn["text"])
                all_tool_calls.extend(turn["tool_calls"])
            result.append(
                Turn(
                    role=first.get("type", "assistant"),
                    text="\n".join(texts),
                    tool_calls=all_tool_calls,
                    timestamp=first.get("timestamp", ""),
                    request_id=first.get("requestId"),
                    source=to_turn(first, agent_index)["source"],
                )
            )

    return result


# ---------------------------------------------------------------------------
# Output dispatch
# ---------------------------------------------------------------------------


def _output(
    data: Any, *, args: argparse.Namespace, formatter: Callable[[Any], str]
) -> None:
    """Route output to JSON or text based on args.json flag."""
    if args.json:
        print(json.dumps(data, indent=2))
    else:
        print(formatter(data))


# ---------------------------------------------------------------------------
# Text Formatters
# ---------------------------------------------------------------------------


def _format_list(sessions: list[dict[str, Any]]) -> str:
    """Format session list as a columnar text table.

    Columns: ID (first 8 chars), Date, Project, Branch, Msgs.
    Duration is omitted because find_sessions() only reads the first ~20 lines
    per file (performance optimization) and doesn't have last-entry timestamps.
    """
    if not sessions:
        return ""

    headers = ["ID", "Date", "Project", "Branch", "Msgs"]
    rows: list[list[str]] = []
    for s in sessions:
        sid = s.get("session_id", "")[:8]
        date = s.get("date", "")
        project = s.get("project", "")
        branch = s.get("branch", "")
        msgs = str(s.get("messages", ""))
        rows.append([sid, date, project, branch, msgs])

    # Calculate column widths
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(cell))

    def _fmt_row(cells: list[str]) -> str:
        parts = []
        for i, cell in enumerate(cells):
            if i == len(cells) - 1:
                # Right-align the numeric Msgs column
                parts.append(cell.rjust(widths[i]))
            else:
                parts.append(cell.ljust(widths[i]))
        return "  ".join(parts)

    lines = [_fmt_row(headers)]
    for row in rows:
        lines.append(_fmt_row(row))
    return "\n".join(lines)


def _render_turn_line(turn: Turn, *, indent: str = "") -> str:
    """Render a single Turn as one or more text lines.

    Returns a multi-line string with role prefix and optional tool call lines.
    """
    lines: list[str] = []
    role = turn["role"]

    if role == "subagent":
        label = turn["source"]
        if turn["text"]:
            lines.append(f"{indent}  [{label}] {turn['text']}")
        for tc in turn["tool_calls"]:
            lines.append(f"{indent}  [{tc['name']}] {tc.get('summary', '')}")
    else:
        prefix = f"[{role}]"
        if turn["text"]:
            lines.append(f"{indent}{prefix} {turn['text']}")
        for tc in turn["tool_calls"]:
            lines.append(f"{indent}[{tc['name']}] {tc.get('summary', '')}")

    return "\n".join(lines)


def _format_show_orientation(data: dict[str, Any]) -> str:
    """Format orientation mode output: metadata header, first message, last entries.

    Input dict keys:
    - session_id, project, date, duration, model, branch, total_count
    - first_message (str | None)
    - last_entries (list[Turn])
    """
    lines: list[str] = []

    # Metadata header line
    parts = [
        f"Session {data['session_id'][:8]}",
        data.get("project", ""),
        data.get("date", ""),
    ]
    if data.get("duration"):
        parts.append(data["duration"])
    if data.get("model"):
        parts.append(data["model"])
    lines.append(" | ".join(p for p in parts if p))

    # Branch + entry count
    meta_parts: list[str] = []
    if data.get("branch"):
        meta_parts.append(f"Branch: {data['branch']}")
    total = data.get("total_count", 0)
    meta_parts.append(f"~{total} entries")
    lines.append(" | ".join(meta_parts))

    lines.append("")

    # First user message
    first_msg = data.get("first_message")
    if first_msg:
        lines.append(f"[user] {first_msg}")
    else:
        lines.append("(no user message found)")

    # Omitted count
    last_entries: list[Turn] = data.get("last_entries", [])
    # 1 for first message + number of last entries = accounted for
    accounted = (1 if first_msg else 0) + len(last_entries)
    omitted = max(0, total - accounted)
    if omitted > 0:
        lines.append("")
        lines.append(f"--- ~{omitted} entries omitted ---")

    # Last entries
    if last_entries:
        lines.append("")
        for turn in last_entries:
            rendered = _render_turn_line(turn)
            if rendered:
                lines.append(rendered)

    return "\n".join(lines)


def _format_show_entries(turns: list[Turn]) -> str:
    """Format a chronological conversation from Turn objects.

    Renders [user], [assistant], [ToolName] prefixed lines.
    Subagent entries are indented.
    """
    if not turns:
        return ""

    lines: list[str] = []
    for turn in turns:
        rendered = _render_turn_line(turn)
        if rendered:
            lines.append(rendered)

    return "\n".join(lines)


def _format_show_grep(matched_turns: list[dict[str, Any]]) -> str:
    """Format grep results: matched sections separated by --- dividers.

    Each item in *matched_turns* has keys:
    - matched: Turn
    - preceding: Turn | None
    """
    if not matched_turns:
        return ""

    sections: list[str] = []
    for item in matched_turns:
        lines: list[str] = []
        preceding = item.get("preceding")
        if preceding is not None:
            rendered = _render_turn_line(preceding)
            if rendered:
                lines.append(rendered)
        matched = item["matched"]
        rendered = _render_turn_line(matched)
        if rendered:
            lines.append(rendered)
        if lines:
            sections.append("\n".join(lines))

    return "\n---\n".join(sections)


def _format_stats(stats: dict[str, Any]) -> str:
    """Format session statistics as a key-value text summary."""
    lines: list[str] = []
    lines.append(f"Session:  {stats.get('session_id', '')}")
    lines.append(f"Project:  {stats.get('project', '')}")
    if stats.get("branch"):
        lines.append(f"Branch:   {stats['branch']}")
    if stats.get("model"):
        lines.append(f"Model:    {stats['model']}")
    if stats.get("duration"):
        lines.append(f"Duration: {stats['duration']}")

    tokens = stats.get("tokens", {})
    if any(tokens.values()):
        lines.append("")
        lines.append("Tokens:")
        lines.append(f"  Input:        {tokens.get('input', 0)}")
        lines.append(f"  Output:       {tokens.get('output', 0)}")
        if tokens.get("cache_read"):
            lines.append(f"  Cache read:   {tokens['cache_read']}")
        if tokens.get("cache_create"):
            lines.append(f"  Cache create: {tokens['cache_create']}")

    type_counts = stats.get("type_counts", {})
    if type_counts:
        lines.append("")
        lines.append("Entry types:")
        for etype, count in sorted(type_counts.items(), key=lambda x: -x[1]):
            lines.append(f"  {etype}: {count}")

    tool_counts = stats.get("tool_counts", {})
    if tool_counts:
        lines.append("")
        lines.append("Tools:")
        for tool, count in sorted(tool_counts.items(), key=lambda x: -x[1]):
            lines.append(f"  {tool}: {count}")

    subagent_tool_counts = stats.get("subagent_tool_counts", {})
    if subagent_tool_counts:
        lines.append("")
        lines.append("Subagent tools:")
        for tool, count in sorted(subagent_tool_counts.items(), key=lambda x: -x[1]):
            lines.append(f"  {tool}: {count}")

    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Subcommand handlers
# ---------------------------------------------------------------------------


def cmd_list(args: argparse.Namespace) -> None:
    """List sessions."""
    sessions = find_sessions(
        project_filter=args.project,
        cwd_filter=getattr(args, "cwd", None),
        since=args.since,
        limit=args.limit,
    )

    if not sessions:
        print("No sessions found.", file=sys.stderr)
        return

    _output(sessions, args=args, formatter=_format_list)


_ENTRY_TRIM_BYTES = 10 * 1024  # 10KB max per ring buffer entry


def _trim_text(text: str, max_bytes: int = _ENTRY_TRIM_BYTES) -> str:
    """Trim text to at most *max_bytes* bytes (UTF-8)."""
    encoded = text.encode("utf-8")
    if len(encoded) <= max_bytes:
        return text
    return encoded[:max_bytes].decode("utf-8", errors="ignore") + "..."


def cmd_show(args: argparse.Namespace) -> None:
    """Show session content.

    Default (no flags): orientation mode — metadata, first user message,
    entry count, last 3 entries.

    With filter flags or --all/--limit/--tail: full/filtered output.
    With --json: raw JSON (backward compatible).
    With --grep: within-session search.
    """
    # Mutual exclusivity: --grep and --tail cannot be used together
    if getattr(args, "grep", None) and getattr(args, "tail", None):
        print(
            "Error: --grep and --tail are mutually exclusive",
            file=sys.stderr,
        )
        sys.exit(2)

    path = resolve_session(args.session_id)

    # Determine which mode we're in
    has_filter = any(
        [
            args.messages,
            args.tools,
            args.user,
            args.assistant,
            args.thinking,
            args.usage,
        ]
    )
    has_grep = bool(getattr(args, "grep", None))
    has_all = getattr(args, "all", False)
    has_limit = args.limit is not None
    has_tail = getattr(args, "tail", None) is not None
    bypass_orientation = has_filter or has_grep or has_all or has_limit or has_tail

    # --- JSON mode: preserve current behavior exactly ---
    if args.json:
        _cmd_show_json(args, path, has_filter)
        return

    # --- Grep mode (subtask 7 — stub for now, will be wired later) ---
    if has_grep:
        _cmd_show_grep(args, path)
        return

    # --- Orientation mode (default) ---
    if not bypass_orientation:
        _cmd_show_orientation(args, path)
        return

    # --- Full/filtered mode ---
    _cmd_show_filtered(args, path)


def _cmd_show_json(args: argparse.Namespace, path: Path, has_filter: bool) -> None:
    """JSON output path — preserves current cmd_show behavior."""
    include_subagents = True
    show_all = not has_filter

    result: list[dict[str, Any]] = []
    agent_index: dict[str, str] = {}

    for entry in iter_entries(path):
        entry_type = entry.get("type", "")

        is_user = entry_type == "user" and (show_all or args.messages or args.user)
        is_assistant = entry_type == "assistant" and (
            show_all
            or args.messages
            or args.assistant
            or args.tools
            or args.thinking
            or args.usage
        )

        if is_user or is_assistant:
            result.append(entry)
            if include_subagents and is_assistant:
                for tool in extract_tool_uses(entry.get("message", {})):
                    if tool.get("name") == "Agent" and tool.get("id"):
                        agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
        elif (
            entry_type == "progress" and include_subagents and (show_all or args.tools)
        ):
            for tool in extract_subagent_tool_uses(entry):
                if tool["name"] == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
                source = agent_index.get(tool["parent_tool_use_id"], "subagent")
                result.append(
                    {
                        "type": "subagent_tool",
                        "timestamp": tool["timestamp"],
                        "name": tool["name"],
                        "input": tool["input"],
                        "source": source,
                        "agent_id": tool["agent_id"],
                    }
                )

    limit = args.limit
    if limit is not None:
        result = result[:limit]

    print(json.dumps(result, indent=2))


def _cmd_show_orientation(args: argparse.Namespace, path: Path) -> None:
    """Orientation mode: single-pass producing metadata + first message + last 3."""
    proj_name = project_name_from_dir(path.parent.name)
    agent_index: dict[str, str] = {}

    first_message: str | None = None
    ring: deque[Turn] = deque(maxlen=3)
    total_count = 0
    first_ts = ""
    last_ts = ""
    branch = ""
    model = ""

    for entry in iter_entries(path):
        total_count += 1
        entry_type = entry.get("type", "")
        ts = entry.get("timestamp", "")

        if ts:
            if not first_ts:
                first_ts = ts
            last_ts = ts

        if not branch and entry.get("gitBranch"):
            branch = entry["gitBranch"]

        if not model and entry_type == "assistant":
            m = entry.get("message", {}).get("model", "")
            if m:
                model = m

        # Build agent index for subagent label resolution
        if entry_type == "assistant":
            for tool in extract_tool_uses(entry.get("message", {})):
                if tool.get("name") == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
        elif entry_type == "progress":
            for tool in extract_subagent_tool_uses(entry):
                if tool["name"] == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))

        # Capture first non-system user message
        if (
            first_message is None
            and entry_type == "user"
            and not _is_system_entry(entry)
        ):
            first_message = extract_text(entry.get("message", {}))

        # Ring buffer — add all entries as Turns, trimmed
        turn = to_turn(entry, agent_index)
        trimmed_turn = Turn(
            role=turn["role"],
            text=_trim_text(turn["text"]),
            tool_calls=turn["tool_calls"],
            timestamp=turn["timestamp"],
            request_id=turn["request_id"],
            source=turn["source"],
        )
        ring.append(trimmed_turn)

    # Compute duration
    duration_str = ""
    if first_ts and last_ts:
        try:
            t1 = datetime.fromisoformat(first_ts.replace("Z", "+00:00"))
            t2 = datetime.fromisoformat(last_ts.replace("Z", "+00:00"))
            delta = t2 - t1
            minutes = int(delta.total_seconds() // 60)
            seconds = int(delta.total_seconds() % 60)
            if minutes > 60:
                hours = minutes // 60
                minutes = minutes % 60
                duration_str = f"{hours}h {minutes}m"
            else:
                duration_str = f"{minutes}m {seconds}s"
        except ValueError:
            pass

    date_str = first_ts[:10] if first_ts else ""

    data: dict[str, Any] = {
        "session_id": path.stem,
        "project": proj_name,
        "date": date_str,
        "duration": duration_str,
        "model": model,
        "branch": branch,
        "total_count": total_count,
        "first_message": first_message,
        "last_entries": list(ring),
    }

    _output(data, args=args, formatter=_format_show_orientation)


def _cmd_show_filtered(args: argparse.Namespace, path: Path) -> None:
    """Full/filtered mode: show entries as text conversation."""
    agent_index: dict[str, str] = {}
    entries: list[dict[str, Any]] = []

    show_all_types = not any(
        [
            args.messages,
            args.tools,
            args.user,
            args.assistant,
            args.thinking,
            args.usage,
        ]
    )

    for entry in iter_entries(path):
        entry_type = entry.get("type", "")

        # Build agent index
        if entry_type == "assistant":
            for tool in extract_tool_uses(entry.get("message", {})):
                if tool.get("name") == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
        elif entry_type == "progress":
            for tool in extract_subagent_tool_uses(entry):
                if tool["name"] == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))

        # Filter logic
        include = False
        if show_all_types:
            include = True
        elif entry_type == "user" and (args.messages or args.user):
            include = True
        elif entry_type == "assistant" and (
            args.messages or args.assistant or args.tools or args.thinking or args.usage
        ):
            include = True
        elif entry_type == "progress" and args.tools:
            include = True

        if include:
            entries.append(entry)

    # Apply tail
    tail = getattr(args, "tail", None)
    if tail is not None:
        entries = entries[-tail:]

    # Apply limit
    if args.limit is not None:
        entries = entries[: args.limit]

    turns = to_turns(entries, agent_index)
    _output(turns, args=args, formatter=_format_show_entries)


def _cmd_show_grep(args: argparse.Namespace, path: Path) -> None:
    """Within-session search: find entries matching pattern, with preceding context.

    Tracks last_user_entry and last_assistant_entry to provide conversation
    context. For assistant/progress matches, preceding is the last user entry.
    For user matches, preceding is the last assistant entry.
    """
    pattern = _compile_pattern(args.grep)
    agent_index: dict[str, str] = {}

    # Determine if type filters narrow which entries to search
    has_filter = any(
        [
            getattr(args, "messages", False),
            getattr(args, "tools", False),
            getattr(args, "user", False),
            getattr(args, "assistant", False),
            getattr(args, "thinking", False),
            getattr(args, "usage", False),
        ]
    )

    last_user_turn: Turn | None = None
    last_assistant_turn: Turn | None = None
    matched_turns: list[dict[str, Any]] = []

    for entry in iter_entries(path):
        entry_type = entry.get("type", "")

        # Build agent index
        if entry_type == "assistant":
            for tool in extract_tool_uses(entry.get("message", {})):
                if tool.get("name") == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
        elif entry_type == "progress":
            for tool in extract_subagent_tool_uses(entry):
                if tool["name"] == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))

        turn = to_turn(entry, agent_index)

        # Track context entries
        if entry_type == "user":
            last_user_turn = turn
        elif entry_type == "assistant":
            last_assistant_turn = turn

        # Apply type filter if present
        if has_filter:
            include = False
            if entry_type == "user" and (args.user or args.messages):
                include = True
            elif entry_type == "assistant":
                if args.assistant or args.messages or args.thinking:
                    include = True
                elif args.tools:
                    # Only match tool calls, not text
                    include = bool(turn["tool_calls"])
            elif entry_type == "progress" and args.tools:
                include = True
            if not include:
                continue

        # Search in turn text and tool call summaries
        searchable = turn["text"]
        for tc in turn["tool_calls"]:
            searchable += f"\n{tc.get('name', '')} {tc.get('summary', '')}"
            searchable += f"\n{json.dumps(tc.get('input', {}))}"

        if pattern.search(searchable):
            # Determine preceding context
            if entry_type in ("assistant", "progress"):
                preceding = last_user_turn
            else:
                preceding = last_assistant_turn
            matched_turns.append(
                {
                    "matched": turn,
                    "preceding": preceding,
                }
            )

    if not matched_turns:
        print("No matches found.", file=sys.stderr)
        sys.exit(1)

    _output(matched_turns, args=args, formatter=_format_show_grep)


def _tool_input_summary(name: str, inp: dict[str, Any]) -> str:
    """Create a short summary of tool input for search result text."""
    if name == "Bash":
        cmd = inp.get("command", "")
        return cmd[:100]
    if name in ("Read", "Write", "Edit"):
        return inp.get("file_path", "")
    if name == "Grep":
        pattern = inp.get("pattern", "")
        path = inp.get("path", "")
        return f'"{pattern}" in {path}' if path else f'"{pattern}"'
    if name == "Glob":
        return inp.get("pattern", "")
    if name == "Task":
        desc = inp.get("description", "")
        agent = inp.get("subagent_type", "")
        return f"[{agent}] {desc}" if agent else desc
    if name == "WebFetch":
        return inp.get("url", "")
    if name == "WebSearch":
        return inp.get("query", "")
    # Fallback: show first key=value pairs
    parts = [f"{k}={str(v)[:40]}" for k, v in list(inp.items())[:3]]
    return ", ".join(parts)


def _match_entry(
    entry_type: str,
    message: dict[str, Any],
    pattern: re.Pattern[str],
    type_filter: str | None,
) -> str:
    """Return matched text from an entry, or empty string if no match."""
    if entry_type == "user" and (not type_filter or type_filter == "user"):
        text = extract_text(message)
        if pattern.search(text):
            return text

    elif entry_type == "assistant":
        content = message.get("content", [])
        if not isinstance(content, list):
            return ""
        for block in content:
            if not isinstance(block, dict):
                continue
            btype = block.get("type", "")

            if btype == "text" and (not type_filter or type_filter == "assistant"):
                text = block.get("text", "")
                if pattern.search(text):
                    return text

            if btype == "tool_use" and (not type_filter or type_filter == "tool_use"):
                inp_str = json.dumps(block.get("input", {}))
                if pattern.search(inp_str):
                    name = block.get("name", "?")
                    return (
                        f"[{name}] {_tool_input_summary(name, block.get('input', {}))}"
                    )

    return ""


def cmd_search(args: argparse.Namespace) -> None:
    """Search across sessions."""
    pattern = _compile_pattern(args.query, fixed=args.fixed)
    include_subagents = True

    results: list[dict[str, Any]] = []
    max_results = args.limit

    for proj_name, session_id, jsonl_file in iter_session_files(
        project_filter=args.project, since=args.since
    ):
        for entry in iter_entries(jsonl_file):
            entry_type = entry.get("type", "")
            message = entry.get("message", {})
            ts = entry.get("timestamp", "")

            matched_text = _match_entry(entry_type, message, pattern, args.type)

            if matched_text:
                results.append(
                    {
                        "session_id": session_id[:8],
                        "project": proj_name,
                        "timestamp": ts,
                        "type": entry_type,
                        "text": matched_text[:120],
                    }
                )
                if len(results) >= max_results:
                    break

            elif entry_type == "progress" and include_subagents:
                for tool in extract_subagent_tool_uses(entry):
                    if args.type and args.type != "tool_use":
                        continue
                    inp_str = json.dumps(tool["input"])
                    if pattern.search(inp_str):
                        name = tool["name"]
                        summary = _tool_input_summary(name, tool["input"])
                        results.append(
                            {
                                "session_id": session_id[:8],
                                "project": proj_name,
                                "timestamp": tool["timestamp"],
                                "type": "subagent_tool",
                                "text": f"[{name}] {summary}"[:120],
                            }
                        )
                        if len(results) >= max_results:
                            break
                if len(results) >= max_results:
                    break

        if len(results) >= max_results:
            break

    if not results:
        print("No matches found.", file=sys.stderr)
        return

    print(json.dumps(results, indent=2))


def cmd_stats(args: argparse.Namespace) -> None:
    """Show session statistics."""
    path = resolve_session(args.session_id)
    proj_name = project_name_from_dir(path.parent.name)
    include_subagents = True

    type_counts: dict[str, int] = {}
    tool_counts: dict[str, int] = {}
    subagent_tool_counts: dict[str, int] = {}
    total_input = 0
    total_output = 0
    total_cache_read = 0
    total_cache_create = 0
    first_ts = ""
    last_ts = ""
    branch = ""
    model = ""

    for entry in iter_entries(path):
        entry_type = entry.get("type", "")
        type_counts[entry_type] = type_counts.get(entry_type, 0) + 1

        if not branch and entry.get("gitBranch"):
            branch = entry["gitBranch"]

        ts = entry.get("timestamp", "")
        if ts:
            if not first_ts:
                first_ts = ts
            last_ts = ts

        if entry_type == "assistant":
            message = entry.get("message", {})
            if not model and message.get("model"):
                model = message["model"]
            usage = message.get("usage", {})
            total_input += usage.get("input_tokens", 0)
            total_output += usage.get("output_tokens", 0)
            total_cache_read += usage.get("cache_read_input_tokens", 0)
            total_cache_create += usage.get("cache_creation_input_tokens", 0)

            for tool in extract_tool_uses(message):
                name = tool.get("name", "?")
                tool_counts[name] = tool_counts.get(name, 0) + 1

        elif entry_type == "progress" and include_subagents:
            for tool in extract_subagent_tool_uses(entry):
                name = tool["name"]
                subagent_tool_counts[name] = subagent_tool_counts.get(name, 0) + 1

    # Calculate duration
    duration_str = ""
    if first_ts and last_ts:
        try:
            t1 = datetime.fromisoformat(first_ts.replace("Z", "+00:00"))
            t2 = datetime.fromisoformat(last_ts.replace("Z", "+00:00"))
            delta = t2 - t1
            minutes = int(delta.total_seconds() // 60)
            seconds = int(delta.total_seconds() % 60)
            if minutes > 60:
                hours = minutes // 60
                minutes = minutes % 60
                duration_str = f"{hours}h {minutes}m"
            else:
                duration_str = f"{minutes}m {seconds}s"
        except ValueError:
            pass

    stats_dict: dict[str, Any] = {
        "session_id": path.stem,
        "project": proj_name,
        "branch": branch,
        "model": model,
        "duration": duration_str,
        "first_timestamp": first_ts,
        "last_timestamp": last_ts,
        "type_counts": type_counts,
        "tool_counts": tool_counts,
        "tokens": {
            "input": total_input,
            "output": total_output,
            "cache_read": total_cache_read,
            "cache_create": total_cache_create,
        },
    }
    if include_subagents:
        stats_dict["subagent_tool_counts"] = subagent_tool_counts
    _output(stats_dict, args=args, formatter=_format_stats)


_BUILTIN_COMMANDS = frozenset(
    (
        "help",
        "clear",
        "compact",
        "resume",
        "rename",
        "init",
        "login",
        "permissions",
        "plan",
    )
)


def _discover_on_disk() -> set[str]:
    """Find all skill and command names installed under ~/.claude/.

    Discovers:
      - Skills: ~/.claude/skills/<name>/SKILL.md  -> <name>
      - Commands: ~/.claude/commands/<name>.md     -> <name>

    Respects $CLAUDE_HOME if set.
    """

    claude_dir = Path(os.environ.get("CLAUDE_HOME", Path.home() / ".claude"))
    names: set[str] = set()

    skills_dir = claude_dir / "skills"
    if skills_dir.is_dir():
        for child in skills_dir.iterdir():
            if child.is_dir() and (child / "SKILL.md").exists():
                names.add(child.name)

    commands_dir = claude_dir / "commands"
    if commands_dir.is_dir():
        for child in commands_dir.iterdir():
            if child.suffix == ".md" and child.is_file():
                names.add(child.stem)

    return names


def _skills_audit(
    usage: dict[str, int],
    sessions: dict[str, set[str]],
) -> None:
    """Cross-reference skill usage with what's installed on disk."""
    on_disk = _discover_on_disk()
    used_names = set(usage.keys())

    never_used = sorted(on_disk - used_names)
    ghost = sorted(used_names - on_disk - _BUILTIN_COMMANDS)
    active = sorted(on_disk & used_names, key=lambda n: -usage.get(n, 0))

    result = {
        "on_disk": sorted(on_disk),
        "active": [
            {
                "skill": name,
                "invocations": usage[name],
                "sessions": len(sessions.get(name, set())),
            }
            for name in active
        ],
        "never_used": never_used,
        "ghost": [
            {
                "skill": name,
                "invocations": usage[name],
                "sessions": len(sessions.get(name, set())),
            }
            for name in ghost
        ],
    }
    print(json.dumps(result, indent=2))


def _normalize_skill_name(name: str) -> str:
    """Canonicalize skill name: ``mine:ship`` → ``mine.ship``."""
    return name.replace(":", ".", 1) if ":" in name else name


def _flush_skill_turn(
    xml_skills: set[str],
    tool_use_skills: set[str],
    skill_counts: dict[str, int],
    skill_via: dict[str, dict[str, int]],
    seen_in_session: set[str],
) -> None:
    """Flush one turn's skill detections, deduplicating by canonical name.

    Each unique skill in the turn is counted once.  When both an XML tag and a
    Skill tool_use were seen for the same skill, prefer tool_use.
    Names are normalized (colon → dot) before dedup so ``mine:ship`` and
    ``mine.ship`` are treated as the same skill within a turn.
    """
    all_skills = xml_skills | tool_use_skills
    for name in all_skills:
        via = "tool_use" if name in tool_use_skills else "xml_tag"
        skill_counts[name] = skill_counts.get(name, 0) + 1
        via_counts = skill_via.setdefault(name, {})
        via_counts[via] = via_counts.get(via, 0) + 1
        seen_in_session.add(name)


def cmd_skills(args: argparse.Namespace) -> None:
    """Show skill/command usage across sessions."""
    skill_pattern = re.compile(r"<command-name>/([^<]+)</command-name>")
    skill_counts: dict[str, int] = {}
    skill_via: dict[str, dict[str, int]] = {}
    skill_sessions: dict[str, set[str]] = {}

    for _proj_name, session_id, jsonl_file in iter_session_files(
        project_filter=args.project, since=args.since
    ):
        sid = session_id[:8]
        seen_in_session: set[str] = set()

        # Per-turn dedup sets — a "turn" spans from one user entry to the next
        turn_xml: set[str] = set()
        turn_tool_use: set[str] = set()

        for entry in iter_entries(jsonl_file):
            entry_type = entry.get("type", "")
            message = entry.get("message", {})

            if entry_type == "user":
                # Flush previous turn before starting a new one
                _flush_skill_turn(
                    turn_xml,
                    turn_tool_use,
                    skill_counts,
                    skill_via,
                    seen_in_session,
                )
                turn_xml = set()
                turn_tool_use = set()

                # Scan this user message for XML command-name tags
                text = extract_text(message)
                for match in skill_pattern.finditer(text):
                    name = _normalize_skill_name(match.group(1))
                    if name not in _BUILTIN_COMMANDS:
                        turn_xml.add(name)

            elif entry_type == "assistant":
                for tool in extract_tool_uses(message):
                    if tool.get("name") == "Skill":
                        skill_name = tool.get("input", {}).get("skill", "")
                        if skill_name:
                            turn_tool_use.add(_normalize_skill_name(skill_name))

        # Flush the final turn
        _flush_skill_turn(
            turn_xml,
            turn_tool_use,
            skill_counts,
            skill_via,
            seen_in_session,
        )

        for name in seen_in_session:
            skill_sessions.setdefault(name, set()).add(sid)

    if not skill_counts:
        print("No skill invocations found.", file=sys.stderr)
        return

    # Names are already normalized (colon→dot) at detection time via
    # _normalize_skill_name, so no post-loop normalization pass needed.

    sorted_skills = sorted(skill_counts.items(), key=lambda x: -x[1])

    if args.audit:
        _skills_audit(skill_counts, skill_sessions)
        return

    result = []
    for name, count in sorted_skills:
        via_counts = skill_via.get(name, {})
        dominant_via = max(via_counts, key=via_counts.get, default="tool_use")  # type: ignore[arg-type]
        result.append(
            {
                "skill": name,
                "invocations": count,
                "sessions": len(skill_sessions.get(name, set())),
                "via": dominant_via,
            }
        )
    print(json.dumps(result, indent=2))


def cmd_agents(args: argparse.Namespace) -> None:
    """Show agent usage across sessions."""
    agent_counts: dict[str, int] = {}
    agent_sessions: dict[str, set[str]] = {}

    for _proj_name, session_id, jsonl_file in iter_session_files(
        project_filter=args.project, since=args.since
    ):
        sid = session_id[:8]
        seen_in_session: set[str] = set()

        for entry in iter_entries(jsonl_file, type_filter="assistant"):
            message = entry.get("message", {})
            for tool in extract_tool_uses(message):
                if tool.get("name") in ("Agent", "Task"):
                    agent_name = tool.get("input", {}).get("subagent_type", "")
                    if agent_name:
                        agent_counts[agent_name] = agent_counts.get(agent_name, 0) + 1
                        seen_in_session.add(agent_name)

        for name in seen_in_session:
            agent_sessions.setdefault(name, set()).add(sid)

    if not agent_counts:
        print("No agent invocations found.", file=sys.stderr)
        return

    sorted_agents = sorted(agent_counts.items(), key=lambda x: -x[1])

    result = [
        {
            "agent": name,
            "invocations": count,
            "sessions": len(agent_sessions.get(name, set())),
        }
        for name, count in sorted_agents
    ]
    print(json.dumps(result, indent=2))


def cmd_extract(args: argparse.Namespace) -> None:
    """Extract structured data as JSON."""
    path = resolve_session(args.session_id)
    grep = getattr(args, "grep", None)
    if grep:
        _compile_pattern(grep)  # validate early — exits on bad regex
    limit = args.limit

    include_subagents = True

    if args.tools:
        _extract_tools(
            path,
            tool_filter=None,
            grep=grep,
            include_subagents=include_subagents,
            limit=limit,
        )
    elif args.bash:
        _extract_tools(
            path,
            tool_filter="Bash",
            grep=grep,
            include_subagents=include_subagents,
            limit=limit,
        )
    elif args.usage:
        _extract_usage(path, limit=limit)
    elif args.messages:
        _extract_messages(path, limit=limit)
    else:
        print("Error: specify --tools, --bash, --usage, or --messages", file=sys.stderr)
        sys.exit(1)


def _agent_label(inp: dict[str, Any]) -> str:
    """Build a human-readable label from Agent tool_use input."""
    desc = inp.get("description", "")
    stype = inp.get("subagent_type", "")
    return f"{desc} ({stype})" if desc and stype else desc or stype or "subagent"


def iter_all_tool_calls(
    path: Path,
    *,
    include_subagents: bool = False,
    tool_filter: str | None = None,
    grep: str | None = None,
    grep_re: re.Pattern[str] | None = None,
) -> Generator[dict[str, Any], None, None]:
    """Yield normalized tool call dicts from a session in chronological order.

    Single-pass: reads the file once, builds the agent name index
    incrementally as Agent tool_use blocks are encountered (they always
    precede their progress entries in the log).

    Each yielded dict has keys: timestamp, name, input.
    When *include_subagents* is True, also: source (str).

    The *grep_re* parameter accepts a pre-compiled pattern (preferred).
    The *grep* parameter accepts a raw regex string for backward compat.
    """
    if grep_re is None and grep:
        grep_re = re.compile(grep, re.IGNORECASE)
    agent_index: dict[str, str] = {}

    for entry in iter_entries(path):
        entry_type = entry.get("type", "")

        if entry_type == "assistant":
            message = entry.get("message", {})
            ts = entry.get("timestamp", "")
            for tool in extract_tool_uses(message):
                name = tool.get("name", "?")
                # Build agent index incrementally
                if include_subagents and name == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
                if tool_filter and name != tool_filter:
                    continue
                inp = tool.get("input", {})
                if grep_re:
                    haystack = (
                        inp.get("command", "") if name == "Bash" else json.dumps(inp)
                    )
                    if not grep_re.search(haystack):
                        continue
                result: dict[str, Any] = {
                    "timestamp": ts,
                    "name": name,
                    "input": inp,
                }
                if include_subagents:
                    result["source"] = "parent"
                yield result

        elif entry_type == "progress" and include_subagents:
            for tool in extract_subagent_tool_uses(entry):
                name = tool["name"]
                # Index nested Agent calls for sub-subagent label resolution
                if name == "Agent" and tool.get("id"):
                    agent_index[tool["id"]] = _agent_label(tool.get("input", {}))
                if tool_filter and name != tool_filter:
                    continue
                inp = tool["input"]
                if grep_re:
                    haystack = (
                        inp.get("command", "") if name == "Bash" else json.dumps(inp)
                    )
                    if not grep_re.search(haystack):
                        continue
                source = agent_index.get(tool["parent_tool_use_id"], "subagent")
                yield {
                    "timestamp": tool["timestamp"],
                    "name": name,
                    "input": inp,
                    "source": source,
                }


def _extract_tools(
    path: Path,
    *,
    tool_filter: str | None,
    grep: str | None = None,
    include_subagents: bool = False,
    limit: int | None = None,
) -> None:
    """Extract tool_use blocks as JSON."""
    gen = iter_all_tool_calls(
        path,
        include_subagents=include_subagents,
        tool_filter=tool_filter,
        grep=grep,
    )
    if limit is not None:
        results = list(islice(gen, limit))
    else:
        results = list(gen)
    print(json.dumps(results, indent=2))


def _extract_usage(path: Path, *, limit: int | None = None) -> None:
    """Extract token usage per turn as JSON."""
    results: list[dict[str, Any]] = []
    for entry in iter_entries(path, type_filter="assistant"):
        message = entry.get("message", {})
        usage = message.get("usage")
        if usage:
            results.append(
                {
                    "timestamp": entry.get("timestamp", ""),
                    "model": message.get("model", ""),
                    "input_tokens": usage.get("input_tokens", 0),
                    "output_tokens": usage.get("output_tokens", 0),
                    "cache_read_input_tokens": usage.get("cache_read_input_tokens", 0),
                    "cache_creation_input_tokens": usage.get(
                        "cache_creation_input_tokens", 0
                    ),
                }
            )
    if limit is not None:
        results = results[:limit]
    print(json.dumps(results, indent=2))


def _extract_messages(path: Path, *, limit: int | None = None) -> None:
    """Extract messages as JSON."""
    results: list[dict[str, Any]] = []
    for entry in iter_entries(path):
        entry_type = entry.get("type", "")
        if entry_type not in ("user", "assistant"):
            continue
        message = entry.get("message", {})
        results.append(
            {
                "timestamp": entry.get("timestamp", ""),
                "type": entry_type,
                "role": message.get("role", ""),
                "text": extract_text(message),
            }
        )
    if limit is not None:
        results = results[:limit]
    print(json.dumps(results, indent=2))


def cmd_grep(args: argparse.Namespace) -> None:
    """Search bash commands across sessions by regex pattern."""
    fixed = getattr(args, "fixed", False)
    # Validate/escape early so the user sees a clean error before any I/O
    grep_pattern = _compile_pattern(args.pattern, fixed=fixed)
    include_subagents = True
    results: list[dict[str, Any]] = []

    for proj_name, session_id, jsonl_file in iter_session_files(
        project_filter=args.project,
        since=args.since,
    ):
        for tool_call in iter_all_tool_calls(
            jsonl_file,
            include_subagents=include_subagents,
            tool_filter="Bash",
            grep_re=grep_pattern,
        ):
            result: dict[str, Any] = {
                "session_id": session_id[:8],
                "project": proj_name,
                "timestamp": tool_call["timestamp"],
                "command": tool_call["input"].get("command", ""),
            }
            if include_subagents:
                result["source"] = tool_call.get("source", "parent")
            results.append(result)

    results.sort(key=lambda r: r.get("timestamp", ""))

    if args.limit:
        results = results[: args.limit]

    if not results:
        print("No matches found.", file=sys.stderr)
        return

    print(json.dumps(results, indent=2))


def cmd_permissions(args: argparse.Namespace) -> None:
    """Deprecated — prints a message and exits."""
    print(
        "claude-log permissions has been removed. "
        "Use /mine.permissions-audit instead, which reads debug logs directly.",
        file=sys.stderr,
    )


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def _positive_int(value: str) -> int:
    """Argparse type: a positive integer."""
    try:
        n = int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"invalid int value: '{value}'") from exc
    if n <= 0:
        raise argparse.ArgumentTypeError(f"must be a positive integer, got {n}")
    return n


def build_parser() -> argparse.ArgumentParser:
    """Build the argument parser."""
    parser = argparse.ArgumentParser(
        prog="claude-log",
        description="Query Claude Code JSONL session logs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  claude-log list                        # list recent sessions
  claude-log list -p Dotfiles            # filter by project name
  claude-log show <session-id>           # show full session content
  claude-log search "error" --since 2024-01-01
  claude-log stats <session-id>          # token usage and tool stats
  claude-log grep "pytest"               # search bash commands across sessions
""",
    )

    subs = parser.add_subparsers(dest="command", required=True)

    # list
    p_list = subs.add_parser(
        "list",
        help="List sessions",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description=(
            "List sessions. JSON output fields: session_id, project, project_path, "
            "date, timestamp, messages, branch, path."
        ),
        epilog="""\
Examples:
  claude-log list                        # 20 most recent sessions
  claude-log list -l 50                  # last 50 sessions
  claude-log list -p Dotfiles            # filter by project name
  claude-log list --since 2024-03-01     # sessions after a date
  claude-log list --cwd /home/user/repo  # filter by working directory
""",
    )
    p_list.add_argument(
        "--json", action="store_true", default=False, help="Output as JSON"
    )
    p_list.add_argument("--project", "-p", help="Filter by project name substring")
    p_list.add_argument("--cwd", help="Filter by working directory path substring")
    p_list.add_argument("--since", "-s", help="Filter by date (YYYY-MM-DD)")
    p_list.add_argument(
        "--limit",
        "-l",
        type=_positive_int,
        default=20,
        help="Max results (default: 20)",
    )

    # show
    p_show = subs.add_parser(
        "show",
        help="Show session content",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  claude-log show abc123                 # show full session
  claude-log show abc123 --messages      # user + assistant text only
  claude-log show abc123 --tools         # tool use blocks only
  claude-log show abc123 --user          # user messages only
  claude-log show abc123 --usage         # token usage per turn
  claude-log show abc123 -l 10           # first 10 entries only
""",
    )
    p_show.add_argument("session_id", help="Session ID or prefix")
    p_show.add_argument(
        "--json", action="store_true", default=False, help="Output as JSON"
    )
    p_show.add_argument(
        "--messages", "-m", action="store_true", help="User + assistant text only"
    )
    p_show.add_argument(
        "--tools", "-t", action="store_true", help="Tool use blocks only"
    )
    p_show.add_argument("--user", "-u", action="store_true", help="User messages only")
    p_show.add_argument(
        "--assistant", "-a", action="store_true", help="Assistant messages only"
    )
    p_show.add_argument("--thinking", action="store_true", help="Thinking blocks only")
    p_show.add_argument("--usage", action="store_true", help="Token usage per turn")
    p_show.add_argument(
        "--grep",
        "-g",
        metavar="PATTERN",
        default=None,
        help="Search within session (regex by default)",
    )
    p_show.add_argument(
        "--all",
        action="store_true",
        default=False,
        help="Show all entries (bypass orientation mode)",
    )
    p_show.add_argument(
        "--tail",
        type=_positive_int,
        default=None,
        help="Show last N entries",
    )
    p_show.add_argument(
        "--limit",
        "-l",
        type=_positive_int,
        default=None,
        help="Max entries to return (default: unlimited)",
    )

    # search
    p_search = subs.add_parser(
        "search",
        help="Search across sessions (regex by default)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  claude-log search "error"              # regex search across all sessions
  claude-log search "exact phrase" -F    # fixed string (literal) search
  claude-log search "bug" -p Dotfiles    # search within a project
  claude-log search "fix" --type user    # search only user messages
  claude-log search "TODO" --since 2024-01-01 -l 10
""",
    )
    p_search.add_argument("query", help="Search pattern (regex by default)")
    p_search.add_argument(
        "--json", action="store_true", default=False, help="Output as JSON"
    )
    p_search.add_argument(
        "--fixed",
        "-F",
        action="store_true",
        help="Treat pattern as a fixed string, not a regex",
    )
    p_search.add_argument("--project", "-p", help="Filter by project name substring")
    p_search.add_argument(
        "--type", choices=["user", "assistant", "tool_use"], help="Filter by type"
    )
    p_search.add_argument("--since", "-s", help="Filter by date (YYYY-MM-DD)")
    p_search.add_argument(
        "--limit",
        "-l",
        type=_positive_int,
        default=50,
        help="Max results (default: 50)",
    )

    # stats
    p_stats = subs.add_parser(
        "stats",
        help="Session statistics",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Examples:
  claude-log stats abc123                # full stats for a session
  claude-log stats abc1                  # prefix match works too
""",
    )
    p_stats.add_argument("session_id", help="Session ID or prefix")
    p_stats.add_argument(
        "--json", action="store_true", default=False, help="Output as JSON"
    )

    # skills
    p_skills = subs.add_parser("skills", help="Skill/command usage across sessions")
    p_skills.add_argument("--project", "-p", help="Filter by project name substring")
    p_skills.add_argument("--since", "-s", help="Filter by date (YYYY-MM-DD)")
    p_skills.add_argument(
        "--audit",
        action="store_true",
        help="Cross-reference usage with skills/commands on disk — shows unused and ghost entries",
    )

    # agents
    p_agents = subs.add_parser("agents", help="Agent usage across sessions")
    p_agents.add_argument("--project", "-p", help="Filter by project name substring")
    p_agents.add_argument("--since", "-s", help="Filter by date (YYYY-MM-DD)")

    # extract
    p_extract = subs.add_parser("extract", help="Extract structured data as JSON")
    p_extract.add_argument("session_id", help="Session ID or prefix")
    grp = p_extract.add_mutually_exclusive_group(required=True)
    grp.add_argument("--tools", "-t", action="store_true", help="All tool_use blocks")
    grp.add_argument("--bash", "-b", action="store_true", help="Bash tool inputs only")
    grp.add_argument("--usage", "-u", action="store_true", help="Token usage array")
    grp.add_argument("--messages", "-m", action="store_true", help="Messages as JSON")
    p_extract.add_argument(
        "--grep",
        metavar="PATTERN",
        help="Filter tool inputs by regex (with --tools or --bash)",
    )
    p_extract.add_argument(
        "--limit",
        "-l",
        type=_positive_int,
        default=None,
        help="Max entries to return (default: unlimited)",
    )

    # grep
    p_grep = subs.add_parser(
        "grep",
        help="Search bash commands across sessions (regex by default)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="Search bash commands across multiple sessions. Like 'extract --bash --grep' but cross-session.",
        epilog="""\
Examples:
  claude-log grep "pytest"               # find pytest runs across sessions
  claude-log grep "docker" -p myapp      # docker commands in a project
  claude-log grep "pip install" -F       # literal string search
  claude-log grep "git push" --since 2024-03-01
""",
    )
    p_grep.add_argument("pattern", help="Search pattern (regex by default)")
    p_grep.add_argument(
        "--fixed",
        "-F",
        action="store_true",
        help="Treat pattern as a fixed string, not a regex",
    )
    p_grep.add_argument("--project", "-p", help="Filter by project name substring")
    p_grep.add_argument("--since", "-s", help="Filter by date (YYYY-MM-DD)")
    p_grep.add_argument(
        "--limit",
        "-l",
        type=_positive_int,
        help="Max results to return",
    )

    # permissions (deprecated stub — prints warning, exits 0)
    subs.add_parser(
        "permissions",
        help="(deprecated) Use /mine.permissions-audit instead",
    )

    return parser


def main(argv: Sequence[str] | None = None) -> None:
    """Entry point."""
    parser = build_parser()
    args = parser.parse_args(argv)

    handlers = {
        "list": cmd_list,
        "show": cmd_show,
        "search": cmd_search,
        "stats": cmd_stats,
        "skills": cmd_skills,
        "agents": cmd_agents,
        "extract": cmd_extract,
        "grep": cmd_grep,
        "permissions": cmd_permissions,
    }

    handlers[args.command](args)


if __name__ == "__main__":
    main()
