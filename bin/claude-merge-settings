#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["deepmerge"]
# ///
"""
Merge Claude Code settings from three layers (later layers override earlier):

  1. ~/Claudefiles/settings.json   (shared, portable — optional)
  2. ~/Dotfiles/config/claude/settings.json  (private, cross-machine)
     Override with $CLAUDE_DOTFILES_SETTINGS
  3. ~/.claude/settings.machine.json  (machine-specific — optional)
  →  ~/.claude/settings.json  (merged output)

Merge strategy:
  - permissions.allow/deny, allowedTools: concatenate + deduplicate across layers
  - hooks.<type>: concatenate arrays across layers
  - Everything else: deep merge, last wins
"""

import json
import os
import sys
from pathlib import Path
from typing import Any

from deepmerge import Merger


def _concat_unique(base: list[Any], nxt: list[Any]) -> list[Any]:
    """Concatenate two lists, deduplicating by serialized value (preserve order)."""
    seen: set[str] = set()
    merged: list[Any] = []
    for item in [*base, *nxt]:
        key = json.dumps(item, sort_keys=True) if isinstance(item, dict) else str(item)
        if key not in seen:
            seen.add(key)
            merged.append(item)
    return merged


# Keys whose lists should concatenate + deduplicate across layers
_CONCAT_KEYS = {"allow", "deny", "allowedTools"}


def _list_strategy(config: Merger, path: list[str], base: list[Any], nxt: list[Any]) -> list[Any]:
    """Custom list merge strategy based on JSON path."""
    key = path[-1] if path else None
    parent = path[0] if path else None

    # permissions.allow, permissions.deny, allowedTools → concat + dedup
    if key in _CONCAT_KEYS:
        return _concat_unique(base, nxt)

    # hooks.<type> arrays → concatenate (each layer adds its hooks)
    if parent == "hooks":
        return _concat_unique(base, nxt)

    # Default: last wins
    return nxt


merger = Merger(
    [(dict, "merge"), (list, _list_strategy)],
    ["override"],  # fallback: last wins
    ["override"],
)


def load_json(path: Path) -> dict[str, Any] | None:
    """Load a JSON file, returning None if missing or empty. Exits on parse error."""
    if not path.exists():
        return None
    try:
        content = path.read_text().strip()
        if not content:
            return None
        data = json.loads(content)
        if not isinstance(data, dict):
            print(f"ERROR: {path} must contain a JSON object, got {type(data).__name__}", file=sys.stderr)
            sys.exit(1)
        return data
    except json.JSONDecodeError as e:
        print(f"ERROR: Invalid JSON in {path}: {e}", file=sys.stderr)
        sys.exit(1)


def main() -> int:
    home = Path.home()

    layers: list[tuple[str, Path]] = [
        ("Claudefiles", home / "Claudefiles" / "settings.json"),
        ("Dotfiles", Path(os.environ.get(
            "CLAUDE_DOTFILES_SETTINGS",
            str(home / "Dotfiles" / "config" / "claude" / "settings.json"),
        ))),
        ("Machine", home / ".claude" / "settings.machine.json"),
    ]
    output_file = home / ".claude" / "settings.json"

    merged: dict[str, Any] = {}
    active: list[str] = []

    for label, path in layers:
        data = load_json(path)
        if data is not None:
            merger.merge(merged, data)
            active.append(label)
            print(f"  Loaded {label}: {path}")
        else:
            print(f"  Skipped {label} (not found): {path}")

    if not active:
        print("ERROR: No settings files found", file=sys.stderr)
        return 1

    # Write output
    output_file.parent.mkdir(parents=True, exist_ok=True)
    with open(output_file, "w") as f:
        json.dump(merged, f, indent=2)
        f.write("\n")

    print(f"\n  Merged settings written to {output_file}")
    print(f"  Active layers: {' -> '.join(active)}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
