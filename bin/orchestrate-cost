#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["whenever>=0.10"]
# ///
"""orchestrate-cost — model-weighted USD cost of mine-orchestrate runs, by role and model.

Answers "where do the token dollars go across an orchestrate run, and how has that
shifted as the pipeline evolved?" — the cost half of the keep/cut/downgrade decision.
Value is deliberately NOT scored here (see the 033 design doc §7: blocking% is a
wrong-sign value proxy). Pair these numbers with per-gate value reasoning by hand.

Why USD, not tokens: dollar cost *is* the correct model weighting. Opus input is 5x
Sonnet, output 5x input, cache_read 0.1x — a raw token count would massively overstate
the cache-read-heavy orchestrator loop. Pricing is a self-contained table inlined below
(get_pricing / turn_cost, extracted from ccrecall's token_parser) — this tool never
depends on an external package for a rate.

What it does:
  - Delimits runs from the durable trail markers in parent-session JSONLs
    (`trail-log ... p0 - start "orchestrate run started"` and the resume variant),
    stitching multi-session runs by (feature, base_commit) — session != run.
  - Attributes cost per (role, model): subagents from their own JSONLs; the
    orchestrator loop from the parent session's windowed turns, split into a band of
    own-generation (output) vs absorbed-context (input/cache it merely received).
  - Disambiguates the shared `general-purpose` agentType into real roles (executor,
    spec-reviewer, the fix subagents, ...) by a dispatch-prompt signature.
  - Buckets runs by pipeline fingerprint (the model assigned to each role whose model
    has actually varied across history) so model-assignment drift is visible and the
    tool can't silently go stale.
  - Reports coverage: runs included / undelimited / unwindowed / crashed / unpriced /
    excluded (non-orchestrate subagents sharing the session window).

Usage:
  orchestrate-cost                  # cost table + bands + fingerprint buckets + coverage
  orchestrate-cost --json           # same data, machine-readable
  orchestrate-cost --since 2026-05-01   # only runs whose start marker is on/after DATE
  orchestrate-cost --projects DIR   # override the projects root

Options:
  --since DATE     Only runs whose start marker timestamp is on/after DATE (YYYY-MM-DD or YYYYMMDD).
  --projects DIR   Projects root (default: $CLAUDE_CONFIG_DIR/projects or ~/.claude/projects).
  --json           Emit JSON instead of the table.
"""

import argparse
import json
import os
import re
import sqlite3
import statistics
import sys
from dataclasses import dataclass, field
from glob import glob
from pathlib import Path

from whenever import Date

# --------------------------------------------------------------------------------------
# Pricing (USD per million tokens), extracted from ccrecall's token_parser.py.
# Source: https://docs.anthropic.com/en/docs/about-claude/pricing
# Keys match as substrings of the lowercased model id, in order, but must NOT be
# immediately followed by another digit (see get_pricing) — so "opus-4-1" matches
# claude-opus-4-1 but not claude-opus-4-10. cache_write_5m = 1.25x input,
# cache_write_1h = 2x input, cache_read = 0.1x input.
# --------------------------------------------------------------------------------------

# Shared by the three legacy-Opus keys below so a legacy-rate correction is a
# one-line edit instead of three in-sync copies. Read-only — get_pricing returns
# it as-is and callers never mutate the dict.
_LEGACY_OPUS_RATES: dict[str, float] = {
    "input": 15.0,
    "output": 75.0,
    "cache_write_5m": 18.75,
    "cache_write_1h": 30.0,
    "cache_read": 1.50,
}

MODEL_PRICING: list[tuple[str, dict[str, float]]] = [
    # Legacy Opus (4.0 / 4.1) — the only Opus models at the old $15/$75 tier; all
    # three keys alias _LEGACY_OPUS_RATES. Enumerated explicitly so they're matched
    # before the generic "opus" fallback below; relative order within this block
    # doesn't matter (no key is a digit-boundary prefix of another).
    #   "opus-4-0"        → the 4.0 alias (claude-opus-4-0)
    #   "opus-4-20250514" → the dated 4.0 id. Must be the FULL date, not a year
    #     prefix like "opus-4-2025": the digit-boundary rule in get_pricing rejects
    #     a key immediately followed by a digit, so "opus-4-2025" (followed by "0")
    #     would never match its own model id.
    #   "opus-4-1"        → 4.1 (claude-opus-4-1, dated or bare)
    ("opus-4-0", _LEGACY_OPUS_RATES),
    ("opus-4-20250514", _LEGACY_OPUS_RATES),
    ("opus-4-1", _LEGACY_OPUS_RATES),
    # Every other Opus (4.5+ and anything newer) is the current $5/$25 tier.
    # A generic fallback rather than per-version entries so a new Opus release
    # prices correctly with no table edit — the failure mode behind issue #37,
    # where new opus-4-N ids silently hit the legacy $15/$75 catch-all.
    (
        "opus",
        {
            "input": 5.0,
            "output": 25.0,
            "cache_write_5m": 6.25,
            "cache_write_1h": 10.0,
            "cache_read": 0.50,
        },
    ),
    (
        "sonnet",
        {
            "input": 3.0,
            "output": 15.0,
            "cache_write_5m": 3.75,
            "cache_write_1h": 6.0,
            "cache_read": 0.30,
        },
    ),
    (
        "haiku",
        {
            "input": 1.0,
            "output": 5.0,
            "cache_write_5m": 1.25,
            "cache_write_1h": 2.0,
            "cache_read": 0.10,
        },
    ),
]


# Fallback rates for unknown/missing models. Resolved by name so reordering
# MODEL_PRICING can't silently change the default (was a hardcoded [4][1] index).
DEFAULT_PRICING = next(rates for substr, rates in MODEL_PRICING if substr == "sonnet")


def get_pricing(model: str | None) -> dict[str, float]:
    """Return pricing dict for a model ID, falling back to Sonnet rates.

    A key matches as a substring of the model id but must not be immediately
    followed by another digit, so a version key like "opus-4-1" matches
    claude-opus-4-1 without also matching a future claude-opus-4-10.
    """
    if model:
        m = model.lower()
        for substr, rates in MODEL_PRICING:
            if re.search(re.escape(substr) + r"(?!\d)", m):
                return rates
    return DEFAULT_PRICING


def turn_cost(
    input_tok: int,
    output_tok: int,
    cache_read: int,
    cache_creation: int,
    ephem_5m: int,
    ephem_1h: int,
    pricing: dict[str, float],
) -> float:
    """Compute dollar cost for a single turn."""
    # Cache creation split: use exact tier amounts where available,
    # attribute remainder to 5m tier (cheaper, conservative estimate).
    unclassified_creation = max(0, cache_creation - ephem_5m - ephem_1h)
    cost = (
        input_tok * pricing["input"]
        + output_tok * pricing["output"]
        + cache_read * pricing["cache_read"]
        + (ephem_5m + unclassified_creation) * pricing["cache_write_5m"]
        + ephem_1h * pricing["cache_write_1h"]
    ) / 1_000_000
    return cost


# --- Run-boundary markers (durable, in the parent-session JSONL as Bash commands) ---
# NOTE: keep in sync with bin/orchestrate-concise-probe, which duplicates these
# markers and the transcript-parsing helpers. Each tool is a self-contained
# single-file PEP 723 uv-script, so the shared logic is duplicated by design
# rather than factored into a sibling module. A grep for either filename surfaces
# both maintenance sites.
START_MARKER = "orchestrate run started"
RESUME_MARKER = "resuming from checkpoint"

# Feature slug like "033-orchestration-cost-analysis"; base commit a short/long sha.
# checkpoint-init (an executed command) is preferred over design/specs/ (which can also
# appear in displayed skill docs). base_commit lands either as the --base-commit flag or
# inside the spec-helper checkpoint JSON *output* ("base_commit": "ea12dcc1") — match
# both. The 6+ hex-digit requirement rejects the literal "<base_commit>" doc placeholder.
# Two separate patterns, tried in order: a checkpoint-init match (the executed command)
# must beat a design/specs/ match anywhere earlier in the text. A single combined regex
# would let whichever appears FIRST lexically win, defeating the stated preference.
CHECKPOINT_FEATURE_RE = re.compile(r"checkpoint-init\s+(\d{2,}[A-Za-z0-9_-]+)")
DESIGN_FEATURE_RE = re.compile(r"design/specs/(\d{2,}[A-Za-z0-9_-]+)")
BASE_COMMIT_RE = re.compile(
    r'(?:--base-commit\s+|base_commit["\s:=]+)([0-9a-f]{6,40})\b'
)

# general-purpose is shared by many orchestrate roles. Resolve by a distinctive
# substring of the dispatch prompt (the subagent's first user message). ORDER MATTERS:
# the fix subagents embed the full implementer-prompt, so the generic executor
# signature must be checked LAST or every fix run misbuckets as an executor.
GP_SIGNATURES: list[tuple[str, str]] = [
    (
        "clean-code",
        "comprehensive stylistic quality review on a completed feature branch",
    ),
    ("trail-audit", "auditing the structural integrity of the decision trail"),
    ("impl-review", "reviewing a completed feature implementation against its design"),
    ("spec-reviewer", "You are independently verifying a completed task"),
    # caliper v2 renamed the unit task -> Work Package; older runs use that wording.
    ("spec-reviewer", "independently verifying a completed Work Package"),
    ("impl-review-fix", "Fix only the listed blocking issues"),
    ("comb-fix", "Fix only the listed design-fidelity gaps"),
    # The rendered dispatch says "executing" (the implementer-prompt heading reads
    # "implementing", but the orchestrator's prompt does not — match the live text).
    # Checked last: the fix subagents embed the implementer prompt.
    ("executor", "executing a single task from an implementation plan"),
    ("executor", "executing a single Work Package from an implementation plan"),
]

# Named (non-general-purpose) agentTypes that mine-orchestrate dispatches. A run's
# parent session can also run *other* skills (challenge critics, doc reviewers, the
# engineering-* agents, ...) whose subagents share the same session window — those are
# NOT orchestrate cost. Restricting to the design's §4 role taxonomy excludes them.
# code-reviewer / integration-reviewer are shared with other skills, but within an
# orchestrate run window they are overwhelmingly orchestrate's own (window assumption).
ORCHESTRATE_TYPES = frozenset(
    {
        "code-reviewer",
        "integration-reviewer",
        "wtf-reviewer",
        "fine-toothed-comb",
    }
)

NO_DATA = "—"

# Normalize SHAs to this many hex characters when building dedup keys.  The DB stores
# full 40-char SHAs; JSONL trail markers may have 6–8 char short SHAs (BASE_COMMIT_RE
# accepts 6-40).  Truncating both sides to 8 chars lets them match.
_COMMIT_PREFIX_LEN = 8

# Roles that the JSONL path prefixes with "gp:" (via resolve_role → GP_SIGNATURES).
# DB dispatches store the bare canonical name; normalise to the gp:-prefixed form before
# mixing the two sources so aggregation/counting sees one vocabulary.
_GP_ROLES = frozenset(role for role, _sig in GP_SIGNATURES)

# --- cfl DB support ---
# DB path logic replicated inline (this is a PEP 723 standalone script, not part of the
# cfl package). Keep in sync with cfl.db.get_db_path() and the same WSL2 /mnt/ guard.

def _cfl_db_path() -> str:
    """DB location: $CFL_DB or ~/.local/share/claudefiles/cfl.db."""
    return os.environ.get("CFL_DB", os.path.expanduser("~/.local/share/claudefiles/cfl.db"))


def _open_cfl_db() -> sqlite3.Connection | None:
    """Open the cfl SQLite DB if it exists. Returns None when unavailable."""
    db_path = _cfl_db_path()
    if not os.path.exists(db_path):
        return None
    try:
        real_path = os.path.realpath(db_path)
        journal_mode = "DELETE" if real_path.startswith("/mnt/") else "WAL"
        conn = sqlite3.connect(db_path, isolation_level=None)
        conn.row_factory = sqlite3.Row
        conn.execute(f"PRAGMA journal_mode={journal_mode}")
        conn.execute("PRAGMA busy_timeout=5000")
        conn.execute("PRAGMA synchronous=NORMAL")
        conn.execute("PRAGMA foreign_keys=ON")
        return conn
    except sqlite3.Error:
        return None


def projects_root(override: str | None) -> Path:
    if override:
        return Path(override).expanduser()
    home = os.environ.get("CLAUDE_CONFIG_DIR")
    base = Path(home).expanduser() if home else Path.home() / ".claude"
    return base / "projects"


def short_model(model: str | None) -> str:
    """claude-opus-4-8 -> opus-4-8; claude-haiku-4-5-20251001 -> haiku-4-5."""
    if not model:
        return "?"
    m = model.removeprefix("claude-")
    return re.sub(r"-\d{8}$", "", m)


def message_text(msg: dict) -> str:
    content = msg.get("content")
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        return "".join(
            b["text"]
            for b in content
            if isinstance(b, dict) and b.get("type") == "text"
        )
    return ""


# --------------------------------------------------------------------------------------
# Pricing: per-turn cost over a JSONL, using the pricing table above. Splits each turn into
# own-generation (output) vs absorbed-context (input + cache) so the orchestrator loop's
# "cost" isn't mislabeled — by late tasks its input carries every subagent's returned
# report as cheap cache_read, which is real spend but not the orchestrator's own work.
# --------------------------------------------------------------------------------------
@dataclass
class Cost:
    own_gen: float = 0.0  # output-token dollars (the turn's own generation)
    absorbed: float = 0.0  # input + cache_read + cache_creation dollars
    model: str | None = None  # dominant model (most turn-output by tokens)

    @property
    def total(self) -> float:
        return self.own_gen + self.absorbed


def price_jsonl(path: str, run_start_ts: str | None = None) -> Cost:
    """Sum dollar cost over a JSONL's assistant turns, de-duped by message id (later
    events for the same id overwrite — matching how usage is finalized). When
    `run_start_ts` is set, only turns at/after it count, bounding an orchestrator session
    to its run window and excluding pre-run contamination. (This is the run-window anchor,
    NOT the CLI --since date — see build_runs.)"""
    turns: dict[str, dict] = {}  # message_id -> {usage, model, ts}
    try:
        with open(path, encoding="utf-8") as fh:
            for raw in fh:
                if '"usage"' not in raw:
                    continue
                try:
                    obj = json.loads(raw)
                except ValueError:
                    continue
                if obj.get("type") != "assistant":
                    continue
                msg = obj.get("message") or {}
                mid = msg.get("id")
                usage = msg.get("usage")
                if not mid or not usage:
                    continue
                turns[mid] = {
                    "usage": usage,
                    "model": msg.get("model"),
                    "ts": obj.get("timestamp") or "",
                }
    except OSError:
        return Cost()

    cost = Cost()
    model_tokens: dict[str, int] = {}
    for t in turns.values():
        # ISO timestamps sort lexically, so a plain string compare windows correctly.
        if run_start_ts and t["ts"] and t["ts"] < run_start_ts:
            continue
        u = t["usage"]
        creation = u.get("cache_creation") or {}
        out = u.get("output_tokens", 0) or 0
        pricing = get_pricing(t["model"])
        total = turn_cost(
            u.get("input_tokens", 0) or 0,
            out,
            u.get("cache_read_input_tokens", 0) or 0,
            u.get("cache_creation_input_tokens", 0) or 0,
            creation.get("ephemeral_5m_input_tokens", 0) or 0,
            creation.get("ephemeral_1h_input_tokens", 0) or 0,
            pricing,
        )
        own = out * pricing["output"] / 1_000_000
        cost.own_gen += own
        cost.absorbed += total - own
        if out:
            model_tokens[t["model"]] = model_tokens.get(t["model"], 0) + out
    if model_tokens:
        cost.model = max(model_tokens, key=model_tokens.get)
    return cost


def first_user_text(path: str) -> str:
    """Text of the first user message — carries the dispatch prompt used for role ID."""
    try:
        with open(path, encoding="utf-8") as fh:
            for raw in fh:
                if '"user"' not in raw:
                    continue
                try:
                    obj = json.loads(raw)
                except ValueError:
                    continue
                msg = obj.get("message") or {}
                if msg.get("role") == "user":
                    text = message_text(msg)
                    if text:
                        return text
    except OSError:
        pass
    return ""


def first_ts(path: str) -> str:
    """First timestamp in a JSONL (used to window subagents to a run)."""
    try:
        with open(path, encoding="utf-8") as fh:
            for raw in fh:
                try:
                    obj = json.loads(raw)
                except ValueError:
                    continue
                ts = obj.get("timestamp")
                if ts:
                    return ts
    except OSError:
        pass
    return ""


def resolve_role(agent_type: str, prompt: str) -> str | None:
    """Map a subagent to an orchestrate role, or None if it is not an orchestrate
    subagent (another skill sharing the session window). Named types are kept only if
    they are in the orchestrate taxonomy; general-purpose is kept only if its dispatch
    prompt matches a known orchestrate signature."""
    if agent_type in ORCHESTRATE_TYPES:
        return agent_type
    if agent_type == "general-purpose":
        for role, sig in GP_SIGNATURES:
            if sig in prompt:
                return f"gp:{role}"
    return None


# --------------------------------------------------------------------------------------
# Run delimiting + attribution
# --------------------------------------------------------------------------------------
@dataclass
class AgentRun:
    role: str
    model: str
    cost: float
    project: str


@dataclass
class SubagentCoverage:
    """Partial-failure tally for the subagents under one session, summed onto the owning
    Run across its stitched sessions so --since can scope it to the selected cohort instead
    of reporting all-time counts against a filtered run list."""

    crashed: int = 0  # meta written, transcript gone (subagent died)
    unpriced: int = 0  # ran but priced to $0 (zero usage or pricing gap)
    excluded_n: int = 0  # non-orchestrate subagent sharing the session window
    excluded_usd: float = 0.0

    def __add__(self, other: "SubagentCoverage") -> "SubagentCoverage":
        return SubagentCoverage(
            crashed=self.crashed + other.crashed,
            unpriced=self.unpriced + other.unpriced,
            excluded_n=self.excluded_n + other.excluded_n,
            excluded_usd=self.excluded_usd + other.excluded_usd,
        )


@dataclass
class Run:
    feature: str
    base_commit: str
    start_ts: str
    has_start: bool = False  # any stitched session had a real START (not resume-only)
    session_start_ts: list[str] = field(default_factory=list)  # marker ts per session
    orch: Cost = field(default_factory=Cost)
    agents: list[AgentRun] = field(default_factory=list)
    coverage: SubagentCoverage = field(default_factory=SubagentCoverage)

    @property
    def key(self) -> tuple[str, str]:
        return (self.feature, self.base_commit)

    @property
    def total(self) -> float:
        return self.orch.total + sum(a.cost for a in self.agents)

    @property
    def executors(self) -> int:
        return sum(1 for a in self.agents if a.role == "gp:executor")


def run_fingerprint(run: Run, varying: set[str]) -> tuple[tuple[str, str], ...]:
    """Pipeline-era signature for a run: the model assigned to each role whose model has
    varied across history (`varying` is a cross-run statistic computed by varying_roles,
    so this can't live on Run alone). Roles with a stable model add no spurious split."""
    seen: dict[str, str] = {}
    for a in run.agents:
        if a.role in varying:
            seen[a.role] = a.model
    return tuple(sorted(seen.items()))


@dataclass
class ParentMarkers:
    has_start: bool
    has_resume: bool
    feature: str | None
    base_commit: str | None
    start_ts: str


def scan_parent_markers(path: str) -> ParentMarkers | None:
    """Find orchestrate run-boundary markers in a parent session. Returns None if the
    session has no orchestrate marker. The start marker is sometimes only a filesystem
    probe that omits base_commit, which instead lands in the checkpoint JSON output — so
    feature/base_commit are extracted from the WHOLE session text (it is a confirmed
    orchestrate session), not just the marker-bearing command, with start_ts still taken
    from the marker line itself."""
    try:
        raw = Path(path).read_text(encoding="utf-8")
    except OSError:
        return None
    if START_MARKER not in raw and RESUME_MARKER not in raw:
        return None

    has_start = has_resume = False
    start_ts = ""
    for line in raw.splitlines():
        if START_MARKER not in line and RESUME_MARKER not in line:
            continue
        try:
            obj = json.loads(line)
        except ValueError:
            continue
        msg = obj.get("message") or {}
        content = msg.get("content")
        if not isinstance(content, list):
            continue
        for b in content:
            if not (isinstance(b, dict) and b.get("type") == "tool_use"):
                continue
            cmd = str((b.get("input") or {}).get("command", ""))
            if START_MARKER in cmd:
                has_start = True
                start_ts = start_ts or (obj.get("timestamp") or "")
            if RESUME_MARKER in cmd:
                has_resume = True
                start_ts = start_ts or (obj.get("timestamp") or "")

    if not (has_start or has_resume):
        return None
    fm = CHECKPOINT_FEATURE_RE.search(raw) or DESIGN_FEATURE_RE.search(raw)
    bm = BASE_COMMIT_RE.search(raw)
    return ParentMarkers(
        has_start=has_start,
        has_resume=has_resume,
        feature=fm.group(1) if fm else None,
        base_commit=bm.group(1) if bm else None,
        start_ts=start_ts,
    )


def iter_parent_sessions(root: Path):
    """Yield (project_dir_name, parent_jsonl_path) for top-level session files."""
    for proj in root.iterdir():
        if not proj.is_dir():
            continue
        for jsonl in proj.glob("*.jsonl"):
            yield proj.name, str(jsonl)


def attribute_subagents(
    root: Path, project: str, session_uuid: str, run_start_ts: str
) -> tuple[list[AgentRun], SubagentCoverage]:
    """All subagents under one parent session whose first turn is at/after the run window.
    Returns the orchestrate AgentRuns AND a per-session coverage tally (crashed / unpriced /
    excluded) — partial failures are counted, never silently dropped. The caller folds the
    tally into the owning Run so --since can scope it to the selected cohort."""
    agents: list[AgentRun] = []
    cov = SubagentCoverage()
    pattern = str(root / project / session_uuid / "subagents" / "agent-*.meta.json")
    for meta_path in glob(pattern):
        try:
            with open(meta_path, encoding="utf-8") as fh:
                meta = json.load(fh)
        except (OSError, ValueError):
            continue
        jsonl = meta_path[: -len(".meta.json")] + ".jsonl"
        if not os.path.exists(jsonl):
            cov.crashed += 1
            continue
        ft = first_ts(jsonl)
        if run_start_ts and ft and ft < run_start_ts:
            continue
        cost = price_jsonl(jsonl)
        role = resolve_role(meta.get("agentType", "?"), first_user_text(jsonl))
        if role is None:
            # Another skill's subagent sharing this session window — not orchestrate cost.
            cov.excluded_n += 1
            cov.excluded_usd += cost.total
            continue
        if cost.total == 0.0:
            # Classified as orchestrate but priced to $0 — a real coverage gap, counted
            # only after exclusion so foreign zero-cost subagents don't inflate it.
            cov.unpriced += 1
            continue
        agents.append(
            AgentRun(
                role=role,
                model=short_model(cost.model),
                cost=cost.total,
                project=project,
            )
        )
    return agents, cov


def build_runs(
    root: Path, since: str | None, exclude_keys: set[tuple[str, str]] | None = None
) -> tuple[list[Run], dict]:
    """Delimit runs across all parent sessions, stitch multi-session runs by
    (feature, base_commit), and attribute orchestrator + subagent cost to each.

    `exclude_keys`: (feature, base_commit) pairs already covered by the cfl DB — skip them
    here so DB data takes precedence and runs are not double-counted.

    The CLI --since filter is applied AFTER merging, on each run's overall earliest start
    — filtering per-session would silently drop the early session of a run that straddles
    the cutoff, undercounting it. Coverage counters are likewise scoped to the selected
    cohort (except `unwindowed`, which by definition has no timestamp to scope by)."""
    runs: dict[tuple[str, str], Run] = {}
    unwindowed = 0
    undelimited_ts: list[str] = []  # one start_ts per session that never forms a clean run

    for project, path in iter_parent_sessions(root):
        markers = scan_parent_markers(path)
        if markers is None:
            continue
        if not markers.start_ts:
            # No usable window anchor: can't bound the orchestrator turns, so including it
            # would sum pre-run work and inflate the band. No timestamp also means it can't
            # be placed in or out of a --since cohort. Count globally, don't attribute.
            unwindowed += 1
            continue
        if not (markers.feature and markers.base_commit):
            # A partial key (only one of the two parsed) would merge unrelated runs under a
            # shared "?" placeholder, corrupting totals and fingerprints. Require both.
            undelimited_ts.append(markers.start_ts)
            continue
        key = (markers.feature, markers.base_commit[:_COMMIT_PREFIX_LEN])
        if exclude_keys and key in exclude_keys:
            continue  # Run is in the cfl DB; SQL path takes precedence over JSONL.
        run = runs.get(key)
        if run is None:
            run = Run(
                feature=key[0],
                base_commit=key[1],
                start_ts=markers.start_ts,
                has_start=markers.has_start,
            )
            runs[key] = run
        else:
            run.has_start = run.has_start or markers.has_start  # any session counts
            if markers.start_ts < run.start_ts:
                run.start_ts = markers.start_ts
        run.session_start_ts.append(markers.start_ts)
        session_uuid = Path(path).stem
        run.orch = _add_cost(run.orch, price_jsonl(path, run_start_ts=markers.start_ts))
        agents, cov = attribute_subagents(root, project, session_uuid, markers.start_ts)
        run.agents.extend(agents)
        run.coverage = run.coverage + cov

    # A run stitched only from resume markers never saw a clean start — its window anchor is
    # a mid-run resume timestamp, so its orchestrator band would be a partial. Drop it to
    # undelimited rather than report a misleading partial run. `undelimited` is session-
    # grained throughout, so a dropped run contributes one entry per stitched session (each
    # session was an orchestrate session that never formed a clean run), counted at the
    # session's own marker timestamp for --since scoping (reusing the run's earliest
    # would undercount later sessions that fall on/after a cutoff between them).
    delimited = [r for r in runs.values() if r.has_start]
    for r in runs.values():
        if not r.has_start:
            undelimited_ts.extend(r.session_start_ts)

    selected = [r for r in delimited if not since or r.start_ts[:10] >= since]
    sel_cov = sum((r.coverage for r in selected), SubagentCoverage())
    coverage = {
        "undelimited": sum(1 for ts in undelimited_ts if not since or ts[:10] >= since),
        "unwindowed": unwindowed,
        "crashed": sel_cov.crashed,
        "unpriced": sel_cov.unpriced,
        "excluded_n": sel_cov.excluded_n,
        "excluded_usd": sel_cov.excluded_usd,
    }
    return selected, coverage


def _add_cost(a: Cost, b: Cost) -> Cost:
    # model is a display label only — cost is already baked into each turn's pricing — so
    # last-session-wins here is a best-effort tag, not a numerically significant choice.
    return Cost(
        own_gen=a.own_gen + b.own_gen,
        absorbed=a.absorbed + b.absorbed,
        model=b.model or a.model,
    )


def build_db_runs(
    conn: sqlite3.Connection, since: str | None
) -> tuple[list[Run], set[tuple[str, str]], int]:
    """Query cfl DB for orchestrate runs.

    Returns (runs, covered_keys, pending_dispatch_count):
    - runs: Run objects built from dispatches.cost_total_usd (may be empty cost if pending).
    - covered_keys: (feature, base_commit) pairs → JSONL fallback skips these.
      A cross-repo key collision would suppress a valid JSONL run. This requires
      matching both spec slug and base_commit prefix across unrelated git histories.
    - pending_dispatch_count: dispatches with NULL cost_total_usd (awaiting cfl ingest-cost).

    Orchestrator-loop cost is NOT stored in dispatches — it requires parsing the parent-session
    JSONL. DB runs have run.orch = Cost() (zero). The render layer shows the orch band only
    for runs where it is populated (JSONL-sourced runs).
    """
    try:
        rows = conn.execute(
            """
            SELECT r.id, s.number, s.slug, r.base_commit, r.started_at
            FROM runs r
            JOIN specs s ON r.spec_id = s.id
            ORDER BY r.started_at
            """
        ).fetchall()
    except sqlite3.Error:
        return [], set(), 0

    db_keys: set[tuple[str, str]] = set()
    runs: list[Run] = []
    pending_total = 0

    for row in rows:
        feature = f"{row['number']:03d}-{row['slug']}" if row["number"] and row["slug"] else ""
        base_commit = (row["base_commit"] or "")[:_COMMIT_PREFIX_LEN]
        start_ts = row["started_at"] or ""
        if since and start_ts[:10] < since:
            continue
        db_keys.add((feature, base_commit))

        try:
            dispatch_rows = conn.execute(
                """
                SELECT d.role, d.model, d.cost_total_usd
                FROM dispatches d
                WHERE d.run_id = ?
                ORDER BY d.dispatched_at
                """,
                (row["id"],),
            ).fetchall()
        except sqlite3.Error:
            dispatch_rows = []

        run = Run(
            feature=feature,
            base_commit=base_commit,
            start_ts=start_ts,
            has_start=True,
        )
        for dr in dispatch_rows:
            if dr["cost_total_usd"] is None:
                pending_total += 1
                continue
            db_role = dr["role"] or ""
            role = f"gp:{db_role}" if db_role in _GP_ROLES else db_role
            run.agents.append(
                AgentRun(
                    role=role,
                    model=short_model(dr["model"] or ""),
                    cost=dr["cost_total_usd"],
                    project="db",
                )
            )
        runs.append(run)

    return runs, db_keys, pending_total


# --------------------------------------------------------------------------------------
# Aggregation + bucketing
# --------------------------------------------------------------------------------------
def varying_roles(runs: list[Run]) -> set[str]:
    """Roles that appear with more than one model across the dataset — the only
    dimensions that should split fingerprint buckets (a stable-model role adds noise)."""
    models: dict[str, set[str]] = {}
    for run in runs:
        for a in run.agents:
            models.setdefault(a.role, set()).add(a.model)
    return {role for role, ms in models.items() if len(ms) > 1}


def aggregate_roles(runs: list[Run]) -> list[dict]:
    """Per (role, model): appearance (dispatch) count, total USD, mean USD per appearance.
    `groups` collects one entry per agent invocation, so a role that runs several times in a
    single run contributes several appearances — this is a call-level metric, not run-level."""
    groups: dict[tuple[str, str], list[float]] = {}
    for run in runs:
        for a in run.agents:
            groups.setdefault((a.role, a.model), []).append(a.cost)
    # Orchestrator loop as a pseudo-role pair (own-gen vs absorbed reported separately).
    rows = []
    for (role, model), costs in groups.items():
        rows.append(
            {
                "role": role,
                "model": model,
                "calls": len(costs),
                "total": sum(costs),
                "mean": statistics.mean(costs),
            }
        )
    rows.sort(key=lambda r: -r["total"])
    return rows


def orchestrator_band(runs: list[Run]) -> dict:
    own = sum(r.orch.own_gen for r in runs)
    absorbed = sum(r.orch.absorbed for r in runs)
    return {"own_gen": own, "absorbed": absorbed, "total": own + absorbed}


def fingerprint_buckets(runs: list[Run], varying: set[str]) -> list[dict]:
    buckets: dict[tuple, list[Run]] = {}
    for run in runs:
        buckets.setdefault(run_fingerprint(run, varying), []).append(run)
    out = []
    for fp, grp in buckets.items():
        starts = sorted(r.start_ts[:10] for r in grp if r.start_ts)
        totals = [r.total for r in grp]
        out.append(
            {
                "fingerprint": [{"role": role, "model": model} for role, model in fp],
                "runs": len(grp),
                "date_range": [starts[0], starts[-1]] if starts else None,
                "mean_run_usd": statistics.mean(totals) if totals else 0.0,
            }
        )
    out.sort(key=lambda b: (b["date_range"] or [""])[0])
    return out


# --------------------------------------------------------------------------------------
# Rendering
# --------------------------------------------------------------------------------------
def usd(x: float) -> str:
    return f"${x:,.2f}"


def render_table(runs: list[Run], coverage: dict) -> None:
    if not runs:
        print("no delimited orchestrate runs found", file=sys.stderr)
        return
    total = sum(r.total for r in runs)
    if total == 0:
        if coverage.get("pending_dispatches", 0) or coverage.get("db_runs", 0):
            print(
                f"found {len(runs)} cfl-managed run(s) but no priced dispatch costs yet — "
                "run `cfl ingest-cost` to populate",
                file=sys.stderr,
            )
        else:
            print(
                "delimited runs found but zero priced cost — nothing to report",
                file=sys.stderr,
            )
        return
    starts = sorted(r.start_ts[:10] for r in runs if r.start_ts)
    span = f"{starts[0]} … {starts[-1]}" if starts else "unknown range"
    print(f"orchestrate-cost — {len(runs)} runs  ({span})   total {usd(total)}\n")

    print(
        f"{'role':<22} {'model':<12} {'calls':>5} {'total':>11} {'mean/call':>11} {'%':>5}"
    )
    print("-" * 70)
    # Orchestrator-loop cost is only available for JSONL-sourced runs (computed by
    # price_jsonl against the parent session). DB-sourced runs have run.orch = Cost().
    orch_runs = [r for r in runs if r.orch.total > 0]
    if orch_runs:
        band = orchestrator_band(orch_runs)
        print(
            f"{'orchestrator (own-gen)':<22} {NO_DATA:<12} {len(orch_runs):>5} "
            f"{usd(band['own_gen']):>11} {usd(band['own_gen'] / len(orch_runs)):>11} "
            f"{100 * band['own_gen'] / total:>4.0f}%"
        )
        print(
            f"{'orchestrator (absorbed)':<22} {NO_DATA:<12} {len(orch_runs):>5} "
            f"{usd(band['absorbed']):>11} {usd(band['absorbed'] / len(orch_runs)):>11} "
            f"{100 * band['absorbed'] / total:>4.0f}%"
        )
    for r in aggregate_roles(runs):
        print(
            f"{r['role']:<22} {r['model']:<12} {r['calls']:>5} "
            f"{usd(r['total']):>11} {usd(r['mean']):>11} "
            f"{100 * r['total'] / total:>4.0f}%"
        )
    print(
        "\n  orchestrator 'absorbed' is input/cache it received — including every "
        "subagent's\n  returned report. It is real spend but not the orchestrator's "
        "own work; read the\n  two bands separately, never as one 'orchestrator cost' "
        "number."
    )
    print(
        "  orchestrator cost is bounded [start-marker, session-end] — there is no "
        "durable\n  run-end marker, so trailing same-session work inflates it. (The "
        "dispatch ledger\n  follow-up removes this guess.)\n"
    )

    # Per-run normalization
    run_totals = [r.total for r in runs]
    execs = [r.executors for r in runs if r.executors]
    print(
        f"  per run:  mean {usd(statistics.mean(run_totals))}"
        + (
            f"  stdev {usd(statistics.stdev(run_totals))}"
            if len(run_totals) > 1
            else ""
        )
        + f"   (N={len(run_totals)})"
    )
    if execs:
        # Full pipeline cost (orchestrator + all gates + every subagent) divided by
        # executor dispatches = end-to-end cost per unit of work the pipeline served.
        per_exec = total / sum(r.executors for r in runs)
        print(
            f"  per executor-dispatch:  {usd(per_exec)}   "
            f"(end-to-end cost per task-unit; inflated by retries)"
        )
    print()

    # Fingerprint buckets
    varying = varying_roles(runs)
    buckets = fingerprint_buckets(runs, varying)
    if varying and len(buckets) > 1:
        print(
            f"  pipeline fingerprint buckets (by model of varying roles: "
            f"{', '.join(sorted(varying))}):"
        )
        for b in buckets:
            fp = (
                ", ".join(f"{f['role']}={f['model']}" for f in b["fingerprint"])
                or "(none)"
            )
            dr = (
                f"{b['date_range'][0]}…{b['date_range'][1]}" if b["date_range"] else "?"
            )
            print(f"    [{dr}]  {b['runs']} runs  mean {usd(b['mean_run_usd'])}   {fp}")
        print()
    elif not varying:
        print(
            "  pipeline fingerprint: no role changed model across this window "
            "(single pipeline era).\n"
        )

    # Coverage
    print("  coverage:")
    print(f"    runs included:   {len(runs)}")
    print(
        f"    undelimited:     {coverage['undelimited']} "
        f"(incomplete feature/base_commit key, or resume-only with no clean start)"
    )
    print(
        f"    unwindowed:      {coverage['unwindowed']} "
        f"(marker present but no timestamp to bound the run — skipped)"
    )
    print(
        "    note: run count is a LOWER BOUND — sessions whose feature/base_commit "
        "can't be\n          parsed are reported as undelimited, and role attribution "
        "relies on drift-prone prompt signatures."
    )
    print(
        f"    crashed:         {coverage['crashed']} (meta present, transcript missing)"
    )
    print(
        f"    unpriced:        {coverage['unpriced']} (subagent ran but priced to $0)"
    )
    print(
        f"    excluded:        {coverage['excluded_n']} non-orchestrate subagent runs, "
        f"{usd(coverage['excluded_usd'])} (other skills sharing the session window)"
    )
    if coverage.get("db_runs", 0):
        print(
            f"    db runs:         {coverage['db_runs']} "
            "(orchestrator-loop cost not available; populated by cfl ingest-cost)"
        )
    if coverage.get("pending_dispatches", 0):
        print(
            f"    pending (cfl):   {coverage['pending_dispatches']} dispatch(es) "
            "awaiting cfl ingest-cost"
        )


def render_json(runs: list[Run], coverage: dict) -> None:
    varying = varying_roles(runs)
    # Only include orch band for runs where it was computed (JSONL-sourced runs).
    orch_runs = [r for r in runs if r.orch.total > 0]
    out = {
        "runs": len(runs),
        "total_usd": sum(r.total for r in runs),
        "by_role_model": aggregate_roles(runs),
        "orchestrator_band": orchestrator_band(orch_runs),
        "per_run": {
            "mean_usd": statistics.mean([r.total for r in runs]) if runs else 0.0,
            "stdev_usd": statistics.stdev([r.total for r in runs])
            if len(runs) > 1
            else None,
            "n": len(runs),
            "executor_dispatches": sum(r.executors for r in runs),
        },
        "fingerprint_buckets": fingerprint_buckets(runs, varying),
        "coverage": coverage,
    }
    print(json.dumps(out, indent=2))


def main() -> int:
    p = argparse.ArgumentParser(
        description="Model-weighted USD cost of mine-orchestrate runs, by role and model.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument(
        "--since",
        help="only runs whose start marker is on/after DATE (YYYY-MM-DD or YYYYMMDD). "
        "NOTE: this is "
        "the durable trail-marker timestamp from the transcript — unlike agent-stats, "
        "which filters by file mtime — so the two tools' --since cohorts can differ.",
    )
    p.add_argument("--projects", help="override projects root")
    p.add_argument("--json", action="store_true", help="emit JSON")
    args = p.parse_args()

    since = None
    if args.since:
        try:
            # rejects impossible dates (2026-99-99) and canonicalizes basic form
            # (20260501 -> 2026-05-01) so the lexical r.start_ts[:10] >= since holds
            since = Date.parse_iso(args.since).format_iso()
        except ValueError:
            print(
                f"bad --since date (want YYYY-MM-DD or YYYYMMDD): {args.since}",
                file=sys.stderr,
            )
            return 1

    # SQL-first: query the cfl DB for runs it knows about, then fall back to JSONL
    # parsing for any runs that predate the DB (no DB entry).
    db_runs: list[Run] = []
    db_keys: set[tuple[str, str]] = set()
    db_pending = 0
    conn = _open_cfl_db()
    if conn is not None:
        try:
            db_runs, db_keys, db_pending = build_db_runs(conn, since)
        finally:
            conn.close()

    jsonl_runs: list[Run] = []
    coverage: dict = {
        "undelimited": 0, "unwindowed": 0, "crashed": 0,
        "unpriced": 0, "excluded_n": 0, "excluded_usd": 0.0,
    }
    root = projects_root(args.projects)
    if root.is_dir():
        jsonl_runs, coverage = build_runs(root, since, exclude_keys=db_keys)
    elif db_runs:
        print(
            f"note: projects root not found ({root}); showing DB runs only",
            file=sys.stderr,
        )
    else:
        print(f"projects root not found: {root}", file=sys.stderr)
        return 1

    coverage["db_runs"] = len(db_runs)
    coverage["pending_dispatches"] = db_pending
    runs = db_runs + jsonl_runs

    if not runs:
        print("no delimited orchestrate runs found", file=sys.stderr)
        return 1

    if args.json:
        render_json(runs, coverage)
    else:
        render_table(runs, coverage)
    return 0


if __name__ == "__main__":
    sys.exit(main())
