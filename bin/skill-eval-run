#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""Run skill evaluation iterations.

Reads an eval config (YAML) and invokes `claude -p` for each variant x iteration
combination. Saves outputs to eval-results/<timestamp>/.

Usage: skill-eval-run <config.yaml>

Config format:
  skill: mine.audit
  variants:
    a: skills/mine.audit/SKILL.md
    b: skills/mine.audit-v2/SKILL.md   # optional for A/B
  iterations: 3
  prompts:
    - "Audit the codebase for tech debt"
  assertions:
    - "Output includes prioritized findings"
    - "Findings cite specific files"
"""

import json
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

import yaml


def load_config(path: str) -> dict:
    with open(path) as f:
        return yaml.safe_load(f)


def run_skill(skill_name: str, prompt: str, skill_path: str | None = None) -> str:
    """Invoke a skill via claude -p and return the output."""
    full_prompt = f"/{skill_name} {prompt}"
    cmd = ["claude", "-p", full_prompt, "--no-input"]

    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=300,
    )

    if result.returncode != 0:
        return f"ERROR (exit {result.returncode}):\n{result.stderr}\n{result.stdout}"

    return result.stdout


def main() -> None:
    if len(sys.argv) != 2:
        print("Usage: skill-eval-run <config.yaml>", file=sys.stderr)
        sys.exit(1)

    config = load_config(sys.argv[1])
    skill = config["skill"]
    variants = config.get("variants", {"a": None})
    iterations = config.get("iterations", 3)
    prompts = config.get("prompts", [""])
    assertions = config.get("assertions", [])

    timestamp = datetime.now(tz=timezone.utc).strftime("%Y%m%d-%H%M%S")
    base_dir = Path("eval-results") / timestamp

    total_runs = len(variants) * iterations * len(prompts)
    completed = 0

    for variant_key, variant_path in variants.items():
        variant_dir = base_dir / f"variant-{variant_key}"
        variant_dir.mkdir(parents=True, exist_ok=True)

        for prompt_idx, prompt in enumerate(prompts):
            for run_idx in range(iterations):
                completed += 1
                run_label = f"variant-{variant_key}/prompt-{prompt_idx}/run-{run_idx + 1}"
                print(f"[{completed}/{total_runs}] Running {run_label}...")

                output = run_skill(skill, prompt, variant_path)

                run_dir = variant_dir / f"prompt-{prompt_idx}"
                run_dir.mkdir(parents=True, exist_ok=True)

                output_file = run_dir / f"run-{run_idx + 1}.md"
                output_file.write_text(output)

                print(f"  Saved to {output_file}")

    # Save config and assertions alongside results
    meta = {
        "skill": skill,
        "variants": variants,
        "iterations": iterations,
        "prompts": prompts,
        "assertions": assertions,
        "timestamp": timestamp,
    }
    meta_file = base_dir / "eval-meta.json"
    meta_file.write_text(json.dumps(meta, indent=2))

    print(f"\nCompleted {completed} runs. Results in {base_dir}/")
    print(f"Metadata saved to {meta_file}")


if __name__ == "__main__":
    main()
