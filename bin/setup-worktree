#!/bin/bash
# setup-worktree — Set up editor and AI config in a new git worktree
#
# Usage:
#   setup-worktree <source-worktree> <target-worktree>
#
# Symlinks shared config (.vscode/, .claude/settings.json, CLAUDE.md) from
# the source worktree into the target, and copies .claude/settings.local.json
# so each worktree gets independent permissions.
#
# For each item:
#   - Skipped if target already exists
#   - Skipped if source doesn't exist
#   - Symlinked or copied as appropriate

set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") <source-worktree> <target-worktree>"
    echo ""
    echo "Set up editor and AI config in a new git worktree."
    echo ""
    echo "Symlinks .vscode/, .claude/settings.json, and CLAUDE.md from source"
    echo "into target. Copies .claude/settings.local.json (independent permissions)."
    exit 1
}

if [[ $# -ne 2 ]]; then
    echo "Error: expected 2 arguments, got $#" >&2
    usage
fi

SOURCE="$1"
TARGET="$2"

# --- Validation ---

if [[ ! -d "$SOURCE" ]]; then
    echo "Error: source worktree does not exist: $SOURCE" >&2
    exit 1
fi

if [[ ! -d "$TARGET" ]]; then
    echo "Error: target worktree does not exist: $TARGET" >&2
    exit 1
fi

# Resolve to absolute paths
SOURCE="$(cd "$SOURCE" && pwd)"
TARGET="$(cd "$TARGET" && pwd)"

# --- Helpers ---

symlink_item() {
    local src="$1"
    local dst="$2"
    local label="$3"

    if [[ ! -e "$src" ]]; then
        echo "  $label: skipped (source missing)"
        return
    fi
    if [[ -e "$dst" || -L "$dst" ]]; then
        echo "  $label: skipped (target exists)"
        return
    fi
    ln -s "$src" "$dst"
    echo "  $label: symlinked"
}

copy_item() {
    local src="$1"
    local dst="$2"
    local label="$3"

    if [[ ! -e "$src" ]]; then
        echo "  $label: skipped (source missing)"
        return
    fi
    if [[ -e "$dst" || -L "$dst" ]]; then
        echo "  $label: skipped (target exists)"
        return
    fi
    cp "$src" "$dst"
    echo "  $label: copied"
}

# --- Setup ---

echo "Setting up worktree config:"
echo "  Source: $SOURCE"
echo "  Target: $TARGET"
echo ""

# .vscode/ — symlink entire directory
symlink_item "$SOURCE/.vscode" "$TARGET/.vscode" ".vscode/"

# .claude/ — create directory, then handle contents individually
if [[ -d "$SOURCE/.claude" ]]; then
    mkdir -p "$TARGET/.claude"
fi

# .claude/settings.local.json — COPY (independent permissions per worktree)
copy_item "$SOURCE/.claude/settings.local.json" "$TARGET/.claude/settings.local.json" ".claude/settings.local.json"

# .claude/settings.json — symlink (project-level, safe to share)
symlink_item "$SOURCE/.claude/settings.json" "$TARGET/.claude/settings.json" ".claude/settings.json"

# CLAUDE.md — symlink if not already present (may be git-tracked)
symlink_item "$SOURCE/CLAUDE.md" "$TARGET/CLAUDE.md" "CLAUDE.md"

# --- Dependencies ---

echo ""
echo "Installing dependencies:"

# pre-commit hooks
if [[ -f "$TARGET/.pre-commit-config.yaml" ]]; then
    if command -v pre-commit &>/dev/null; then
        (cd "$TARGET" && pre-commit install)
        echo "  pre-commit: installed"
    else
        echo "  pre-commit: skipped (pre-commit not found on PATH)"
    fi
else
    echo "  pre-commit: skipped (no .pre-commit-config.yaml)"
fi

# Node.js dependencies (fixes npx errors in pre-commit hooks like eslint)
if [[ -f "$TARGET/package-lock.json" ]]; then
    if command -v npm &>/dev/null; then
        (cd "$TARGET" && npm ci --no-audit --no-fund)
        echo "  npm: installed (npm ci)"
    else
        echo "  npm: skipped (npm not found on PATH)"
    fi
elif [[ -f "$TARGET/package.json" ]]; then
    if command -v npm &>/dev/null; then
        (cd "$TARGET" && npm install --no-audit --no-fund)
        echo "  npm: installed (npm install)"
    else
        echo "  npm: skipped (npm not found on PATH)"
    fi
else
    echo "  npm: skipped (no package.json)"
fi

echo ""
echo "Done."
