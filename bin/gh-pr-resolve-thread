#!/usr/bin/env bash
# Resolve one or more PR review threads by their GraphQL node IDs (PRRT_...)
# Usage: gh-pr-resolve-thread <thread-id> [thread-id...]

set -euo pipefail

# --- Help guard ---
for arg in "$@"; do
  case "$arg" in
    -h | --help)
      cat << 'EOF'
Usage: gh-pr-resolve-thread <thread-id> [thread-id...]

Resolve one or more PR review threads by their GraphQL node IDs (PRRT_...).

Options:
  -h, --help  Show this help message and exit

Examples:
  gh-pr-resolve-thread PRRT_abc123              # resolve a single thread
  gh-pr-resolve-thread PRRT_abc123 PRRT_def456  # resolve multiple threads
EOF
      exit 0
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "Usage: gh-pr-resolve-thread <thread-id> [thread-id...]" >&2
  exit 1
fi

for thread_id in "$@"; do
  resolved=$(gh api graphql \
    -f query='mutation($id: ID!) {
            resolveReviewThread(input: {threadId: $id}) {
                thread { isResolved }
            }
        }' \
    -f id="$thread_id" \
    --jq '.data.resolveReviewThread.thread.isResolved')
  if [[ "$resolved" != "true" ]]; then
    echo "FAILED to resolve $thread_id (got: $resolved)" >&2
    exit 1
  fi
  echo "Resolved $thread_id"
done
