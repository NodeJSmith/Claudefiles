#!/usr/bin/env bash
# Create a unique temp directory for a skill run.
# Prints the directory path to stdout.
#
# Usage (run bare so the printed path is visible to reuse in later calls —
# shell state does not persist across separate Bash tool calls):
#   get-skill-tmpdir mine-challenge
#   # prints: /tmp/claude-mine-challenge-a8Kx3Q
#   # then pass this path to subagents or use fixed filenames inside it
#
# All paths start with claude- for consistent allowlisting.
[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
  cat << 'EOF'
Usage: get-skill-tmpdir <skill-name>

Create a unique temp directory for a skill run. Prints the path to stdout.

All paths start with "claude-" for consistent allowlisting. Run it bare so
the printed path is visible to reuse in the next call — shell state does not
persist across separate Bash tool calls.

Examples:
  get-skill-tmpdir mine-challenge    # /tmp/claude-mine-challenge-a8Kx3Q
  get-skill-tmpdir mine-audit        # /tmp/claude-mine-audit-x9Zk2P
EOF
  exit 0
}

set -euo pipefail
prefix="${1:?usage: get-skill-tmpdir <skill-name>}"
mktemp -d "${CLAUDE_CODE_TMPDIR:-/tmp}/claude-${prefix}-XXXXXX"
