#!/usr/bin/env bash
# Print the base ref for the current branch.
#
# Finds the closest remote branch (fewest commits ahead of HEAD) as the base.
# This works correctly for worktrees and fresh clones that don't have a
# tracking branch set. Falls back to origin/<default>, then <default>.
#
# Usage: git-branch-base
#   Prints a ref like "origin/main" or "origin/feature-x" to stdout.
#
# Exit codes:
#   0  found a base ref (printed to stdout)
#   1  could not determine a base ref

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
  cat << 'EOF'
Usage: git-branch-base

Print the base ref for the current branch (closest remote ancestor).

Finds the remote branch with the fewest commits ahead of HEAD. Falls back
to origin/<default-branch> or <default-branch> if no closer match exists.

Examples:
  git-branch-base                    # prints e.g. "origin/main"
  git diff "$(git-branch-base)"      # diff against base branch
  git log "$(git-branch-base)..HEAD" # commits on this branch
EOF
  exit 0
}

set -uo pipefail

current=$(git branch --show-current 2> /dev/null) || current=""

# Find the remote branch with the fewest commits ahead of HEAD (closest ancestor)
best_base=""
if [[ -n "$current" ]]; then
  best_base=$(git for-each-ref --sort=-committerdate --format='%(refname:short)' 'refs/remotes/origin/*' 2> /dev/null |
    grep -v -e "^origin/${current}$" -e "^origin$" |
    head -20 |
    while IFS= read -r ref; do
      count=$(git rev-list --count --max-count=100 "${ref}..HEAD" 2> /dev/null) || continue
      printf '%d\t%s\n' "$count" "$ref"
    done | sort -n | head -1 | cut -f2)
fi

if [[ -n "$best_base" ]]; then
  printf '%s\n' "$best_base"
  exit 0
fi

# Fallback: use default branch
default=$(git-default-branch 2> /dev/null) || exit 1

if git rev-parse --verify "origin/${default}" &> /dev/null; then
  printf 'origin/%s\n' "$default"
else
  printf '%s\n' "$default"
fi
