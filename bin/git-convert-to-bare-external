#!/bin/bash
# git-convert-to-bare-external — Convert an existing git repo to a bare repo with an external
# bare database, keeping the original working tree path unchanged.
#
# Usage:
#   git-convert-to-bare-external [--dry-run] [<repo-path>] --bare <bare-path>
#
# If repo-path is omitted, uses the current directory.
#
# Use this when the repo path is load-bearing — referenced by symlinks, installed tools,
# or editor/IDE settings — and must not change after conversion.
#
# Converts:
#   ~/Claudefiles/
#   ├── .git/
#   ├── agents/
#   └── bin/
#
# Into:
#   ~/source/Claudefiles/    (bare repo — git database only)
#   ~/Claudefiles/           (worktree at original path — files unchanged)
#   ├── .git                 (pointer to ~/source/Claudefiles/)
#   ├── agents/
#   └── bin/
#
# Feature worktrees:
#   cd ~/source/Claudefiles
#   git worktree add worktrees/feat-name -b feat/name

set -euo pipefail

DRY_RUN=false
REPO_PATH=""
BARE_PATH=""

usage() {
    local exit_code="${1:-1}"
    echo "Usage: $(basename "$0") [--dry-run] [<repo-path>] --bare <bare-path>"
    echo ""
    echo "Convert an existing git repo to a bare repo with an external bare database."
    echo "The original repo path remains unchanged as the main worktree."
    echo ""
    echo "Options:"
    echo "  --dry-run        Show what would happen without making changes"
    echo "  --bare <path>    Path for the external bare repository (required)"
    echo "  <repo-path>      Path to the repo (default: current directory)"
    exit "$exit_code"
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true; shift ;;
        --bare)
            if [[ $# -lt 2 ]]; then
                echo "Error: --bare requires a path argument" >&2
                usage
            fi
            BARE_PATH="$2"
            shift 2
            ;;
        --help|-h) usage 0 ;;
        -*)
            echo "Error: unknown option: $1" >&2
            usage
            ;;
        *)
            if [[ -n "$REPO_PATH" ]]; then
                echo "Error: unexpected argument: $1" >&2
                usage
            fi
            REPO_PATH="$1"
            shift
            ;;
    esac
done

if [[ -z "$BARE_PATH" ]]; then
    echo "Error: --bare <path> is required" >&2
    usage
fi

REPO_PATH="${REPO_PATH:-.}"
REPO_PATH="$(cd "$REPO_PATH" && pwd)"
# Resolve bare path (parent may not exist yet — only resolve what exists)
BARE_PARENT="$(dirname "$BARE_PATH")"
if [[ ! -d "$BARE_PARENT" ]]; then
    echo "Error: parent directory does not exist: $BARE_PARENT" >&2
    exit 1
fi
BARE_PATH="$(cd "$BARE_PARENT" && pwd)/$(basename "$BARE_PATH")"

# --- Validation ---

if [[ ! -d "$REPO_PATH/.git" ]]; then
    if [[ -f "$REPO_PATH/.git" ]]; then
        echo "Error: $REPO_PATH/.git is already a pointer file (repo may already be converted)" >&2
        exit 1
    fi
    echo "Error: $REPO_PATH is not a git repository (no .git directory)" >&2
    exit 1
fi

if [[ -e "$BARE_PATH" ]]; then
    echo "Error: bare path already exists: $BARE_PATH" >&2
    exit 1
fi

if [[ "$REPO_PATH" == "$BARE_PATH" || "$BARE_PATH" == "$REPO_PATH"/* ]]; then
    echo "Error: bare path must not be inside the repo path" >&2
    exit 1
fi

# Check for submodules
if [[ -f "$REPO_PATH/.gitmodules" ]]; then
    echo "Error: repo has submodules (.gitmodules found)" >&2
    echo "Submodule conversion is not supported. Remove submodules first or convert manually." >&2
    exit 1
fi

# Check for existing worktrees (beyond the main one)
worktree_count=$(git -C "$REPO_PATH" worktree list 2>/dev/null | wc -l)
if [[ "$worktree_count" -gt 1 ]]; then
    echo "Error: repo already has $worktree_count worktrees" >&2
    echo "Remove extra worktrees before converting: git worktree remove <path>" >&2
    exit 1
fi

# Detect current branch
current_branch=$(git -C "$REPO_PATH" branch --show-current 2>/dev/null || true)
if [[ -z "$current_branch" ]]; then
    echo "Error: HEAD is detached — check out a branch before converting" >&2
    exit 1
fi

# Guard against branch names that conflict with bare repo structure
if [[ "$current_branch" == ".bare" || "$current_branch" == ".git" ]]; then
    echo "Error: branch name '$current_branch' conflicts with bare repo structure" >&2
    echo "Rename the branch first: git branch -m <new-name>"
    exit 1
fi

# Check for uncommitted changes (staged or unstaged)
if ! git -C "$REPO_PATH" diff --quiet 2>/dev/null || ! git -C "$REPO_PATH" diff --cached --quiet 2>/dev/null; then
    echo "Error: repo has uncommitted changes" >&2
    echo "Commit or stash changes before converting." >&2
    exit 1
fi

# Collect untracked files (including gitignored) for reporting
untracked_count=$(git -C "$REPO_PATH" ls-files --others --exclude-standard 2>/dev/null | wc -l)
ignored_count=$(git -C "$REPO_PATH" ls-files --others --ignored --exclude-standard 2>/dev/null | wc -l)

echo "Repository:  $REPO_PATH"
echo "Branch:      $current_branch"
echo "Bare repo:   $BARE_PATH"
echo "Worktree:    $REPO_PATH (path unchanged)"
echo "Untracked:   $untracked_count files"
echo "Ignored:     $ignored_count files (will be preserved)"
echo "Mode:        $( $DRY_RUN && echo "DRY RUN" || echo "LIVE" )"
echo ""

REPO_PARENT="$(dirname "$REPO_PATH")"
REPO_NAME="$(basename "$REPO_PATH")"
STAGING_TEMPLATE="${REPO_PARENT}/.convert-staging-${REPO_NAME}.XXXXXX"

if $DRY_RUN; then
    echo "Would perform these steps:"
    echo "  1. Move all files to temporary staging area (in $REPO_PARENT/.convert-staging-${REPO_NAME}.XXXX)"
    echo "  2. Move .git/ → $BARE_PATH/"
    echo "  3. Configure as bare, fix fetch refspec"
    echo "  4. Create worktree at $REPO_PATH (path unchanged)"
    echo "  5. Restore preserved files into $REPO_PATH/"
    echo ""
    echo "Result structure:"
    echo "  $BARE_PATH/          (bare repo — git database)"
    echo "  $REPO_PATH/          (worktree — files at same path as before)"
    echo "  ├── .git             (pointer to $BARE_PATH/)"
    echo "  └── (all original files)"
    echo ""
    echo "Feature worktrees:"
    echo "  cd $BARE_PATH"
    echo "  git worktree add worktrees/feat-name -b feat/name"
    echo ""
    echo "Run without --dry-run to convert."
    exit 0
fi

# --- Point of no return ---

echo "Converting..."
STAGING_DIR=$(mktemp -d "$STAGING_TEMPLATE")

STEP=1
cleanup() {
    local exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        echo "" >&2
        echo "ERROR: Conversion failed at step $STEP" >&2
        echo "" >&2
        if [[ -d "$STAGING_DIR" ]] && [[ "$(ls -A "$STAGING_DIR" 2>/dev/null)" ]]; then
            echo "Staged files are preserved in: $STAGING_DIR" >&2
            echo "To recover manually:" >&2
            if [[ -d "$BARE_PATH" ]]; then
                # .git was successfully moved to BARE_PATH; move it back first
                echo "  1. Move bare repo back: mv \"$BARE_PATH\" \"$REPO_PATH/.git\"" >&2
                echo "  2. Restore staged files: mv \"$STAGING_DIR\"/* \"$STAGING_DIR\"/.[!.]* \"$REPO_PATH/\" 2>/dev/null" >&2
                echo "  3. rmdir $STAGING_DIR" >&2
            else
                # .git is still at $REPO_PATH/.git (step 2 not yet reached or failed)
                echo "  1. Restore staged files: mv \"$STAGING_DIR\"/* \"$STAGING_DIR\"/.[!.]* \"$REPO_PATH/\" 2>/dev/null" >&2
                echo "  2. rmdir $STAGING_DIR" >&2
            fi
        else
            if [[ -d "$STAGING_DIR" ]]; then
                rmdir "$STAGING_DIR" 2>/dev/null || true
            fi
        fi
    else
        if [[ -d "$STAGING_DIR" ]]; then
            rmdir "$STAGING_DIR" 2>/dev/null || true
        fi
    fi
}
trap cleanup EXIT

# Step 1: Move all non-.git files to staging (staging is in parent, not inside repo)
# This empties $REPO_PATH so git worktree add can populate it in step 4.
echo "  [1/5] Moving files to staging area..."
for item in "$REPO_PATH"/* "$REPO_PATH"/.[!.]* "$REPO_PATH"/..?*; do
    # Use -e and -L to catch both regular files and dangling symlinks
    [[ -e "$item" || -L "$item" ]] || continue
    basename_item="$(basename "$item")"
    [[ "$basename_item" == ".git" ]] && continue
    mv "$item" "$STAGING_DIR/"
done
# Verify repo dir is now empty (only .git should remain) — dangling symlinks or
# race conditions would leave unexpected entries that would block git worktree add
remaining=$(ls -A "$REPO_PATH" 2>/dev/null | grep -v '^\.git$' || true)
if [[ -n "$remaining" ]]; then
    echo "Error: $REPO_PATH not empty after staging — unexpected entries remain:" >&2
    echo "$remaining" | sed 's/^/  /' >&2
    exit 1
fi
STEP=2

# Step 2: Move .git/ to bare path
echo "  [2/5] Moving .git/ → $BARE_PATH/"
mv "$REPO_PATH/.git" "$BARE_PATH"
STEP=3

# Step 3: Configure as bare and fix fetch refspec (only if an origin remote exists)
echo "  [3/5] Configuring bare repo"
git -C "$BARE_PATH" config core.bare true
if git -C "$BARE_PATH" remote get-url origin &>/dev/null; then
    git -C "$BARE_PATH" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
fi
STEP=4

# Step 4: Register original path as the main worktree
# git worktree add writes the .git pointer file and registers the worktree automatically.
echo "  [4/5] Creating worktree at $REPO_PATH (path unchanged)"
git -C "$BARE_PATH" worktree add "$REPO_PATH" "$current_branch"
STEP=5

# Step 5: Restore preserved files (untracked, ignored, dotfiles) into worktree
echo "  [5/5] Restoring preserved files"
moved_extra=0
for item in "$STAGING_DIR"/* "$STAGING_DIR"/.[!.]* "$STAGING_DIR"/..?*; do
    [[ -e "$item" ]] || continue
    basename_item="$(basename "$item")"
    target="$REPO_PATH/$basename_item"

    if [[ -e "$target" ]]; then
        # Git already checked out this file/dir — merge in any untracked extras
        if [[ -d "$item" ]] && [[ -d "$target" ]]; then
            cp -r --update=none "$item/." "$target/"
            rm -rf "$item"
            moved_extra=$((moved_extra + 1))
        fi
        # For files already present (tracked by git), the checkout version wins
    else
        mv "$item" "$target"
        moved_extra=$((moved_extra + 1))
    fi
done

rm -rf "$STAGING_DIR"

echo ""
echo "Done! Converted to bare repo with external storage."
echo ""
echo "Structure:"
echo "  $BARE_PATH/          (bare repo — git database)"
echo "  $REPO_PATH/          (worktree — original path preserved)"
echo "  ├── .git             (pointer to $BARE_PATH/)"
echo "  └── (all original files)"
if [[ $moved_extra -gt 0 ]]; then
    echo ""
    echo "Preserved $moved_extra untracked/ignored items in worktree."
fi
echo ""
echo "Feature worktrees:"
echo "  cd $BARE_PATH"
echo "  git worktree add worktrees/<name> -b feat/<name>"
