#!/usr/bin/env python3
"""Generate the global Codex AGENTS.md from rules/common/*.md.

Codex CLI has no directory-based prose-rules discovery; its only always-on prose
channel is the AGENTS.md chain. This concatenates the rules tagged for Codex into
$CODEX_HOME/AGENTS.md so Codex is governed by the same always-on behavioral rules
as Claude Code.

Classification is whole-file via a `tool:` frontmatter allowlist — e.g.
`tool: claude, codex, antigravity` for a portable rule, `tool: claude` for one that
is Claude-Code-harness-specific (skill routing, the code-review agent gate, tmux/sudo
helpers) and would only mislead Codex. This generator only acts on `codex`; other
tokens (e.g. `antigravity`, delivered by a separate sync) document a rule's intended
reach and are otherwise ignored here, so the list is forward-compatible. The default
is FAIL-CLOSED: a rule with no `tool:` key reaches Claude only, so forgetting to tag a
new rule keeps it OUT of Codex (under-inclusion is a degraded result; over-inclusion
injects directives Codex cannot act on). Reaching Codex is always a deliberate
`tool: ..., codex`.

Stdlib only (no third-party YAML), matching the bin/lint-agent-models convention,
so it runs in environments without the install.py dependency set.
"""

import argparse
import os
import re
import sys
from pathlib import Path

TARGET_TOOL = "codex"
ROOT = Path(__file__).resolve().parent.parent
DEFAULT_RULES_DIR = ROOT / "rules" / "common"
GENERATED_HEADER = (
    "<!-- GENERATED BY codex-rules-sync — DO NOT EDIT MANUALLY. "
    "Run codex-rules-sync to regenerate. -->"
)
PRECEDENCE_NOTE = (
    "<!-- Baseline rules synced from Claudefiles (tool: codex). A project-level "
    "AGENTS.md deeper in the tree may add to or override these. -->"
)
# Captures the `tool:` value up to an inline `#` comment or end of line, so a
# self-documenting `tool: claude  # harness-only: <reason>` parses to just the list.
# Anchored at column 0 so an indented (nested-YAML) `tool:` key can't match; any
# trailing whitespace before the `#` is left in the group and dropped by tools_for.
TOOL_KEY_RE = re.compile(r"^tool:\s*([^#\n]+)", re.MULTILINE)


def split_frontmatter(text: str) -> tuple[str, str]:
    """Return (frontmatter, body). A file without a leading `---` block is all body.

    The tuple-returning cousin of bin/lint-agent-models' `parse_frontmatter` (which
    returns only the frontmatter) — here the generator also needs the body to strip
    the frontmatter from the emitted content. A `---` appearing only inside the body
    (horizontal rule, etc.) is not frontmatter because the file does not start with
    `---`. An *unclosed* opening `---` (no second delimiter) is malformed: the opening
    line is dropped so it cannot leak into the output as a stray horizontal rule, and
    the rest is treated as body with no frontmatter (build_output warns on this).
    """
    if not text.startswith("---"):
        return "", text
    parts = text.split("---", 2)
    if len(parts) < 3:
        _opening_dashes, _newline, body = text.partition("\n")
        return "", body
    return parts[1], parts[2]


def tools_for(frontmatter: str) -> list[str] | None:
    """The `tool:` allowlist as a lowercased list, or None when the key is absent.

    Reads the `tool:` key specifically (not a substring scan of the whole block) so a
    body or comment mention cannot affect classification.
    """
    m = TOOL_KEY_RE.search(frontmatter)
    if not m:
        return None
    return [t.strip().strip("\"'").lower() for t in m.group(1).split(",") if t.strip()]


def is_included(frontmatter: str) -> bool:
    """True iff the rule's `tool:` allowlist contains the target tool (fail-closed).

    Delegates to tools_for; an absent key (None) means Claude-only → excluded.
    """
    tools = tools_for(frontmatter)
    return tools is not None and TARGET_TOOL in tools


def source_label(path: Path, rules_dir: Path) -> str:
    """Repo-relative provenance for a source marker (e.g. `rules/common/coding-style.md`).

    Falls back to `<rules-dir-name>/<file>` when the rule lives outside the repo (a
    custom --rules-dir, as in tests), so the marker stays meaningful either way.
    """
    try:
        return str(path.relative_to(ROOT))
    except ValueError:
        return f"{rules_dir.name}/{path.name}"


def build_output(rules_dir: Path) -> tuple[str, list[Path], list[Path]]:
    """Assemble the AGENTS.md text. Returns (output, included, excluded).

    Files are processed in sorted-filename order so the output is deterministic
    (byte-identical across runs with no source change).
    """
    included: list[Path] = []
    excluded: list[Path] = []
    blocks: list[str] = [GENERATED_HEADER, PRECEDENCE_NOTE]

    for path in sorted(rules_dir.glob("*.md")):
        text = path.read_text()
        frontmatter, body = split_frontmatter(text)
        if text.startswith("---") and not frontmatter:
            print(
                f"codex-rules-sync: {source_label(path, rules_dir)}: opening '---' with "
                "no closing '---' — frontmatter ignored, so this rule is treated as "
                "Claude-only and excluded from Codex.",
                file=sys.stderr,
            )
        if not is_included(frontmatter):
            excluded.append(path)
            continue
        included.append(path)
        blocks.append(f"<!-- from {source_label(path, rules_dir)} -->\n{body.strip()}")

    return "\n\n".join(blocks) + "\n", included, excluded


def resolve_codex_home() -> Path:
    """$CODEX_HOME, treating unset *or empty* as ~/.codex (matches Codex's own default).

    Resolved (symlinks followed) so the temp file and final file land on the same
    physical filesystem — otherwise os.replace would raise a cross-device error.
    """
    raw = os.environ.get("CODEX_HOME") or "~/.codex"
    return Path(raw).expanduser().resolve()


def in_worktree() -> bool:
    """True when this script lives inside a git worktree checkout, not the main repo.

    The global ~/.codex/AGENTS.md is machine-wide; generating it from in-progress
    worktree rules would clobber every repo's Codex governance (the hazard
    worktrees.md exists to prevent). Detected by the repo's worktree layout
    (`.claude/worktrees/<branch>/`). The installed symlink resolves to the main repo,
    so normal `codex-rules-sync` runs are unaffected — only running it by path from
    inside a worktree trips this. The caller only consults this for the default rules
    dir; an explicit --rules-dir or --allow-worktree bypasses it.
    """
    return "/.claude/worktrees/" in ROOT.as_posix()


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Generate the global Codex AGENTS.md from rules/common/*.md "
        "(includes only rules whose `tool:` allowlist contains `codex`).",
        epilog="Writes $CODEX_HOME/AGENTS.md (default ~/.codex/AGENTS.md). "
        "Skips silently if Codex is not installed (home dir absent).",
    )
    parser.add_argument(
        "--rules-dir",
        type=Path,
        default=DEFAULT_RULES_DIR,
        help="directory of rule files to read (default: repo rules/common)",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="print which rules reach Codex and which don't, then exit without writing",
    )
    parser.add_argument(
        "--allow-worktree",
        action="store_true",
        help="permit generating from a worktree checkout (default refuses, to protect "
        "the machine-global ~/.codex/AGENTS.md)",
    )
    args = parser.parse_args()

    # The worktree guard only applies to the in-repo default rules dir: an explicit
    # --rules-dir (e.g. tests) or --allow-worktree is a deliberate opt-out.
    using_default_rules = args.rules_dir == DEFAULT_RULES_DIR
    if using_default_rules and in_worktree() and not args.allow_worktree:
        raise SystemExit(
            f"codex-rules-sync: refusing to generate from a worktree ({ROOT}). The "
            "global ~/.codex/AGENTS.md is machine-wide — run from the main repo, or "
            "pass --allow-worktree (or an explicit --rules-dir) to override."
        )

    output, included, excluded = build_output(args.rules_dir)

    if args.list:
        print(f"Codex rules ({len(included)} included, {len(excluded)} excluded):")
        for p in included:
            print(f"  include  {p.name}")
        for p in excluded:
            print(f"  exclude  {p.name}")
        return 0

    if not included:
        raise SystemExit(
            "codex-rules-sync: no rule is tagged for Codex (tool: ..., codex) — "
            "refusing to write an empty AGENTS.md. Check the frontmatter."
        )

    codex_home = resolve_codex_home()
    if not codex_home.exists():
        print(
            f"codex-rules-sync: Codex home {codex_home} does not exist — "
            "skipping (Codex not installed)."
        )
        return 0
    if not codex_home.is_dir():
        raise SystemExit(
            f"codex-rules-sync: {codex_home} exists but is not a directory — cannot write AGENTS.md."
        )

    target = codex_home / "AGENTS.md"
    tmp = codex_home / "AGENTS.md.tmp"
    try:
        tmp.write_text(output)
        os.replace(tmp, target)
    except OSError as e:
        tmp.unlink(missing_ok=True)
        raise SystemExit(f"codex-rules-sync: could not write {target}: {e}")

    print(
        f"codex-rules-sync: wrote {target} "
        f"({len(included)} rules included, {len(excluded)} excluded, "
        f"{len(output.encode())} bytes)"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
