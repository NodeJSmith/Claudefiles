#!/usr/bin/env python3
"""Post-hoc effectiveness stats for subagent runs, mined from the JSONL store.

Answers the recurring "is this gate earning its keep?" question for any
subagent type (fine-toothed-comb, code-reviewer, integration-reviewer, ...)
without hand-mining thousands of transcripts. For each run it reads the
durable record — `<project>/<session>/subagents/agent-*.jsonl` plus the
`.meta.json` sidecar — and reports, per agent type:

  - run count
  - verdict mix parsed from the agent's own `## Summary` line
    (clean / minor-only / blocking, with blocking-finding counts)
  - compaction rate (count of `compact_boundary` events in the run)
  - peak turn tokens (max input+output usage in any one turn, a
    compaction-risk proxy)

Why JSONL and not the trail: trail.tsv records the orchestrator's *distilled,
post-verification* verdict and is archived/deleted on ship, so it both
undercounts (dedup, downgrades) and disappears. The agent JSONL is the
complete, durable, per-run source.

The fine-toothed-comb is used for design and plan combs (the implementation
comb was removed from the pipeline — historical impl-comb data remains in the DB).

Usage:
  agent-stats                         # summary table across all agent types
  agent-stats --type fine-toothed-comb        # detailed report for one type
  agent-stats --type fine-toothed-comb --findings   # dump blocking finding text
  agent-stats --type code-reviewer --json
  agent-stats --since 2026-06-01       # only runs whose file mtime is on/after

Options:
  --type NAME      Restrict to one agentType; print a detailed report.
  --findings       Print the Blocking section text for each blocking run.
  --since DATE     Only runs modified on/after DATE (YYYY-MM-DD).
  --projects DIR   Override the projects root (default: $CLAUDE_CONFIG_DIR/projects
                   or ~/.claude/projects).
  --json           Emit machine-readable JSON instead of a table.
"""

import argparse
import calendar
import datetime
import json
import os
import re
import sqlite3
import statistics
import sys
from glob import glob
from pathlib import Path

# Sonnet's auto-compaction fires around here (measured 167k–176k; the floor is
# the conservative threshold). See the subagent-baseline-trim research / spec 031.
AUTO_COMPACT_TOKEN_THRESHOLD = 167_000

# Shown wherever a stat has no underlying data (empty denominator, no token usage).
NO_DATA = "—"

# --- cfl DB support ---
# DB path logic replicated inline (standalone PEP 723 script). Keep in sync with
# cfl.db.get_db_path() and the same WSL2 /mnt/ journal-mode guard.


def _cfl_db_path() -> str:
    """DB location: $CFL_DB or ~/.local/share/claudefiles/cfl.db."""
    return os.environ.get(
        "CFL_DB", os.path.expanduser("~/.local/share/claudefiles/cfl.db")
    )


def _open_cfl_db() -> sqlite3.Connection | None:
    """Open the cfl SQLite DB if it exists. Returns None when unavailable."""
    db_path = _cfl_db_path()
    if not os.path.exists(db_path):
        return None
    try:
        real_path = os.path.realpath(db_path)
        journal_mode = "DELETE" if real_path.startswith("/mnt/") else "WAL"
        conn = sqlite3.connect(db_path, isolation_level=None)
        conn.row_factory = sqlite3.Row
        conn.execute(f"PRAGMA journal_mode={journal_mode}")
        conn.execute("PRAGMA busy_timeout=5000")
        conn.execute("PRAGMA synchronous=NORMAL")
        conn.execute("PRAGMA foreign_keys=ON")
        return conn
    except sqlite3.Error:
        return None


def db_covered_dispatch_keys(conn: sqlite3.Connection) -> set[tuple[str, str]]:
    """Return (session_uuid, tool_use_id) pairs for all dispatches tracked in the DB.
    Used to skip JSONL subagents that are already represented by a DB dispatch row,
    preventing double-counting when both DB and JSONL data cover the same run."""
    try:
        rows = conn.execute(
            """
            SELECT session_uuid, tool_use_id
            FROM dispatches
            WHERE session_uuid IS NOT NULL AND tool_use_id IS NOT NULL
            """
        ).fetchall()
    except sqlite3.Error:
        return set()
    return {(row["session_uuid"], row["tool_use_id"]) for row in rows}


def collect_db(
    conn: sqlite3.Connection, type_filter: str | None, since_str: str | None
) -> list[dict]:
    """Query cfl DB for gate/dispatch data, returning records in the same format as
    collect(). Only dispatches with a gate (reviewers) are included — executor dispatches
    have no gate and no verdict. `since_str` is an ISO date (YYYY-MM-DD) or None.

    `peak` is always 0 for DB records: raw token counts are not stored in the DB
    (only peak_context_pct %). DB records are therefore excluded from peak-token stats.
    `compactions` uses dispatches.compactions (populated by hook or ingest-cost); NULL
    is treated as 0.
    `report` and `jsonl` are empty strings for DB records: findings text lives in
    gate files during execution and is not persisted to the DB in v1.
    """
    try:
        rows = conn.execute(
            """
            SELECT
                d.agent_type,
                d.role,
                d.compactions,
                g.verdict,
                g.gate_type,
                g.data   AS gate_data,
                s.slug   AS project,
                d.dispatched_at
            FROM dispatches d
            JOIN gates g ON d.gate_id = g.id
            JOIN runs r ON d.run_id = r.id
            JOIN specs s ON r.spec_id = s.id
            WHERE d.session_uuid IS NOT NULL
              AND d.tool_use_id IS NOT NULL
            ORDER BY d.dispatched_at
            """
        ).fetchall()
    except sqlite3.Error:
        return []

    records = []
    for row in rows:
        agent_type = row["agent_type"] or "?"
        if type_filter and agent_type != type_filter:
            continue
        if since_str and (row["dispatched_at"] or "")[:10] < since_str:
            continue

        gate_data: dict = {}
        if row["gate_data"]:
            try:
                gate_data = json.loads(row["gate_data"])
            except (ValueError, TypeError):
                gate_data = {}

        # Map unified DB verdicts (PASS/WARN/FAIL/SKIPPED) to agent-stats terms.
        # Counts come from gate_data where the gate type stores them:
        #   code-review, integration-review → {"findings": N, "critical": C, ...}
        verdict_raw = row["verdict"] or "SKIPPED"
        if verdict_raw in ("PASS", "SKIPPED"):
            verdict, blk, mnr = "clean", 0, 0
        elif verdict_raw == "WARN":
            verdict = "minor"
            blk = 0
            mnr = gate_data.get("minor") or gate_data.get("findings") or 1
        else:  # FAIL
            verdict = "blocking"
            blk = gate_data.get("blocking") or gate_data.get("findings") or 1
            mnr = gate_data.get("minor", 0)

        records.append(
            {
                "type": agent_type,
                "desc": "",
                "project": row["project"] or "?",
                "verdict": verdict,
                "blocking": blk,
                "minor": mnr,
                # compactions: NULL in DB means not yet populated by hook/ingest-cost; treat as 0.
                "compactions": row["compactions"]
                if row["compactions"] is not None
                else 0,
                # peak: raw token count not stored; 0 excludes this record from peak stats.
                "peak": 0,
                "jsonl": "",
                "report": "",
            }
        )
    return records


def projects_root(override: str | None) -> Path:
    if override:
        return Path(override).expanduser()
    home = os.environ.get("CLAUDE_CONFIG_DIR")
    base = Path(home).expanduser() if home else Path.home() / ".claude"
    return base / "projects"


def iter_runs(root: Path, type_filter: str | None):
    """Yield (meta_dict, jsonl_path) per run, reading the cheap meta sidecar
    first so the type filter is applied before the larger JSONL is opened."""
    for meta_path in glob(
        str(root / "**" / "subagents" / "agent-*.meta.json"), recursive=True
    ):
        try:
            with open(meta_path, encoding="utf-8") as fh:
                meta = json.load(fh)
        except (OSError, ValueError):
            continue
        if type_filter and meta.get("agentType") != type_filter:
            continue
        jsonl = meta_path[: -len(".meta.json")] + ".jsonl"
        if os.path.exists(jsonl):
            yield meta, jsonl


def parse_summary(text: str) -> tuple[str, int | None, int | None]:
    """Return (verdict, blocking, minor) from an agent's `## Summary` line."""
    m = re.search(r"##\s*Summary\s*\n+\s*(.+)", text)
    line = m.group(1).strip() if m else ""
    if re.search(r"\bno findings\b", line, re.I):
        return "clean", 0, 0
    mb = re.search(r"(\d+)\s*blocking", line, re.I)
    mm = re.search(r"(\d+)\s*minor", line, re.I)
    blk = int(mb.group(1)) if mb else None
    mnr = int(mm.group(1)) if mm else None
    if blk is None and mnr is None:
        return "unparsed", None, None
    if (blk or 0) > 0:
        return "blocking", blk, mnr
    if (mnr or 0) > 0:
        return "minor", blk, mnr
    return "clean", blk, mnr


def message_text(msg: dict) -> str:
    """Concatenate the text blocks of one message (assistant or user)."""
    content = msg.get("content")
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        return "".join(
            b["text"]
            for b in content
            if isinstance(b, dict) and b.get("type") == "text"
        )
    return ""


def scan_run(jsonl: str) -> dict:
    """Single pass over a run's JSONL for everything we report: compaction
    count, peak turn tokens, and the final assistant message's text (the
    agent's report, which carries `## Summary`)."""
    compactions = 0
    peak = 0
    report = ""
    try:
        with open(jsonl, encoding="utf-8") as fh:
            for raw in fh:
                if '"compact_boundary"' in raw:
                    compactions += 1
                if '"usage"' not in raw and '"assistant"' not in raw:
                    continue
                try:
                    obj = json.loads(raw)
                except ValueError:
                    continue
                msg = obj.get("message", {}) or {}
                # Peak = total turn tokens (input context + this turn's output).
                # Output is included deliberately: it rolls into the next turn's
                # input, so total is the better compaction-risk proxy. Evidence:
                # the one run that auto-compacted peaked at 161,661 input-only
                # but 173,972 total — only total lands it in the ~167k+ band.
                u = msg.get("usage") or {}
                if u:
                    peak = max(
                        peak,
                        u.get("input_tokens", 0)
                        + u.get("cache_read_input_tokens", 0)
                        + u.get("cache_creation_input_tokens", 0)
                        + u.get("output_tokens", 0),
                    )
                if msg.get("role") == "assistant":
                    text = message_text(msg)
                    if text:
                        report = text  # keep the most recent assistant turn
    except OSError:
        pass
    return {
        "compactions": compactions,
        "peak": peak,
        "report": report,
    }


def blocking_section(text: str) -> str:
    """Return the body of the report's `### Blocking` section (everything up to
    the next Minor/##-level heading), or empty if there is none."""
    m = re.search(
        r"###?\s*Blocking(.*?)(?:\n###?\s*Minor|\n##\s|\Z)", text, re.S | re.I
    )
    return m.group(1).strip() if m else ""


def collect(
    root: Path,
    type_filter: str | None,
    since: float | None,
    skip_keys: set[tuple[str, str]] | None = None,
) -> list[dict]:
    """Collect stats from JSONL subagent transcripts.

    `skip_keys`: (session_uuid, tool_use_id) pairs already tracked in the cfl DB —
    skip matching JSONL files so DB data takes precedence and entries are not
    double-counted in the merged result."""
    runs = []
    for meta, jsonl in iter_runs(root, type_filter):
        if since is not None and os.path.getmtime(jsonl) < since:
            continue
        if skip_keys:
            # Derive (session_uuid, tool_use_id) from the JSONL path:
            #   <root>/<project>/<session_uuid>/subagents/agent-<tool_use_id>.jsonl
            j = Path(jsonl)
            session_uuid = j.parts[-3]
            tool_use_id = j.stem.removeprefix("agent-")
            if (session_uuid, tool_use_id) in skip_keys:
                continue  # Already tracked in cfl DB; use SQL path instead.
        scan = scan_run(jsonl)
        report = scan["report"]
        verdict, blk, mnr = parse_summary(report)
        # Path layout: <project>/<session>/subagents/agent-*.jsonl → parts[-4] is project.
        parts = Path(jsonl).parts
        runs.append(
            {
                "type": meta.get("agentType", "?"),
                "desc": meta.get("description", ""),
                "project": parts[-4] if len(parts) >= 4 else "?",
                "verdict": verdict,
                "blocking": blk,
                "minor": mnr,
                "compactions": scan["compactions"],
                "peak": scan["peak"],
                "jsonl": jsonl,
                "report": report,
            }
        )
    return runs


def pct(n: int, d: int) -> str:
    return f"{100 * n / d:.0f}%" if d else NO_DATA


def peak_line(runs: list[dict]) -> str:
    peaks = sorted(r["peak"] for r in runs if r["peak"])
    if not peaks:
        return NO_DATA
    over = sum(1 for p in peaks if p >= AUTO_COMPACT_TOKEN_THRESHOLD)
    return (
        f"median {int(statistics.median(peaks)):,}  max {peaks[-1]:,}"
        f"  [>={AUTO_COMPACT_TOKEN_THRESHOLD // 1000}k auto-compact zone: {over}]"
    )


def verdict_counts(runs: list[dict]) -> dict:
    return {
        "n": len(runs),
        "clean": sum(1 for r in runs if r["verdict"] == "clean"),
        "minor": sum(1 for r in runs if r["verdict"] == "minor"),
        "blocking": sum(1 for r in runs if r["verdict"] == "blocking"),
        "unparsed": sum(1 for r in runs if r["verdict"] == "unparsed"),
    }


def report_one_type(runs: list[dict], agent_type: str, show_findings: bool) -> None:
    n = len(runs)
    print(f"{agent_type} — {n} runs\n")
    compacted = sum(1 for r in runs if r["compactions"] > 0)
    print(f"  compaction: {compacted}/{n} runs ({pct(compacted, n)})")
    print(f"  peak tokens: {peak_line(runs)}\n")

    groups = [("all", runs)]

    for label, grp in groups:
        if not grp:
            continue
        c = verdict_counts(grp)
        print(f"  [{label}]  n={c['n']}")
        print(
            f"    verdicts:   clean {c['clean']} | minor-only {c['minor']} "
            f"| blocking {c['blocking']}"
            + (f" | unparsed {c['unparsed']}" if c["unparsed"] else "")
        )
        print(
            f"    raised >=1 blocking: {c['blocking']}/{c['n']} ({pct(c['blocking'], c['n'])})"
        )
        gcompact = sum(1 for r in grp if r["compactions"] > 0)
        print(
            f"    compaction: {gcompact}/{c['n']} ({pct(gcompact, c['n'])})   "
            f"peak: {peak_line(grp)}"
        )
        print()

    if show_findings:
        blockers = [r for r in runs if r["verdict"] == "blocking"]
        # DB-sourced records have no report text (findings text is not persisted in v1).
        text_blockers = [r for r in blockers if r["report"]]
        db_only = len(blockers) - len(text_blockers)
        note = f", {db_only} DB-sourced (no text)" if db_only else ""
        print(f"=== blocking-finding text ({len(text_blockers)} runs{note}) ===")
        for r in sorted(text_blockers, key=lambda r: -(r["blocking"] or 0)):
            print(
                f"\n--- [{r['project']}]  "
                f"{r['blocking']} blocking, {r['minor'] or 0} minor ---"
            )
            body = blocking_section(r["report"]) or r["report"]
            print(body[:900])


def report_summary(runs: list[dict]) -> None:
    types: dict[str, list[dict]] = {}
    for r in runs:
        types.setdefault(r["type"], []).append(r)
    print(
        f"{'agent type':<26} {'runs':>5} {'compact%':>9} {'blocking%':>10} {'median pk':>11}"
    )
    print("-" * 65)
    for t in sorted(types, key=lambda t: -len(types[t])):
        grp = types[t]
        n = len(grp)
        comp = sum(1 for r in grp if r["compactions"] > 0)
        blk = sum(1 for r in grp if r["verdict"] == "blocking")
        parseable = sum(1 for r in grp if r["verdict"] != "unparsed")
        peaks = [r["peak"] for r in grp if r["peak"]]
        med = f"{int(statistics.median(peaks)):,}" if peaks else NO_DATA
        blk_pct = pct(blk, parseable) if parseable else "n/a"
        print(f"{t:<26} {n:>5} {pct(comp, n):>9} {blk_pct:>10} {med:>11}")
    print(
        f"\n{len(runs)} runs across {len(types)} agent types. "
        f"blocking% is over runs with a parseable ## Summary line."
    )


def main() -> int:
    p = argparse.ArgumentParser(
        description="Post-hoc effectiveness stats for subagent runs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("--type", help="restrict to one agentType (detailed report)")
    p.add_argument(
        "--findings",
        action="store_true",
        help="print Blocking section text for each blocking run",
    )
    p.add_argument("--since", help="only runs modified on/after DATE (YYYY-MM-DD)")
    p.add_argument("--projects", help="override projects root")
    p.add_argument("--json", action="store_true", help="emit JSON")
    args = p.parse_args()

    if args.findings and not args.type:
        print(
            "--findings requires --type (findings are only dumped in the "
            "per-type report)",
            file=sys.stderr,
        )
        return 1

    root = projects_root(args.projects)
    if not root.is_dir():
        print(f"projects root not found: {root}", file=sys.stderr)
        return 1

    since = None
    since_str = (
        None  # ISO date string for DB queries (separate from JSONL Unix timestamp)
    )
    if args.since:
        try:
            y, m, d = (int(x) for x in args.since.split("-"))
            datetime.date(y, m, d)  # rejects invalid day/month (timegm would roll over)
            since = calendar.timegm((y, m, d, 0, 0, 0, 0, 0, 0))
            since_str = args.since
        except (ValueError, TypeError):
            print(f"bad --since date (want YYYY-MM-DD): {args.since}", file=sys.stderr)
            return 1

    # SQL-first: query the cfl DB for dispatches it knows about, then fall back to JSONL
    # for any subagents that predate the DB (no DB dispatch row).
    db_records: list[dict] = []
    skip_keys: set[tuple[str, str]] = set()
    conn = _open_cfl_db()
    if conn is not None:
        try:
            db_records = collect_db(conn, args.type, since_str)
            skip_keys = db_covered_dispatch_keys(conn)
        finally:
            conn.close()

    jsonl_records = collect(root, args.type, since, skip_keys=skip_keys)
    runs = jsonl_records + db_records

    if not runs:
        print("no matching subagent runs found", file=sys.stderr)
        return 1

    if args.json:
        slim = [
            {
                k: r[k]
                for k in (
                    "type",
                    "project",
                    "verdict",
                    "blocking",
                    "minor",
                    "compactions",
                    "peak",
                    "desc",
                )
            }
            for r in runs
        ]
        print(json.dumps(slim, indent=2))
        return 0

    if args.type:
        report_one_type(runs, args.type, args.findings)
    else:
        report_summary(runs)
    return 0


if __name__ == "__main__":
    sys.exit(main())
