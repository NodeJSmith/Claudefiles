#!/usr/bin/env bash
# Azure DevOps build management — list, cancel, or bulk-cancel pipeline builds.
# Uses az devops defaults for org/project (no flags needed).
#
# Usage: ado-builds <command> [args...]
#
# Commands:
#   list [--tags TAG] [--branch BRANCH] [--status STATUS] [--top N] [--json]
#       List builds with optional filters. Defaults: --top 50.
#       Output: one line per build — ID, status, result, pipeline name, tags.
#
#   cancel <build-id> [build-id...]
#       Cancel one or more builds by ID. Skips already completed/cancelled builds.
#
#   cancel-by-tag <tag> [--branch BRANCH]
#       Cancel all in-progress builds matching a tag. Default: branch from git-default-branch.
#       Shows what will be cancelled and proceeds.

set -euo pipefail

usage() {
  echo "Usage: ado-builds <command> [args...]" >&2
  echo "Commands:" >&2
  echo "  list [--tags TAG] [--branch BRANCH] [--status STATUS] [--top N] [--json]" >&2
  echo "      List builds. Defaults: --top 50." >&2
  echo "  cancel <build-id> [build-id...]" >&2
  echo "      Cancel one or more builds by ID." >&2
  echo "  cancel-by-tag <tag> [--branch BRANCH]" >&2
  echo "      Cancel all in-progress builds for a tag. Default: branch from git-default-branch." >&2
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

cmd="$1"
shift

case "$cmd" in
  --help | -h)
    cat << 'EOF'
ado-builds — Azure DevOps build management

Usage: ado-builds <command> [args...]

Commands:
  list [--tags TAG] [--branch BRANCH] [--status STATUS] [--top N] [--json]
      List builds with optional filters. Defaults: --top 50.

  cancel <build-id> [build-id...]
      Cancel one or more builds by ID. Skips already completed/cancelled builds.

  cancel-by-tag <tag> [--branch BRANCH]
      Cancel all in-progress builds matching a tag.

Examples:
  ado-builds list --status inProgress
  ado-builds list --tags deploy --branch main --top 10
  ado-builds cancel 12345 12346
  ado-builds cancel-by-tag deploy --branch release/2.0

Use "ado-builds <command> --help" for subcommand details.
EOF
    exit 0
    ;;
  list)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-builds list — list pipeline builds

Usage: ado-builds list [--tags TAG] [--branch BRANCH] [--status STATUS] [--top N] [--json]

Options:
  --tags TAG       Filter by build tag
  --branch BRANCH  Filter by source branch
  --status STATUS  Filter by status (inProgress, completed, cancelling, etc.)
  --top N          Max results (default: 50)
  --json           Output raw JSON

Examples:
  ado-builds list --status inProgress
  ado-builds list --tags deploy --branch main --json
EOF
      exit 0
    fi

    tags=""
    branch=""
    status=""
    top="50"
    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --tags)
          tags="$2"
          shift 2
          ;;
        --branch)
          branch="$2"
          shift 2
          ;;
        --status)
          status="$2"
          shift 2
          ;;
        --top)
          top="$2"
          shift 2
          ;;
        --json)
          output_json=true
          shift
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    args=(az pipelines build list --top "$top")
    [[ -n "$tags" ]] && args+=(--tags "$tags")
    [[ -n "$branch" ]] && args+=(--branch "$branch")
    [[ -n "$status" ]] && args+=(--status "$status")

    result=$("${args[@]}")

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      echo "$result" | jq -r '.[] | [
                (.id | tostring),
                .status,
                (.result // "-"),
                .definition.name,
                ((.tags // []) | join(","))
            ] | @tsv' | column -t -s $'\t'
    fi
    ;;

  cancel)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-builds cancel — cancel builds by ID

Usage: ado-builds cancel <build-id> [build-id...]

Cancels one or more builds. Skips builds that are already completed or cancelling.

Examples:
  ado-builds cancel 12345
  ado-builds cancel 12345 12346 12347
EOF
      exit 0
    fi

    if [[ $# -lt 1 ]]; then
      echo "Usage: ado-builds cancel <build-id> [build-id...]" >&2
      exit 1
    fi

    for build_id in "$@"; do
      # Fetch current status before attempting cancel
      current=$(az pipelines build show --id "$build_id" | jq -r '.status')

      if [[ "$current" == "completed" || "$current" == "cancelling" ]]; then
        echo "Skipped $build_id (already $current)"
        continue
      fi

      az pipelines build cancel --build-id "$build_id" > /dev/null
      echo "Cancelled $build_id"
    done
    ;;

  cancel-by-tag)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-builds cancel-by-tag — cancel builds by tag

Usage: ado-builds cancel-by-tag <tag> [--branch BRANCH]

Cancels all in-progress builds matching a tag. Defaults to the branch from git-default-branch.

Options:
  --branch BRANCH  Filter by source branch (default: from git-default-branch)

Examples:
  ado-builds cancel-by-tag deploy
  ado-builds cancel-by-tag nightly --branch release/2.0
EOF
      exit 0
    fi

    if [[ $# -lt 1 ]]; then
      echo "Usage: ado-builds cancel-by-tag <tag> [--branch BRANCH]" >&2
      exit 1
    fi

    tag="$1"
    shift
    branch=$(git-default-branch 2> /dev/null || echo "master")

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --branch)
          branch="$2"
          shift 2
          ;;
        *)
          echo "Unknown option: $1" >&2
          exit 1
          ;;
      esac
    done

    # Fetch builds matching tag + branch that are still in progress or not started
    builds=$(az pipelines build list --tags "$tag" --branch "$branch" --top 100 |
      jq -r '.[] | select(.status != "completed") | [(.id | tostring), .status, .definition.name] | @tsv')

    if [[ -z "$builds" ]]; then
      echo "No in-progress builds found for tag '$tag' on branch '$branch'"
      exit 0
    fi

    count=$(echo "$builds" | wc -l)
    echo "Found $count build(s) to cancel for tag '$tag' on branch '$branch':"
    echo "$builds" | column -t -s $'\t'
    echo ""

    while IFS=$'\t' read -r build_id status name; do
      az pipelines build cancel --build-id "$build_id" > /dev/null
      echo "Cancelled $build_id ($name)"
    done <<< "$builds"

    echo ""
    echo "Done — cancelled $count build(s)"
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage
    ;;
esac
