#!/usr/bin/env bash
# pytest-loop-reset — manually clear all pytest failure loop counters.
#
# Clears both the no-edit counter (.count) and the total failure counter
# (.total). Use when the pytest-loop-detector hook denies a run and you
# want to retry without setting CLAUDE_PYTEST_LOOP_BYPASS=1.
# Reads the session UUID from the same path as the detector hook.
#
# Usage:
#   pytest-loop-reset

set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  printf 'Usage: pytest-loop-reset\n\n'
  printf 'Clear all pytest failure loop counters for the current session.\n'
  printf 'Clears both the no-edit counter and the total failure counter.\n'
  printf 'Use when the pytest-loop-detector hook denies a run and you want\n'
  printf 'to retry without setting CLAUDE_PYTEST_LOOP_BYPASS=1.\n'
  exit 0
fi

TMPDIR="${CLAUDE_CODE_TMPDIR:-/tmp}"
SESSION_FILE="${TMPDIR}/claude-pytest-loop-session.id"

if [ ! -f "$SESSION_FILE" ]; then
  printf 'pytest-loop-reset: no active session (session ID file not found)\n'
  exit 0
fi

SESSION_UUID=$(tr -d '[:space:]' < "$SESSION_FILE")

if [ -z "$SESSION_UUID" ]; then
  printf 'pytest-loop-reset: session ID file is empty, nothing to reset\n'
  exit 0
fi

COUNTER_FILE="${TMPDIR}/claude-pytest-loop-${SESSION_UUID}.count"
TOTAL_FILE="${TMPDIR}/claude-pytest-loop-${SESSION_UUID}.total"

CLEARED=0

if [ -f "$COUNTER_FILE" ]; then
  printf '%s\n' "0" > "${COUNTER_FILE}.tmp" && mv "${COUNTER_FILE}.tmp" "$COUNTER_FILE"
  CLEARED=1
fi

if [ -f "$TOTAL_FILE" ]; then
  printf '%s\n' "0" > "${TOTAL_FILE}.tmp" && mv "${TOTAL_FILE}.tmp" "$TOTAL_FILE"
  CLEARED=1
fi

if [ "$CLEARED" -eq 0 ]; then
  printf 'pytest-loop-reset: no counter files found (already at 0 or no pytest runs yet)\n'
else
  printf 'pytest-loop-reset: all failure counters cleared\n'
fi

exit 0
