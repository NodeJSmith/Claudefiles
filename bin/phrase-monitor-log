#!/usr/bin/env bash
# View phrase monitor detections
#
# Usage:
#   phrase-monitor-log              # last 20 detections
#   phrase-monitor-log -n 50        # last 50
#   phrase-monitor-log --stats      # category frequency summary
#   phrase-monitor-log --clear      # truncate the log
#   phrase-monitor-log --tail       # follow new detections

set -euo pipefail

log_file="/tmp/claude-phrase-monitor.log"

if [ ! -f "$log_file" ]; then
  echo "No detections yet. Log file does not exist: $log_file"
  exit 0
fi

case "${1:-}" in
  --stats | -s)
    echo "Category frequency (all time):"
    echo "---"
    awk -F'\t' '{print $3}' "$log_file" | sort | uniq -c | sort -rn
    echo ""
    echo "Top phrases:"
    echo "---"
    awk -F'\t' '{print $3 "\t" $5}' "$log_file" | sort | uniq -c | sort -rn | head -20
    echo ""
    echo "Total detections: $(wc -l < "$log_file")"
    ;;
  --clear | -c)
    : > "$log_file"
    echo "Log cleared."
    ;;
  --tail | -f)
    tail -f "$log_file" | awk -F'\t' '{printf "%s  %-20s  [%s]  %s\n", $1, $3, $5, substr($6, 1, 80)}'
    ;;
  --help | -h)
    echo "Usage: phrase-monitor-log [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  -n N       Show last N detections (default: 20)"
    echo "  --stats    Category frequency summary"
    echo "  --clear    Truncate the log"
    echo "  --tail     Follow new detections live"
    echo "  --help     This message"
    ;;
  -n)
    n="${2:-20}"
    tail -n "$n" "$log_file" | awk -F'\t' '{printf "%s  %-20s  [%s]  %s\n", $1, $3, $5, substr($6, 1, 80)}'
    ;;
  *)
    tail -n 20 "$log_file" | awk -F'\t' '{printf "%s  %-20s  [%s]  %s\n", $1, $3, $5, substr($6, 1, 80)}'
    ;;
esac
