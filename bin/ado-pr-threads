#!/usr/bin/env bash
# Azure DevOps PR thread operations — list, reply, resolve threads.
# Uses ADO REST API with PAT authentication.
#
# Usage: ado-pr-threads <command> [args...]
#
# Commands:
#   list [PR_ID] [--all] [--json]
#       List PR threads. Default: active threads only. Auto-detects PR if omitted.
#
#   reply PR_ID THREAD_ID BODY
#       Reply to a thread. Prints new comment ID on success.
#
#   resolve THREAD_ID [THREAD_ID...] [--pr PR_ID] [--status STATUS]
#       Resolve one or more threads. Auto-detects PR if --pr omitted.
#       Default status: fixed.
#
#   resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]
#       Resolve all active threads matching PATTERN (substring match).
#       Default status: closed.

set -euo pipefail

# Source shared ADO utilities (resolve symlink to find real bin/ dir)
# Pin to 7.0 — thread API behavior differs in 7.1; not yet verified compatible
ADO_API_VERSION="7.0"
_self="$(readlink -f "$0")"
source "$(dirname "$_self")/ado-common.sh"

usage() {
  echo "Usage: ado-pr-threads <command> [args...]" >&2
  echo "Commands:" >&2
  echo "  list [PR_ID] [--all] [--json]" >&2
  echo "      List threads. Default: active only. Auto-detects PR if omitted." >&2
  echo "  reply PR_ID THREAD_ID BODY" >&2
  echo "      Reply to a thread. Prints new comment ID." >&2
  echo "  resolve THREAD_ID [THREAD_ID...] [--pr PR_ID] [--status STATUS]" >&2
  echo "      Resolve threads. Auto-detects PR if --pr omitted. Default status: fixed." >&2
  echo "  resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]" >&2
  echo "      Resolve threads matching PATTERN. Default status: closed." >&2
  exit 1
}

validate_thread_status() {
  local status="$1"
  local valid_statuses=("active" "byDesign" "closed" "fixed" "pending" "wontFix")

  local found=false
  for valid in "${valid_statuses[@]}"; do
    if [[ "$status" == "$valid" ]]; then
      found=true
      break
    fi
  done

  if [[ "$found" != true ]]; then
    echo "Error: invalid status '$status'. Valid: ${valid_statuses[*]}" >&2
    exit 1
  fi
}

resolve_single_thread() {
  local org="$1"
  local project_encoded="$2"
  local repo="$3"
  local pr_id="$4"
  local thread_id="$5"
  local status="$6"

  # Check current status first
  local thread_url="$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id?api-version=$ADO_API_VERSION"
  local thread_data
  thread_data=$(call_ado_api GET "$thread_url")
  local current_status
  current_status=$(echo "$thread_data" | jq -r '.status // "unknown"')

  if [[ "$current_status" == "$status" ]]; then
    echo "skip|$thread_id"
    return 0
  fi

  # Update thread status
  local payload
  payload=$(jq -n --arg st "$status" '{status: $st}')
  local result
  result=$(call_ado_api PATCH "$thread_url" -d "$payload")

  local new_status
  new_status=$(echo "$result" | jq -r '.status // empty')
  if [[ "$new_status" == "$status" ]]; then
    echo "success|$thread_id"
    return 0
  else
    echo "failed|$thread_id"
    return 1
  fi
}

if [[ $# -lt 1 ]]; then
  usage
fi

cmd="$1"
shift

case "$cmd" in
  --help | -h)
    cat << 'EOF'
ado-pr-threads — Azure DevOps PR thread operations

Usage: ado-pr-threads <command> [args...]

Commands:
  list [PR_ID] [--all] [--json]
      List PR threads. Default: active threads only. Auto-detects PR if omitted.

  reply PR_ID THREAD_ID BODY
      Reply to a thread. Prints new comment ID on success.

  resolve THREAD_ID [THREAD_ID...] [--pr PR_ID] [--status STATUS]
      Resolve one or more threads. Auto-detects PR if --pr omitted.

  resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]
      Resolve all active threads matching PATTERN (substring match).

Examples:
  ado-pr-threads list --all
  ado-pr-threads reply 42 15 "Done — fixed in latest push"
  ado-pr-threads resolve 15 16 --pr 42 --status fixed
  ado-pr-threads resolve-pattern 42 "nit" --dry-run

Use "ado-pr-threads <command> --help" for subcommand details.
EOF
    exit 0
    ;;
  list)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr-threads list — list PR threads

Usage: ado-pr-threads list [PR_ID] [--all] [--json]

Auto-detects PR from current branch if PR_ID is omitted.
Default: shows only active threads.

Options:
  --all   Show all threads (including resolved)
  --json  Output raw JSON

Examples:
  ado-pr-threads list
  ado-pr-threads list 42 --all
  ado-pr-threads list --json
EOF
      exit 0
    fi

    pr_id=""
    show_all=false
    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --all)
          show_all=true
          shift
          ;;
        --json)
          output_json=true
          shift
          ;;
        *)
          if [[ -z "$pr_id" ]]; then
            pr_id="$1"
            shift
          else
            echo "Unknown option: $1" >&2
            usage
          fi
          ;;
      esac
    done

    if [[ -z "$pr_id" ]]; then
      pr_id=$(get_pr_from_env_or_branch)
    fi

    mapfile -t context < <(setup_ado_context)
    org="${context[0]}"
    repo="${context[2]}"
    project_encoded="${context[3]}"

    url="$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads?api-version=$ADO_API_VERSION"

    result=$(call_ado_api GET "$url")
    check_api_response "$result" "value"

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      # Filter and format threads
      filter_jq='.value[]'
      if [[ "$show_all" != true ]]; then
        filter_jq='.value[] | select(.status == "active")'
      fi

      echo "$result" | jq -r "$filter_jq |
                [
                    (.id | tostring),
                    (.status // \"unknown\"),
                    (.threadContext.filePath // \"(general)\"),
                    ((.threadContext.rightFileStart?.line // \"?\") | tostring),
                    (.comments[0].author.displayName // \"unknown\"),
                    (.comments[0].content // \"\" | gsub(\"\\n\"; \" \") | .[0:80])
                ] | @tsv" | column -t -s $'\t'
    fi
    ;;

  reply)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr-threads reply — reply to a thread

Usage: ado-pr-threads reply PR_ID THREAD_ID BODY

Replies to an existing thread. Prints the new comment ID on success.

Examples:
  ado-pr-threads reply 42 15 "Done — fixed in latest push"
  ado-pr-threads reply 42 15 "Won't fix — see design doc"
EOF
      exit 0
    fi

    if [[ $# -lt 3 ]]; then
      echo "Usage: ado-pr-threads reply PR_ID THREAD_ID BODY" >&2
      exit 1
    fi

    pr_id="$1"
    thread_id="$2"
    body="$3"

    mapfile -t context < <(setup_ado_context)
    org="${context[0]}"
    repo="${context[2]}"
    project_encoded="${context[3]}"

    # First, get the thread to find the last comment (parent)
    thread_url="$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id?api-version=$ADO_API_VERSION"
    thread_data=$(call_ado_api GET "$thread_url")

    last_comment_id=$(echo "$thread_data" | jq -r '.comments[-1].id')

    if [[ -z "$last_comment_id" || "$last_comment_id" == "null" ]]; then
      echo "Error: could not find thread $thread_id or extract last comment" >&2
      exit 1
    fi

    # Post reply to the thread
    url="$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id/comments?api-version=$ADO_API_VERSION"
    payload=$(jq -n --arg content "$body" --argjson parent_id "$last_comment_id" '{
            content: $content,
            parentCommentId: $parent_id,
            commentType: 1
        }')

    result=$(call_ado_api POST "$url" -d "$payload")

    new_comment_id=$(echo "$result" | jq -r '.id')
    if [[ -n "$new_comment_id" && "$new_comment_id" != "null" ]]; then
      echo "Reply posted: $new_comment_id"
    else
      echo "Error: failed to post reply" >&2
      echo "$result" >&2
      exit 1
    fi
    ;;

  resolve)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr-threads resolve — resolve threads

Usage: ado-pr-threads resolve THREAD_ID [THREAD_ID...] [--pr PR_ID] [--status STATUS]

Auto-detects PR from current branch if --pr is omitted.
Valid statuses: active, byDesign, closed, fixed, pending, wontFix.

Options:
  --pr PR_ID       PR ID (default: auto-detect from branch)
  --status STATUS  Resolution status (default: fixed)

Examples:
  ado-pr-threads resolve 15
  ado-pr-threads resolve 15 16 17 --pr 42
  ado-pr-threads resolve 15 --status wontFix
EOF
      exit 0
    fi

    if [[ $# -lt 1 ]]; then
      echo "Usage: ado-pr-threads resolve THREAD_ID [THREAD_ID...] [--pr PR_ID] [--status STATUS]" >&2
      exit 1
    fi

    pr_id=""
    status="fixed"
    thread_ids=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --pr)
          pr_id="$2"
          shift 2
          ;;
        --status)
          status="$2"
          shift 2
          ;;
        *)
          thread_ids+=("$1")
          shift
          ;;
      esac
    done

    if [[ ${#thread_ids[@]} -eq 0 ]]; then
      echo "Error: no thread IDs provided" >&2
      exit 1
    fi

    validate_thread_status "$status"

    mapfile -t context < <(setup_ado_context)
    org="${context[0]}"
    repo="${context[2]}"
    project_encoded="${context[3]}"

    if [[ -z "$pr_id" ]]; then
      pr_id=$(get_pr_from_env_or_branch)
    fi

    for thread_id in "${thread_ids[@]}"; do
      result=$(resolve_single_thread "$org" "$project_encoded" "$repo" "$pr_id" "$thread_id" "$status")
      action="${result%%|*}"
      tid="${result#*|}"

      case "$action" in
        skip) echo "Skipped $tid (already $status)" ;;
        success) echo "Resolved $tid → $status" ;;
        failed) echo "FAILED to resolve $tid" >&2 ;;
      esac
    done
    ;;

  resolve-pattern)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr-threads resolve-pattern — resolve threads by pattern

Usage: ado-pr-threads resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]

Resolves all active threads whose comments match PATTERN (case-insensitive substring).

Options:
  --status STATUS  Resolution status (default: closed)
  --dry-run        Show what would be resolved without making changes

Examples:
  ado-pr-threads resolve-pattern 42 "nit" --dry-run
  ado-pr-threads resolve-pattern 42 "style" --status byDesign
EOF
      exit 0
    fi

    if [[ $# -lt 2 ]]; then
      echo "Usage: ado-pr-threads resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]" >&2
      exit 1
    fi

    pr_id="$1"
    pattern="$2"
    shift 2

    status="closed"
    dry_run=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --status)
          status="$2"
          shift 2
          ;;
        --dry-run)
          dry_run=true
          shift
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    validate_thread_status "$status"

    mapfile -t context < <(setup_ado_context)
    org="${context[0]}"
    repo="${context[2]}"
    project_encoded="${context[3]}"

    # Fetch all threads
    url="$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads?api-version=$ADO_API_VERSION"
    threads=$(call_ado_api GET "$url")
    check_api_response "$threads" "value"

    # Filter: active status AND case-insensitive pattern match in any comment
    matching=$(echo "$threads" | jq -r --arg pattern "$pattern" '
            [.value[] |
                select(.status == "active") |
                select(.comments | any(.content // "" | test($pattern; "i")))
            ]
        ')

    count=$(echo "$matching" | jq 'length')

    if [[ "$count" -eq 0 ]]; then
      echo "No active threads matching '$pattern' on PR #$pr_id"
      exit 0
    fi

    echo "Found $count active thread(s) matching '$pattern' on PR #$pr_id"

    resolved=0
    while IFS=$'\t' read -r thread_id preview; do
      if [[ "$dry_run" == true ]]; then
        echo "  [dry-run] Would resolve thread $thread_id: $preview"
        ((resolved++)) || true
      else
        result=$(resolve_single_thread "$org" "$project_encoded" "$repo" "$pr_id" "$thread_id" "$status")
        action="${result%%|*}"

        if [[ "$action" == "success" ]]; then
          echo "  Resolved thread $thread_id: $preview"
          ((resolved++)) || true
        else
          echo "  FAILED to resolve thread $thread_id: $preview" >&2
        fi
      fi
    done < <(echo "$matching" | jq -r '.[] | [
            (.id | tostring),
            (.comments[0].content // "" | gsub("\\n"; " ") | .[0:80])
        ] | @tsv')

    action="Would resolve"
    if [[ "$dry_run" != true ]]; then
      action="Resolved"
    fi

    echo "$action $resolved/$count threads"
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage
    ;;
esac
