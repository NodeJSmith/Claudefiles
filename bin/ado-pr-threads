#!/usr/bin/env bash
# Azure DevOps PR thread operations — list, reply, resolve threads.
# Uses ADO REST API with PAT authentication.
#
# Usage: ado-pr-threads <command> [args...]
#
# Commands:
#   list [PR_ID] [--all] [--json]
#       List PR threads. Default: active threads only. Auto-detects PR if omitted.
#
#   reply PR_ID THREAD_ID BODY
#       Reply to a thread. Prints new comment ID on success.
#
#   resolve THREAD_ID [THREAD_ID...] [--status STATUS]
#       Resolve one or more threads. Default status: fixed.
#
#   resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]
#       Resolve all active threads matching PATTERN (substring match).
#       Default status: closed.

set -euo pipefail

API_VERSION="7.0"

usage() {
    echo "Usage: ado-pr-threads <command> [args...]" >&2
    echo "Commands:" >&2
    echo "  list [PR_ID] [--all] [--json]" >&2
    echo "      List threads. Default: active only. Auto-detects PR if omitted." >&2
    echo "  reply PR_ID THREAD_ID BODY" >&2
    echo "      Reply to a thread. Prints new comment ID." >&2
    echo "  resolve THREAD_ID [THREAD_ID...] [--status STATUS]" >&2
    echo "      Resolve threads. Default status: fixed." >&2
    echo "  resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]" >&2
    echo "      Resolve threads matching PATTERN. Default status: closed." >&2
    exit 1
}

get_pat() {
    # Check env vars first
    if [[ -n "${SYSTEM_ACCESSTOKEN:-}" ]]; then
        echo "$SYSTEM_ACCESSTOKEN"
        return 0
    fi

    if [[ -n "${ADO_PAT:-}" ]]; then
        echo "$ADO_PAT"
        return 0
    fi

    # Parse ~/.azure/azuredevops/personalAccessTokens
    local token_file="$HOME/.azure/azuredevops/personalAccessTokens"
    if [[ -f "$token_file" ]]; then
        # File format: line 1 is header, line 2 is "key = value"
        local pat
        pat=$(sed -n '2p' "$token_file" | cut -d' ' -f3)
        if [[ -n "$pat" ]]; then
            echo "$pat"
            return 0
        fi
    fi

    echo "Error: Missing Azure DevOps PAT. Set SYSTEM_ACCESSTOKEN, ADO_PAT, or configure ~/.azure/azuredevops/personalAccessTokens" >&2
    exit 1
}

build_auth_header() {
    local pat
    pat=$(get_pat)
    local b64
    b64=$(printf "%s" "basic user:$pat" | base64 -w 0)
    echo "Authorization: Basic $b64"
}

get_ado_config() {
    # Parse az devops configure --list for org and project
    local config
    config=$(az devops configure --list 2>/dev/null)

    local org
    org=$(echo "$config" | grep -E '^organization' | cut -d' ' -f3)
    if [[ -z "$org" ]]; then
        echo "Error: organization not configured. Run 'az devops configure --defaults organization=<org>'" >&2
        exit 1
    fi

    local project
    project=$(echo "$config" | grep -E '^project' | cut -d' ' -f3)
    if [[ -z "$project" ]]; then
        echo "Error: project not configured. Run 'az devops configure --defaults project=<project>'" >&2
        exit 1
    fi

    echo "$org|$project"
}

get_repo_name() {
    # Parse git remote URL to extract repo name
    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null || true)

    if [[ -z "$remote_url" ]]; then
        echo "Error: not in a git repository with origin remote" >&2
        exit 1
    fi

    # Extract repo name from URL (last component before .git or end)
    # Example: https://dev.azure.com/org/project/_git/repo or git@ssh.dev.azure.com:v3/org/project/repo
    local repo
    repo=$(basename "$remote_url" .git)

    if [[ -z "$repo" ]]; then
        echo "Error: could not extract repo name from origin URL: $remote_url" >&2
        exit 1
    fi

    echo "$repo"
}

call_ado_api() {
    local method="$1"
    local url="$2"
    shift 2

    local auth_header
    auth_header=$(build_auth_header)

    curl -s -X "$method" "$url" \
        -H "$auth_header" \
        -H "Content-Type: application/json" \
        "$@"
}

get_pr_from_env_or_branch() {
    # Check SYSTEM_PULLREQUEST_PULLREQUESTID first (CI/CD env)
    if [[ -n "${SYSTEM_PULLREQUEST_PULLREQUESTID:-}" ]]; then
        echo "$SYSTEM_PULLREQUEST_PULLREQUESTID"
        return 0
    fi

    # Auto-detect from current branch
    local branch
    branch=$(git branch --show-current 2>/dev/null || true)
    if [[ -z "$branch" ]]; then
        echo "Error: not on a branch and SYSTEM_PULLREQUEST_PULLREQUESTID not set" >&2
        exit 1
    fi

    local pr_id
    pr_id=$(az repos pr list --source-branch "refs/heads/$branch" --status active \
        | jq -r '.[0].pullRequestId // empty' 2>/dev/null || true)

    if [[ -z "$pr_id" ]]; then
        echo "Error: no active PR found for branch '$branch'" >&2
        exit 1
    fi

    echo "$pr_id"
}

setup_ado_context() {
    # Returns org, project, repo, project_encoded (one per line for mapfile)
    local config
    config=$(get_ado_config)
    local org="${config%%|*}"
    local project="${config#*|}"
    local repo
    repo=$(get_repo_name)
    local project_encoded="${project// /%20}"

    echo "$org"
    echo "$project"
    echo "$repo"
    echo "$project_encoded"
}

validate_thread_status() {
    local status="$1"
    local valid_statuses=("active" "byDesign" "closed" "fixed" "pending" "wontFix")

    local found=false
    for valid in "${valid_statuses[@]}"; do
        if [[ "$status" == "$valid" ]]; then
            found=true
            break
        fi
    done

    if [[ "$found" != true ]]; then
        echo "Error: invalid status '$status'. Valid: ${valid_statuses[*]}" >&2
        exit 1
    fi
}

resolve_single_thread() {
    local org="$1"
    local project_encoded="$2"
    local repo="$3"
    local pr_id="$4"
    local thread_id="$5"
    local status="$6"

    # Check current status first
    local thread_url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id?api-version=$API_VERSION"
    local thread_data
    thread_data=$(call_ado_api GET "$thread_url")
    local current_status
    current_status=$(echo "$thread_data" | jq -r '.status // "unknown"')

    if [[ "$current_status" == "$status" ]]; then
        echo "skip|$thread_id"
        return 0
    fi

    # Update thread status
    local payload
    payload=$(jq -n --arg st "$status" '{status: $st}')
    local result
    result=$(call_ado_api PATCH "$thread_url" -d "$payload")

    local new_status
    new_status=$(echo "$result" | jq -r '.status // empty')
    if [[ "$new_status" == "$status" ]]; then
        echo "success|$thread_id"
        return 0
    else
        echo "failed|$thread_id"
        return 1
    fi
}

if [[ $# -lt 1 ]]; then
    usage
fi

cmd="$1"
shift

case "$cmd" in
    list)
        pr_id=""
        show_all=false
        output_json=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --all) show_all=true; shift ;;
                --json) output_json=true; shift ;;
                *)
                    if [[ -z "$pr_id" ]]; then
                        pr_id="$1"
                        shift
                    else
                        echo "Unknown option: $1" >&2
                        usage
                    fi
                    ;;
            esac
        done

        if [[ -z "$pr_id" ]]; then
            pr_id=$(get_pr_from_env_or_branch)
        fi

        mapfile -t context < <(setup_ado_context)
        org="${context[0]}"
        project="${context[1]}"
        repo="${context[2]}"
        project_encoded="${context[3]}"

        url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads?api-version=$API_VERSION"

        result=$(call_ado_api GET "$url")

        if [[ "$output_json" == true ]]; then
            echo "$result"
        else
            # Filter and format threads
            filter_jq='.value[]'
            if [[ "$show_all" != true ]]; then
                filter_jq='.value[] | select(.status == "active")'
            fi

            echo "$result" | jq -r "$filter_jq |
                [
                    (.id | tostring),
                    (.status // \"unknown\"),
                    (.threadContext.filePath // \"(general)\"),
                    ((.threadContext.rightFileStart?.line // \"?\") | tostring),
                    (.comments[0].author.displayName // \"unknown\"),
                    (.comments[0].content // \"\" | gsub(\"\\n\"; \" \") | .[0:80])
                ] | @tsv" | column -t -s $'\t'
        fi
        ;;

    reply)
        if [[ $# -lt 3 ]]; then
            echo "Usage: ado-pr-threads reply PR_ID THREAD_ID BODY" >&2
            exit 1
        fi

        pr_id="$1"
        thread_id="$2"
        body="$3"

        mapfile -t context < <(setup_ado_context)
        org="${context[0]}"
        project="${context[1]}"
        repo="${context[2]}"
        project_encoded="${context[3]}"

        # First, get the thread to find the last comment (parent)
        thread_url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id?api-version=$API_VERSION"
        thread_data=$(call_ado_api GET "$thread_url")

        last_comment_id=$(echo "$thread_data" | jq -r '.comments[-1].id')

        if [[ -z "$last_comment_id" || "$last_comment_id" == "null" ]]; then
            echo "Error: could not find thread $thread_id or extract last comment" >&2
            exit 1
        fi

        # Post reply to the thread
        url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads/$thread_id/comments?api-version=$API_VERSION"
        payload=$(jq -n --arg content "$body" --argjson parent_id "$last_comment_id" '{
            content: $content,
            parentCommentId: $parent_id,
            commentType: 1
        }')

        result=$(call_ado_api POST "$url" -d "$payload")

        new_comment_id=$(echo "$result" | jq -r '.id')
        if [[ -n "$new_comment_id" && "$new_comment_id" != "null" ]]; then
            echo "Reply posted: $new_comment_id"
        else
            echo "Error: failed to post reply" >&2
            echo "$result" >&2
            exit 1
        fi
        ;;

    resolve)
        if [[ $# -lt 1 ]]; then
            echo "Usage: ado-pr-threads resolve THREAD_ID [THREAD_ID...] [--status STATUS]" >&2
            exit 1
        fi

        status="fixed"
        thread_ids=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --status) status="$2"; shift 2 ;;
                *)
                    thread_ids+=("$1")
                    shift
                    ;;
            esac
        done

        if [[ ${#thread_ids[@]} -eq 0 ]]; then
            echo "Error: no thread IDs provided" >&2
            exit 1
        fi

        validate_thread_status "$status"

        mapfile -t context < <(setup_ado_context)
        org="${context[0]}"
        project="${context[1]}"
        repo="${context[2]}"
        project_encoded="${context[3]}"

        # Need to get PR ID from one of the threads
        # Fetch first thread to extract PR ID
        thread_url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests?api-version=$API_VERSION"
        # Actually, we need PR ID to resolve. Let's require it as an env var or error
        # For simplicity, try to auto-detect from branch
        pr_id=$(get_pr_from_env_or_branch)

        for thread_id in "${thread_ids[@]}"; do
            result=$(resolve_single_thread "$org" "$project_encoded" "$repo" "$pr_id" "$thread_id" "$status")
            action="${result%%|*}"
            tid="${result#*|}"

            case "$action" in
                skip) echo "Skipped $tid (already $status)" ;;
                success) echo "Resolved $tid → $status" ;;
                failed) echo "FAILED to resolve $tid" >&2 ;;
            esac
        done
        ;;

    resolve-pattern)
        if [[ $# -lt 2 ]]; then
            echo "Usage: ado-pr-threads resolve-pattern PR_ID PATTERN [--status STATUS] [--dry-run]" >&2
            exit 1
        fi

        pr_id="$1"
        pattern="$2"
        shift 2

        status="closed"
        dry_run=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --status) status="$2"; shift 2 ;;
                --dry-run) dry_run=true; shift ;;
                *)
                    echo "Unknown option: $1" >&2
                    usage
                    ;;
            esac
        done

        validate_thread_status "$status"

        mapfile -t context < <(setup_ado_context)
        org="${context[0]}"
        project="${context[1]}"
        repo="${context[2]}"
        project_encoded="${context[3]}"

        # Fetch all threads
        url="https://dev.azure.com/$org/$project_encoded/_apis/git/repositories/$repo/pullRequests/$pr_id/threads?api-version=$API_VERSION"
        threads=$(call_ado_api GET "$url")

        # Filter: active status AND pattern match in any comment
        matching=$(echo "$threads" | jq -r --arg pattern "$pattern" '
            [.value[] |
                select(.status == "active") |
                select(.comments | any(.content | contains($pattern)))
            ]
        ')

        count=$(echo "$matching" | jq 'length')

        if [[ "$count" -eq 0 ]]; then
            echo "No active threads matching '$pattern' on PR #$pr_id"
            exit 0
        fi

        echo "Found $count active thread(s) matching '$pattern' on PR #$pr_id"

        resolved=0
        while IFS=$'\t' read -r thread_id preview; do
            if [[ "$dry_run" == true ]]; then
                echo "  [dry-run] Would resolve thread $thread_id: $preview"
                ((resolved++)) || true
            else
                result=$(resolve_single_thread "$org" "$project_encoded" "$repo" "$pr_id" "$thread_id" "$status")
                action="${result%%|*}"

                if [[ "$action" == "success" ]]; then
                    echo "  Resolved thread $thread_id: $preview"
                    ((resolved++)) || true
                else
                    echo "  FAILED to resolve thread $thread_id: $preview" >&2
                fi
            fi
        done < <(echo "$matching" | jq -r '.[] | [
            (.id | tostring),
            (.comments[0].content // "" | gsub("\\n"; " ") | .[0:80])
        ] | @tsv')

        action="Would resolve"
        if [[ "$dry_run" != true ]]; then
            action="Resolved"
        fi

        echo "$action $resolved/$count threads"
        ;;

    *)
        echo "Unknown command: $cmd" >&2
        usage
        ;;
esac
