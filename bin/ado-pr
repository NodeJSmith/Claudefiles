#!/usr/bin/env bash
# Azure DevOps PR helper — simplified wrapper around az repos pr with smart defaults.
# Uses az devops defaults for org/project (no flags needed).
#
# Usage: ado-pr <command> [args...]
#
# Commands:
#   list [--status STATUS] [--author AUTHOR] [--target BRANCH] [--top N] [--json]
#       List PRs. Defaults: --status active, --top 50.
#       Author shortcuts: @me expands to current user.
#
#   show [PR_ID] [--json]
#       Show PR details. Auto-detects from current branch if PR_ID omitted.
#
#   current [--json]
#       Show PR for current branch (if exists). Errors if no PR found.
#
#   create [--title TITLE] [--description DESC] [--target BRANCH] [--draft] [--json]
#       Create PR from current branch. Defaults: --target from git-default-branch.
#
#   update PR_ID [--title TITLE] [--description DESC] [--status STATUS]
#       Update PR fields. Status: active, abandoned, completed.

set -euo pipefail

# Source shared ADO utilities (resolve symlink to find real bin/ dir)
_self="$(readlink -f "$0")"
source "$(dirname "$_self")/ado-common.sh"

usage() {
  echo "Usage: ado-pr <command> [args...]" >&2
  echo "Commands:" >&2
  echo "  list [--status STATUS] [--author AUTHOR] [--target BRANCH] [--top N] [--json]" >&2
  echo "      List PRs. Defaults: --status active, --top 50." >&2
  echo "  show [PR_ID] [--json]" >&2
  echo "      Show PR details. Auto-detects from current branch if PR_ID omitted." >&2
  echo "  current [--json]" >&2
  echo "      Show PR for current branch (errors if no PR found)." >&2
  echo "  create [--title TITLE] [--description DESC] [--target BRANCH] [--draft] [--json]" >&2
  echo "      Create PR from current branch. Default: --target from git-default-branch." >&2
  echo "  update PR_ID [--title TITLE] [--description DESC] [--status STATUS]" >&2
  echo "      Update PR. Status: active, abandoned, completed." >&2
  exit 1
}

format_pr_detail() {
  # Format az repos pr show JSON as human-readable output
  jq -r '
        "PR #\(.pullRequestId): \(.title)",
        "Status: \(.status)",
        "Author: \(.createdBy.displayName) (\(.createdBy.uniqueName))",
        "Source: \(.sourceRefName | sub("refs/heads/"; "")) → \(.targetRefName | sub("refs/heads/"; ""))",
        "Created: \(.creationDate)",
        "URL: \(.repository.webUrl)/pullrequest/\(.pullRequestId)",
        "",
        "Description:",
        (.description // "(no description)")
    '
}

expand_author() {
  local author="$1"
  if [[ "$author" == "@me" ]]; then
    az account show --query user.name -o tsv
  else
    echo "$author"
  fi
}

if [[ $# -lt 1 ]]; then
  usage
fi

cmd="$1"
shift

case "$cmd" in
  --help | -h)
    cat << 'EOF'
ado-pr — Azure DevOps PR helper

Usage: ado-pr <command> [args...]

Commands:
  list [--status STATUS] [--author AUTHOR] [--target BRANCH] [--top N] [--json]
      List PRs. Defaults: --status active, --top 50.

  show [PR_ID] [--json]
      Show PR details. Auto-detects from current branch if PR_ID omitted.

  current [--json]
      Show PR for current branch (errors if no PR found).

  create [--title TITLE] [--description DESC] [--target BRANCH] [--draft] [--json]
      Create PR from current branch. Default target: from git-default-branch.

  update PR_ID [--title TITLE] [--description DESC] [--status STATUS]
      Update PR fields. Status: active, abandoned, completed.

Examples:
  ado-pr list --author @me
  ado-pr show 42 --json
  ado-pr current
  ado-pr create --title "Add feature" --draft
  ado-pr update 42 --status completed

Use "ado-pr <command> --help" for subcommand details.
EOF
    exit 0
    ;;
  list)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr list — list pull requests

Usage: ado-pr list [--status STATUS] [--author AUTHOR] [--target BRANCH] [--top N] [--json]

Options:
  --status STATUS   Filter by status (default: active)
  --author AUTHOR   Filter by author (@me expands to current user)
  --target BRANCH   Filter by target branch
  --top N           Max results (default: 50)
  --json            Output raw JSON

Examples:
  ado-pr list --author @me
  ado-pr list --status completed --top 10
  ado-pr list --target main --json
EOF
      exit 0
    fi

    status="active"
    author=""
    target=""
    top="50"
    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --status)
          status="$2"
          shift 2
          ;;
        --author)
          author=$(expand_author "$2")
          shift 2
          ;;
        --target)
          target="$2"
          shift 2
          ;;
        --top)
          top="$2"
          shift 2
          ;;
        --json)
          output_json=true
          shift
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    args=(az repos pr list --top "$top")
    [[ -n "$status" ]] && args+=(--status "$status")
    [[ -n "$author" ]] && args+=(--creator "$author")
    [[ -n "$target" ]] && args+=(--target-branch "$target")

    result=$("${args[@]}")

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      echo "$result" | jq -r '.[] | [
                (.pullRequestId | tostring),
                .status,
                .createdBy.displayName,
                .title,
                .creationDate[0:10]
            ] | @tsv' | column -t -s $'\t'
    fi
    ;;

  show)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr show — show PR details

Usage: ado-pr show [PR_ID] [--json]

Auto-detects PR from current branch if PR_ID is omitted.

Options:
  --json  Output raw JSON

Examples:
  ado-pr show 42
  ado-pr show --json
EOF
      exit 0
    fi

    pr_id=""
    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --json)
          output_json=true
          shift
          ;;
        *)
          if [[ -z "$pr_id" ]]; then
            pr_id="$1"
            shift
          else
            echo "Unknown option: $1" >&2
            usage
          fi
          ;;
      esac
    done

    if [[ -z "$pr_id" ]]; then
      pr_id=$(get_pr_from_env_or_branch)
    fi

    result=$(az repos pr show --id "$pr_id")

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      echo "$result" | format_pr_detail
    fi
    ;;

  current)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr current — show PR for current branch

Usage: ado-pr current [--json]

Errors if no PR is found for the current branch.

Options:
  --json  Output raw JSON

Examples:
  ado-pr current
  ado-pr current --json
EOF
      exit 0
    fi

    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --json)
          output_json=true
          shift
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    pr_id=$(get_pr_from_env_or_branch)

    result=$(az repos pr show --id "$pr_id")

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      echo "$result" | format_pr_detail
    fi
    ;;

  create)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr create — create a pull request

Usage: ado-pr create [--title TITLE] [--description DESC] [--target BRANCH] [--draft] [--json]

Creates a PR from the current branch. Default target: from git-default-branch.

Options:
  --title TITLE        PR title
  --description DESC   PR description
  --target BRANCH      Target branch (default: from git-default-branch)
  --draft              Create as draft PR
  --json               Output raw JSON

Examples:
  ado-pr create --title "Add feature" --draft
  ado-pr create --title "Fix bug" --target release/2.0
EOF
      exit 0
    fi

    title=""
    description=""
    target=$(git-default-branch 2> /dev/null || echo "master")
    draft=false
    output_json=false

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --title)
          title="$2"
          shift 2
          ;;
        --description)
          description="$2"
          shift 2
          ;;
        --target)
          target="$2"
          shift 2
          ;;
        --draft)
          draft=true
          shift
          ;;
        --json)
          output_json=true
          shift
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
      echo "Error: not on a branch" >&2
      exit 1
    fi

    args=(az repos pr create --source-branch "$branch" --target-branch "$target")
    [[ -n "$title" ]] && args+=(--title "$title")
    [[ -n "$description" ]] && args+=(--description "$description")
    [[ "$draft" == true ]] && args+=(--draft true)

    result=$("${args[@]}")

    if [[ "$output_json" == true ]]; then
      echo "$result"
    else
      pr_id=$(echo "$result" | jq -r '.pullRequestId')
      pr_url=$(echo "$result" | jq -r '"\(.repository.webUrl)/pullrequest/\(.pullRequestId)"')
      echo "Created PR #$pr_id"
      echo "$pr_url"
    fi
    ;;

  update)
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
      cat << 'EOF'
ado-pr update — update PR fields

Usage: ado-pr update PR_ID [--title TITLE] [--description DESC] [--status STATUS]

At least one of --title, --description, or --status is required.
Status values: active, abandoned, completed.

Examples:
  ado-pr update 42 --title "New title"
  ado-pr update 42 --status completed
  ado-pr update 42 --description "Updated description" --title "Better title"
EOF
      exit 0
    fi

    if [[ $# -lt 1 ]]; then
      echo "Usage: ado-pr update PR_ID [--title TITLE] [--description DESC] [--status STATUS]" >&2
      exit 1
    fi

    pr_id="$1"
    shift

    title=""
    description=""
    status=""

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --title)
          title="$2"
          shift 2
          ;;
        --description)
          description="$2"
          shift 2
          ;;
        --status)
          status="$2"
          shift 2
          ;;
        *)
          echo "Unknown option: $1" >&2
          usage
          ;;
      esac
    done

    if [[ -z "$title" && -z "$description" && -z "$status" ]]; then
      echo "Error: at least one of --title, --description, or --status is required" >&2
      exit 1
    fi

    args=(az repos pr update --id "$pr_id")
    [[ -n "$title" ]] && args+=(--title "$title")
    [[ -n "$description" ]] && args+=(--description "$description")
    [[ -n "$status" ]] && args+=(--status "$status")

    "${args[@]}" > /dev/null

    echo "Updated PR #$pr_id"
    [[ -n "$title" ]] && echo "  Title: $title"
    [[ -n "$description" ]] && echo "  Description updated"
    [[ -n "$status" ]] && echo "  Status: $status"
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    usage
    ;;
esac
