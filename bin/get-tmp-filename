#!/usr/bin/env bash
# Create a temp file for capturing command output.
# Prints the file path to stdout. Pair with tee/tail in the next command.
#
# Usage (run bare so the printed path is visible to reuse in the next call and
# to Read back later — shell state does not persist across separate Bash calls):
#   get-tmp-filename
#   command 2>&1 | tee /path/from/above | tail -80
#
# See rules/common/command-output.md for the full pattern.
[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && {
  cat << 'EOF'
Usage: get-tmp-filename

Create a temp file for capturing command output. Prints the path to stdout.

Run it bare so the printed path is visible to reuse in the next call with
tee — shell state does not persist across separate Bash tool calls.

Examples:
  get-tmp-filename                   # /tmp/claude-cmd-abc123.txt
  pytest -v 2>&1 | tee /path/from/above | tail -80
EOF
  exit 0
}

set -euo pipefail

mktemp "${CLAUDE_CODE_TMPDIR:-/tmp}/claude-cmd-XXXXXX.txt"
