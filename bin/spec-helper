#!/usr/bin/env python3
"""spec-helper — Work Package and spec directory management for the caliper v2 pipeline.

Commands:
  init <slug>                         Create design/specs/NNN-slug/ + spec.md template
  wp-move <feature> <wp-id> <lane>    Update WP lane frontmatter + append activity log
  status [feature]                    Print terminal kanban for one or all features
  next-number                         Print next available feature number

All commands exit 1 with a message on error. Success outputs go to stdout.
Pass --json to get JSON output where supported.
"""

import argparse
import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, NoReturn

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

VALID_LANES = ("planned", "doing", "for_review", "done")
LANE_HEADERS = ["Planned", "Doing", "For Review", "Done"]
LANE_KEYS = ["planned", "doing", "for_review", "done"]

SPEC_TEMPLATE = """\
---
feature_number: "{number}"
feature_slug: "{slug}"
status: "draft"
created: "{date}"
---

# Spec: {title}

## Problem Statement

<!-- What problem are we solving? Who experiences it? -->

## Goals

<!-- What does success look like? What are the measurable outcomes? -->

## Non-Goals

<!-- What is explicitly out of scope? -->

## User Scenarios

<!-- Primary flows: who does what, and what happens -->

## Functional Requirements

<!-- Testable, unambiguous requirements with clear acceptance criteria -->

## Edge Cases

<!-- Boundary conditions, error states, unusual inputs -->

## Dependencies and Assumptions

<!-- External systems, services, or assumptions this depends on -->

## Acceptance Criteria

<!-- Measurable, technology-agnostic criteria for done -->
"""

WP_TEMPLATE = """\
---
work_package_id: "{wp_id}"
title: "{title}"
lane: "planned"
plan_section: ""
depends_on: []
---

## Objectives & Success Criteria

<!-- What this WP achieves and how you know it's done -->

## Subtasks

<!-- Concrete steps to complete this WP -->

## Test Strategy

<!-- What tests are written, what they verify -->

## Review Guidance

<!-- What the spec reviewer and quality reviewer should check -->

## Activity Log

- {date} — system — lane=planned — WP created
"""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def find_repo_root() -> Path:
    """Walk up from cwd to find a directory containing design/specs/."""
    cwd = Path.cwd()
    for parent in [cwd, *cwd.parents]:
        if (parent / "design" / "specs").exists():
            return parent
    # Fallback: use cwd (init will create the directory)
    return cwd


def specs_dir(root: Path) -> Path:
    return root / "design" / "specs"


def list_features(root: Path) -> list[Path]:
    """Return sorted list of feature directories under design/specs/."""
    sd = specs_dir(root)
    if not sd.exists():
        return []
    dirs = sorted(
        [d for d in sd.iterdir() if d.is_dir() and re.match(r"^\d{3}-", d.name)],
        key=lambda d: d.name,
    )
    return dirs


def parse_feature_number(name: str) -> int | None:
    m = re.match(r"^(\d+)-", name)
    return int(m.group(1)) if m else None


def next_feature_number(root: Path) -> int:
    features = list_features(root)
    if not features:
        return 1
    nums = [parse_feature_number(d.name) for d in features]
    valid = [n for n in nums if n is not None]
    return max(valid) + 1 if valid else 1


def find_feature_dir(root: Path, feature: str) -> Path:
    """Resolve a feature identifier (NNN, NNN-slug, or full dir name) to a Path."""
    sd = specs_dir(root)
    if not sd.exists():
        die(f"No design/specs/ directory found at {root}")

    # Exact match first
    exact = sd / feature
    if exact.is_dir():
        return exact

    # Match by number prefix
    if re.match(r"^\d+$", feature):
        num = int(feature)
        for d in list_features(root):
            if parse_feature_number(d.name) == num:
                return d

    # Match by number prefix with slug
    for d in list_features(root):
        if d.name.startswith(feature):
            return d

    die(f"Feature '{feature}' not found in {sd}")


def find_wp_file(feature_dir: Path, wp_id: str) -> Path:
    """Find a WP file by ID within a feature directory."""
    tasks_dir = feature_dir / "tasks"
    if not tasks_dir.exists():
        die(f"No tasks/ directory in {feature_dir}")

    # Normalize: WP01, wp01, 01, 1 all work
    normalized = wp_id.upper()
    if not normalized.startswith("WP"):
        normalized = f"WP{int(normalized):02d}"

    target = tasks_dir / f"{normalized}.md"
    if target.exists():
        return target

    # Fuzzy: find any file whose stem starts with the normalized ID
    for f in sorted(tasks_dir.glob("WP*.md")):
        if f.stem.upper().startswith(normalized):
            return f

    die(f"WP file '{normalized}.md' not found in {tasks_dir}")


def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Frontmatter parsing (minimal YAML subset — key: "value" or key: value)
# ---------------------------------------------------------------------------


def parse_frontmatter(text: str) -> tuple[dict, str]:
    """Split --- frontmatter from body. Returns (fields_dict, body_text).

    Handles scalar values (quoted or unquoted) and simple inline arrays ([] or ["a"]).
    Multi-line YAML block scalars are not supported.
    """
    if not text.startswith("---"):
        return {}, text
    end = text.find("\n---", 3)
    if end == -1:
        return {}, text
    fm_block = text[3:end].strip()
    body = text[end + 4 :].lstrip("\n")
    fields: dict[str, Any] = {}
    for line in fm_block.splitlines():
        if ":" not in line:
            continue
        key, _, val = line.partition(":")
        key = key.strip()
        val = val.strip()
        # Inline array: [] or ["a", "b"]
        if val.startswith("["):
            try:
                parsed = json.loads(val)
                fields[key] = parsed
            except (json.JSONDecodeError, ValueError):
                fields[key] = val  # leave as string if unparseable
        else:
            fields[key] = val.strip('"').strip("'")
    return fields, body


def update_frontmatter_field(text: str, field: str, value: str) -> str:
    """Replace a scalar frontmatter field value in-place (frontmatter only)."""
    if not text.startswith("---"):
        die(f"Field '{field}' not found in frontmatter")
    end = text.find("\n---", 3)
    if end == -1:
        die(f"Field '{field}' not found in frontmatter")
    fm_section = text[: end + 4]  # "---\n...\n---"
    body = text[end + 4 :]
    pattern = re.compile(
        r"^(" + re.escape(field) + r':\s*)(".*?"|\'.*?\'|[^\n]*)',
        re.MULTILINE,
    )
    new_fm, count = pattern.subn(f'\\1"{value}"', fm_section, count=1)
    if count == 0:
        die(f"Field '{field}' not found in frontmatter")
    return new_fm + body


def read_wp_files(feature_dir: Path) -> list[dict[str, Any]]:
    """Read all WP*.md files in tasks/, return list of dicts with filename + frontmatter."""
    tasks_dir = feature_dir / "tasks"
    if not tasks_dir.exists():
        return []
    results = []
    for f in sorted(tasks_dir.glob("WP*.md")):
        text = f.read_text()
        fm, _ = parse_frontmatter(text)
        results.append({"filename": f.name, **fm})
    return results


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_next_number(args: argparse.Namespace) -> None:
    root = find_repo_root()
    n = next_feature_number(root)
    if args.json:
        print(json.dumps({"next_number": n}))
    else:
        print(n)


def cmd_init(args: argparse.Namespace) -> None:
    root = find_repo_root()
    slug = args.slug.lower().replace(" ", "-").replace("_", "-")
    # Strip leading digits if user passed them (e.g. "001-auth")
    slug = re.sub(r"^\d+-", "", slug)

    if not slug or slug.isdigit():
        die(f"Slug must be a non-empty, non-numeric string (got: '{slug}')")

    number = next_feature_number(root)
    padded = f"{number:03d}"
    feature_dir = specs_dir(root) / f"{padded}-{slug}"

    if feature_dir.exists():
        die(f"Feature directory already exists: {feature_dir}")

    tasks_dir = feature_dir / "tasks"
    tasks_dir.mkdir(parents=True)

    title = slug.replace("-", " ").title()
    date = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    spec_path = feature_dir / "spec.md"
    spec_path.write_text(
        SPEC_TEMPLATE.format(
            number=padded,
            slug=slug,
            title=title,
            date=date,
        )
    )

    result = {
        "feature_number": padded,
        "feature_slug": slug,
        "feature_dir": str(feature_dir.relative_to(root)),
        "spec_path": str(spec_path.relative_to(root)),
    }

    if args.json:
        print(json.dumps(result))
    else:
        print(f"Created: {result['feature_dir']}/")
        print(f"  spec.md: {result['spec_path']}")


def cmd_wp_move(args: argparse.Namespace) -> None:
    lane = args.lane.lower()
    if lane not in VALID_LANES:
        die(f"Invalid lane '{lane}'. Must be one of: {', '.join(VALID_LANES)}")

    root = find_repo_root()
    feature_dir = find_feature_dir(root, args.feature)
    wp_file = find_wp_file(feature_dir, args.wp_id)

    text = wp_file.read_text()
    fm, _ = parse_frontmatter(text)
    old_lane = fm.get("lane", "unknown")

    if old_lane == lane:
        if args.json:
            print(
                json.dumps(
                    {
                        "status": "no_change",
                        "lane": lane,
                        "file": str(wp_file.relative_to(root)),
                    }
                )
            )
        else:
            print(f"{wp_file.name}: already in lane '{lane}' — no change")
        return

    # Update lane field
    text = update_frontmatter_field(text, "lane", lane)

    # Append activity log entry
    date = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    log_entry = f"- {date} — system — lane={lane} — moved from {old_lane}"

    # Find Activity Log section and append
    if "## Activity Log" in text:
        text = text.rstrip() + "\n" + log_entry + "\n"
    else:
        text = text.rstrip() + "\n\n## Activity Log\n\n" + log_entry + "\n"

    wp_file.write_text(text)

    result = {
        "file": str(wp_file.relative_to(root)),
        "wp_id": fm.get("work_package_id", args.wp_id),
        "old_lane": old_lane,
        "new_lane": lane,
    }

    if args.json:
        print(json.dumps(result))
    else:
        print(f"{wp_file.name}: {old_lane} → {lane}")


def cmd_status(args: argparse.Namespace) -> None:
    root = find_repo_root()

    if args.feature:
        feature_dirs = [find_feature_dir(root, args.feature)]
    else:
        feature_dirs = list_features(root)

    if not feature_dirs:
        if args.json:
            print(json.dumps([]))
        else:
            print("No features found in design/specs/")
        return

    all_data = []
    for feature_dir in feature_dirs:
        wps = read_wp_files(feature_dir)
        lanes: dict[str, list[str]] = {k: [] for k in LANE_KEYS}
        for wp in wps:
            lane = wp.get("lane", "planned")
            wp_id = wp.get("work_package_id", Path(wp["filename"]).stem)
            if lane in lanes:
                lanes[lane].append(wp_id)
            else:
                lanes["planned"].append(wp_id)
        all_data.append({"feature": feature_dir.name, "lanes": lanes, "wps": wps})

    if args.json:
        print(json.dumps(all_data, indent=2))
        return

    for data in all_data:
        print(f"\nFeature: {data['feature']}")
        lanes = data["lanes"]
        columns = [lanes[k] for k in LANE_KEYS]
        max_rows = max((len(c) for c in columns), default=0)

        if max_rows == 0:
            print("  (no WP files found)")
            continue

        col_widths = [
            max(len(h), max((len(v) for v in col), default=0))
            for h, col in zip(LANE_HEADERS, columns)
        ]

        def row_sep(left: str, mid: str, right: str, fill: str) -> str:
            return left + mid.join(fill * (w + 2) for w in col_widths) + right

        print(row_sep("┌", "┬", "┐", "─"))
        header_cells = "│".join(f" {h:<{w}} " for h, w in zip(LANE_HEADERS, col_widths))
        print(f"│{header_cells}│")
        print(row_sep("├", "┼", "┤", "─"))

        for i in range(max_rows):
            cells = []
            for col, w in zip(columns, col_widths):
                val = col[i] if i < len(col) else ""
                cells.append(f" {val:<{w}} ")
            print(f"│{'│'.join(cells)}│")

        print(row_sep("└", "┴", "┘", "─"))


# ---------------------------------------------------------------------------
# CLI entry point
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="spec-helper",
        description="Work Package and spec directory management for the caliper v2 pipeline.",
    )
    parser.add_argument(
        "--json", action="store_true", help="Output JSON instead of human-readable text"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # init
    p_init = sub.add_parser(
        "init", help="Create design/specs/NNN-slug/ + spec.md template"
    )
    p_init.add_argument("slug", help="Feature slug (e.g. user-auth, payment-flow)")
    p_init.add_argument(
        "--json", action="store_true", dest="json_sub", help="Output JSON"
    )

    # wp-move
    p_move = sub.add_parser("wp-move", help="Move a WP to a new lane")
    p_move.add_argument(
        "feature", help="Feature identifier (NNN, NNN-slug, or full dir name)"
    )
    p_move.add_argument("wp_id", help="Work package ID (e.g. WP01, 01, 1)")
    p_move.add_argument("lane", help=f"Target lane: {', '.join(VALID_LANES)}")
    p_move.add_argument(
        "--json", action="store_true", dest="json_sub", help="Output JSON"
    )

    # status
    p_status = sub.add_parser(
        "status", help="Print terminal kanban for one or all features"
    )
    p_status.add_argument(
        "feature",
        nargs="?",
        default=None,
        help="Feature identifier (optional; all if omitted)",
    )
    p_status.add_argument(
        "--json", action="store_true", dest="json_sub", help="Output JSON"
    )

    # next-number
    p_next = sub.add_parser("next-number", help="Print next available feature number")
    p_next.add_argument(
        "--json", action="store_true", dest="json_sub", help="Output JSON"
    )

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    # Merge --json from global flag or subcommand flag
    args.json = getattr(args, "json", False) or getattr(args, "json_sub", False)

    dispatch = {
        "init": cmd_init,
        "wp-move": cmd_wp_move,
        "status": cmd_status,
        "next-number": cmd_next_number,
    }

    fn = dispatch.get(args.command)
    if fn is None:
        parser.print_help()
        sys.exit(1)

    fn(args)


if __name__ == "__main__":
    main()
