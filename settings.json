{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-issue:*)",
      "Bash(gh-pr-create:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Bash(ado-api:*)",
      "Read(/tmp/*)",
      "Read(/tmp/**)",
      "Write(/tmp/*)",
      "Write(/tmp/**)",
      "Edit(/tmp/*)",
      "Edit(/tmp/**)",
      "Bash(get-tmp-filename)",
      "Bash(get-skill-tmpdir:*)",
      "Bash(git-default-branch)",
      "Bash(git-branch-base)",
      "Bash(git-branch-log)",
      "Bash(git-branch-diff-stat)",
      "Bash(git-branch-diff-files)",
      "Bash(git-platform)",
      "Bash(cm-backfill-summaries:*)",
      "Bash(cm-clear-handoff:*)",
      "Bash(cm-consolidation-check:*)",
      "Bash(cm-import-conversations:*)",
      "Bash(cm-ingest-token-data:*)",
      "Bash(cm-memory-context:*)",
      "Bash(cm-memory-setup:*)",
      "Bash(cm-memory-sync:*)",
      "Bash(cm-onboarding:*)",
      "Bash(cm-recent-chats:*)",
      "Bash(cm-search-conversations:*)",
      "Bash(cm-sync-current:*)",
      "Bash(cm-write-config:*)",
      "Bash(git:*)",
      "Grep(/tmp/*)",
      "Grep(/tmp/**)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(pytest:*)",
      "Bash(timeout:*)",
      "Bash(agnix:*)",
      "Bash(ls:*)",
      "Bash(uv:*)",
      "Skill(mine.commit-push)",
      "Bash(claude-tmux:*)",
      "Bash(edit-manifest:*)",
      "Bash(which:*)",
      "Bash(pytest-loop-reset)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "includeGitInstructions": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/sudo-poll.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 35000
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/pytest-guard.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/pytest-loop-detector.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/context-tier.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/pytest-loop-reset.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/pytest-loop-status.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '(command -v uuidgen > /dev/null && uuidgen || python3 -c \"import uuid; print(uuid.uuid4())\") > \"${CLAUDE_CODE_TMPDIR:-/tmp}/claude-pytest-loop-session.id\"'",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/tmux-remind.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v cm-memory-setup >/dev/null 2>&1 && cm-memory-setup || true'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v cm-onboarding >/dev/null 2>&1 && cm-onboarding || true'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v cm-memory-context >/dev/null 2>&1 && cm-memory-context || true'",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash -c 'command -v cm-consolidation-check >/dev/null 2>&1 && cm-consolidation-check || true'",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v cm-clear-handoff >/dev/null 2>&1 && cm-clear-handoff || true'",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v cm-memory-sync >/dev/null 2>&1 && cm-memory-sync || true'",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
