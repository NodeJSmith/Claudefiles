{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Bash(ado-builds:*)",
      "Bash(ado-logs:*)",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)",
      "Bash(claude-log:*)",
      "Bash(get-tmp-filename)",
      "Bash(git-default-branch)",
      "Grep(/tmp/*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/block-git-c.js"
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": []
  }
}
