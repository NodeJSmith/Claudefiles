{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Bash(ado-builds:*)",
      "Bash(ado-logs:*)",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)",
      "Bash(claude-log:*)",
      "Bash(get-tmp-filename)",
      "Bash(git-default-branch)",
      "Bash(git:*)",
      "Grep(/tmp/*)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(pytest:*)",
      "Bash(agnix:*)"
    ],
    "defaultMode": "default"
  },
  "includeGitInstructions": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/block-git-c.js"
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": []
  }
}
