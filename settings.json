{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-issue:*)",
      "Bash(gh-pr-create:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Bash(ado-api:*)",
      "Read(/tmp/*)",
      "Read(/tmp/**)",
      "Write(/tmp/*)",
      "Write(/tmp/**)",
      "Edit(/tmp/*)",
      "Edit(/tmp/**)",
      "Bash(get-tmp-filename)",
      "Bash(get-skill-tmpdir:*)",
      "Bash(git-default-branch)",
      "Bash(git-branch-base)",
      "Bash(git-branch-log)",
      "Bash(git-branch-diff-stat)",
      "Bash(git-branch-diff-files)",
      "Bash(git-platform)",
      "Bash(git:*)",
      "Grep(/tmp/*)",
      "Grep(/tmp/**)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(pytest:*)",
      "Bash(timeout:*)",
      "Bash(agnix:*)",
      "Bash(ls:*)",
      "Bash(uv:*)",
      "Skill(mine-commit-push)",
      "Bash(claude-tmux:*)",
      "Bash(edit-manifest:*)",
      "Bash(which:*)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "extraKnownMarketplaces": {
    "claude-code-recall": {
      "source": {
        "source": "github",
        "repo": "NodeJSmith/claude-code-recall"
      }
    }
  },
  "enabledPlugins": {
    "ccrecall@claude-code-recall": true
  },
  "includeGitInstructions": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/sudo-poll.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 35000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/tmux-drift-check.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/subagent-compaction-check.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/tmux-remind.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [],
    "Stop": []
  }
}
