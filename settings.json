{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-issue:*)",
      "Bash(gh-pr-create:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Bash(ado-builds:*)",
      "Bash(ado-logs:*)",
      "Bash(ado-pr:*)",
      "Bash(ado-pr-threads:*)",
      "Read(/tmp/*)",
      "Read(/tmp/**)",
      "Write(/tmp/*)",
      "Write(/tmp/**)",
      "Edit(/tmp/*)",
      "Edit(/tmp/**)",
      "Bash(claude-log:*)",
      "Bash(get-tmp-filename)",
      "Bash(get-skill-tmpdir:*)",
      "Bash(git-default-branch)",
      "Bash(git-branch-base)",
      "Bash(git-branch-log)",
      "Bash(git-branch-diff-stat)",
      "Bash(git-branch-diff-files)",
      "Bash(git-platform)",
      "Bash(git:*)",
      "Grep(/tmp/*)",
      "Grep(/tmp/**)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(pytest:*)",
      "Bash(agnix:*)",
      "Bash(ls:*)",
      "Bash(uv:*)",
      "Skill(mine.commit-push)",
      "Bash(claude-tmux:*)",
      "Bash(which:*)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "includeGitInstructions": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/sudo-poll.sh",
            "timeout": 35000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/track-edited-files.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_HOME:-$HOME/.claude}/scripts/hooks/tmux-remind.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
