{
  "permissions": {
    "allow": [
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(gh-pr-reply:*)",
      "Bash(gh-pr-resolve-thread:*)",
      "Bash(gh-pr-threads:*)",
      "Read(/tmp/*)",
      "Write(/tmp/*)",
      "Edit(/tmp/*)",
      "Bash(claude-log:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/block-git-c.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/pre-compact-save.js",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/hooks/post-compact-inject.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
