{
  "permissions": {
    "allow": [
      "Edit(//tmp/**)",
      "Bash(cfl:*)",
      "Bash(get-skill-tmpdir:*)",
      "Bash(get-tmp-filename)",
      "Bash(ruff:*)",
      "Bash(pyright:*)",
      "Bash(pytest:*)",
      "Skill(mine-commit-push)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "extraKnownMarketplaces": {
    "claude-code-recall": {
      "source": {
        "source": "github",
        "repo": "NodeJSmith/claude-code-recall"
      }
    }
  },
  "enabledPlugins": {
    "ccrecall@claude-code-recall": true
  },
  "includeGitInstructions": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/sudo-poll.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 35000
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/tmux-drift-check.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/subagent-model-default.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/subagent-compaction-check.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/dispatch-stats.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/tmux-remind.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/cfl-stop-orphans.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/scripts/hooks/project-meta-prompt.sh\"; [ -x \"$f\" ] && exec \"$f\" || exit 0'",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [],
    "Stop": []
  },
  "env": {}
}
